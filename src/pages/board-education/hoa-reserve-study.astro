---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 56px; position: relative; overflow: hidden; }
    .page-hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 92% 8%, rgba(149,208,49,0.14) 0%, transparent 38%), radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%); pointer-events: none; }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 36px; }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light { display: block; margin-top: 8px; font-family: var(--font-body); font-weight: 300; font-style: italic; color: rgba(255,255,255,0.55); font-size: 0.48em; letter-spacing: -0.02em; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }
    
    .page-hero { padding: 56px 0 40px; }
    .page-hero .meta-row { display: flex; gap: 24px; align-items: center; margin: 20px 0 0; padding-top: 14px; border-top: 1px solid rgba(255,255,255,0.18); font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,0.5); letter-spacing: 0.06em; text-transform: uppercase; }
    .page-hero .meta-row .green { color: var(--innovia-green); }
  
  
    .article-body { padding: 32px 0 96px; }
    .article-body .layout { display: grid; grid-template-columns: 220px 1fr; gap: 64px; align-items: start; }
    .article-body .toc { position: sticky; top: 96px; }
    .article-body .toc h6 { font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.45); letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.14); }
    .article-body .toc ol { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; counter-reset: tocnum; }
    .article-body .toc li { counter-increment: tocnum; }
    .article-body .toc a { font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; padding-left: 24px; position: relative; display: block; line-height: 1.4; transition: color .15s; }
    .article-body .toc a::before { content: counter(tocnum, decimal-leading-zero); position: absolute; left: 0; color: var(--innovia-green); font-size: 10px; }
    .article-body .toc a:hover { color: #fff; }

    .article-body .content { max-width: 66ch; }
    .article-body .content .lede-graf { font-family: var(--font-display); font-weight: 500; font-size: 22px; line-height: 1.45; color: #fff; margin: 0 0 32px; letter-spacing: -0.01em; }
    .article-body .content .lede-graf::first-letter { font-family: var(--font-display); font-weight: 900; font-size: 84px; float: left; line-height: 0.8; margin: 6px 14px 0 0; color: var(--innovia-green); }
    .article-body .content h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 3vw, 38px); color: #fff; letter-spacing: -0.018em; margin: 56px 0 18px; line-height: 1.1; scroll-margin-top: 96px; }
    .article-body .content h3 { font-family: var(--font-display); font-weight: 700; font-size: 20px; color: #fff; letter-spacing: -0.008em; margin: 32px 0 10px; }
    .article-body .content p { font-size: 17px; line-height: 1.7; color: rgba(255,255,255,0.78); margin: 0 0 18px; }
    .article-body .content strong { color: #fff; }
    .article-body .content .pull { font-family: var(--font-display); font-weight: 500; font-style: italic; font-size: 24px; line-height: 1.4; color: #fff; padding: 24px 28px; margin: 32px 0; background: rgba(149,208,49,0.06); border-left: 3px solid var(--innovia-green); letter-spacing: -0.005em; }
    .article-body .content .pull cite { display: block; margin-top: 14px; font-family: var(--font-mono); font-style: normal; font-size: 12px; color: rgba(255,255,255,0.55); letter-spacing: 0.06em; text-transform: uppercase; }
    .article-body .content ul, .article-body .content ol { padding-left: 24px; margin: 0 0 18px; }
    .article-body .content li { font-size: 17px; line-height: 1.65; color: rgba(255,255,255,0.78); margin-bottom: 8px; }
    .article-body .content .figure { margin: 32px 0; padding: 24px 28px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); }
    .article-body .content .figure .cap { font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 12px; }
    .article-body .content .figure h4 { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff; margin: 0 0 8px; letter-spacing: -0.008em; }
    .article-body .content .figure p { font-size: 14px; line-height: 1.55; color: rgba(255,255,255,0.65); margin: 0 0 6px; }

    .inline-cta { margin: 48px 0; padding: 28px 32px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; gap: 28px; align-items: center; justify-content: space-between; flex-wrap: wrap; }
    .inline-cta strong { display: block; font-family: var(--font-display); font-weight: 700; color: #fff; font-size: 17px; }
    .inline-cta span { font-size: 14px; color: rgba(255,255,255,0.7); margin-top: 4px; display: block; }

    .article-foot { margin-top: 64px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.18); display: flex; justify-content: space-between; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.55); letter-spacing: 0.04em; }
    .article-foot .share { display: flex; gap: 14px; }
    .article-foot .share a { color: rgba(255,255,255,0.6); }
    .article-foot .share a:hover { color: var(--innovia-green); }

    .related-spokes { padding: 80px 0 96px; background: var(--innovia-navy-deep); border-top: 1px solid rgba(255,255,255,0.08); }
    .related-spokes h2 { font-family: var(--font-display); font-weight: 700; font-size: 28px; color: #fff; margin: 0 0 24px; letter-spacing: -0.014em; }
    .related-spokes .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .related-spokes a { padding: 24px 26px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit; transition: border-color .15s; }
    .related-spokes a:hover { border-color: var(--innovia-green); }
    .related-spokes a .cat { font-family: var(--font-mono); font-size: 10px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; }
    .related-spokes a h3 { font-family: var(--font-display); font-weight: 700; font-size: 17px; color: #fff; letter-spacing: -0.005em; margin: 0; line-height: 1.3; }

    @media (max-width: 1080px) { .article-body .layout { grid-template-columns: 1fr; gap: 32px; } .article-body .toc { position: static; } .related-spokes .grid { grid-template-columns: 1fr; } }
  </style>



  <section class="page-hero">
    <div class="container">
      
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <a href="/board-education/">Board Resources</a>
        <span>/</span>
        <span style="color:#fff;">Reserve Study Guide</span>
      </div>
      <h1>The HOA <em>reserve study</em><br><span class="light">guide every board should keep open.</span></h1>
      <p class="lede">What a reserve study is, the statutory triggers by state, the funding strategies that actually hold up, and the questions a board should be asking their management company about all of it.</p>
      <div class="meta-row">
        <span><span class="green">Topic</span> &middot; Financials &amp; Reserves</span>
        <span><span class="green">Read</span> &middot; <span class="placeholder placeholder-inline">12 min</span></span>
        <span><span class="green">Updated</span> &middot; <span class="placeholder placeholder-inline">May 2026</span></span>
      </div>
    </div>
  </section>

  <section class="article-body">
    <div class="container">
      <div class="layout">
        <aside class="toc">
          <h6>In this guide</h6>
          <ol>
            <li><a href="#what">What a reserve study is</a></li>
            <li><a href="#levels">Levels 1, 2, 3</a></li>
            <li><a href="#triggers">State-by-state triggers</a></li>
            <li><a href="#funding">Funding strategies</a></li>
            <li><a href="#mistakes">Common mistakes</a></li>
            <li><a href="#asking">Questions to ask</a></li>
          </ol>
        </aside>

        <article class="content">
          <p class="lede-graf">A reserve study is the single most important document on your board&rsquo;s shelf. It tells you what needs replacing, when, and what it will cost &mdash; and whether the dues you&rsquo;re collecting today will cover it.</p>

          <h2 id="what">What a reserve study is.</h2>
          <p>A reserve study is a forward-looking capital plan: an inventory of every major asset the association is responsible for, a projection of when each will need replacement or major repair, and a funding model showing how the association should accumulate reserves to pay for it without a special assessment.</p>
          <p>It typically covers a <strong>30-year horizon</strong>, gets updated every 3&ndash;5 years, and is performed by a credentialed reserve specialist (RS or PRA designation).</p>

          <h2 id="levels">The three levels: 1, 2, and 3.</h2>
          <p>Reserve studies come in three flavors. Understanding which one your association has &mdash; and which one it needs &mdash; matters.</p>

          <div class="figure">
            <span class="cap">Reference</span>
            <h4>Level 1: Full study</h4>
            <p>On-site visual inspection, complete inventory measurement, full financial analysis. Recommended every 5&ndash;7 years.</p>
            <h4 style="margin-top: 14px;">Level 2: Update with on-site review</h4>
            <p>Re-inspect, but use existing inventory data. Refresh costs and reserves balance.</p>
            <h4 style="margin-top: 14px;">Level 3: Update with no site visit</h4>
            <p>Desk-only refresh of the funding model. Cheapest but least reliable.</p>
          </div>

          <p class="pull">"A board with no reserve study is a board running on luck. A board with a 10-year-old reserve study is a board running on luck that hasn&rsquo;t caught up to them yet."<cite>&mdash; <span class="placeholder placeholder-inline">Member-firm reserve specialist · paraphrased</span></cite></p>

          <h2 id="triggers">State-by-state statutory triggers.</h2>
          <p><span class="placeholder placeholder-inline">[Section: cover the states with statutory requirements &mdash; California (Davis-Stirling), Florida (post-Surfside), Colorado, Washington, Nevada. Note Federal lending requirements for FHA / Fannie / Freddie eligibility.]</span></p>

          <div class="inline-cta">
            <div>
              <strong>Need a manager who actually reads your reserve study?</strong>
              <span>Innovia-backed companies treat the reserve study as the operating document, not a binder. We&rsquo;ll match you to a member in your area.</span>
            </div>
            <a href="/find-a-management-company/#request" class="btn btn-primary">Send the inquiry
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <h2 id="funding">Funding strategies: fully funded, threshold, baseline.</h2>
          <p><span class="placeholder placeholder-inline">[Section: explain the three funding approaches, with the trade-offs. Include a worked example of how dues change under each.]</span></p>

          <h2 id="mistakes">Common mistakes.</h2>
          <p><span class="placeholder placeholder-inline">[Section: the five mistakes boards make &mdash; postponing the study, choosing the cheapest reserve specialist, ignoring the funding recommendation, treating the study as static, not informing owners.]</span></p>

          <h2 id="asking">Questions every board should ask.</h2>
          <p><span class="placeholder placeholder-inline">[Section: 8&ndash;10 specific questions a board can ask its management company about how they use the reserve study.]</span></p>

          <div class="article-foot">
            <span>By <span class="placeholder placeholder-inline">Innovia editorial team</span></span>
            <div class="share">
              <a href="#">LinkedIn</a>
              <a href="#">Email</a>
              <a href="#">Print</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="related-spokes">
    <div class="container">
      <h2>Read next.</h2>
      <div class="grid">
        <a href="/board-education/hoa-governance/">
          <span class="cat">Governance</span>
          <h3>HOA Governance: A Board&rsquo;s Quick Reference</h3>
        </a>
        <a href="/board-education/hoa-management-fees/">
          <span class="cat">Financials</span>
          <h3>HOA Management Fees Explained</h3>
        </a>
        <a href="/board-education/hoa-transition-from-developer/">
          <span class="cat">Transition</span>
          <h3>HOA Transition from Developer: A Board&rsquo;s Guide</h3>
        </a>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="The HOA Reserve Study Guide · Innovia Co-op"
  description="The HOA Reserve Study Guide · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  ctaLabel="Send Inquiry"
  ctaHref="/find-a-management-company/#request"
>
  <Fragment set:html={html} />
</BaseLayout>
