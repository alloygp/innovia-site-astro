---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    /* This page uses the DEFAULT light header from site.css — no override. */
    body { background: #FBFAF6; color: var(--fg-2); }

    /* ---------- Page hero (light, cream) ---------- */
    .page-hero {
      padding: 72px 0 56px;
      background: #FBFAF6;
      border-bottom: 1px solid var(--border-subtle);
    }
    .page-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: var(--fg-3); letter-spacing: 0.04em;
      margin-bottom: 32px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border-subtle);
    }
    .page-hero .crumb a:hover { color: var(--innovia-navy); }
    .page-hero .crumb .right { margin-left: auto; display: flex; align-items: center; gap: 12px; }
    .page-hero .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green-deep);
    }
    .page-hero .crumb .right .badge {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 10px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      font-family: var(--font-display); font-weight: 700;
      font-size: 10px; letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .page-hero .title-row {
      display: grid; grid-template-columns: 1.5fr 1fr;
      gap: 80px; align-items: end;
    }
    .page-hero h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(52px, 7.2vw, 116px);
      line-height: 0.94;
      letter-spacing: -0.04em;
      color: var(--innovia-navy); margin: 0;
      text-wrap: balance;
    }
    .page-hero h1 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 700; }
    .page-hero .meta-stack {
      display: flex; flex-direction: column; gap: 18px;
      padding-bottom: 6px;
    }
    .page-hero .meta-stack p {
      font-size: 16px; line-height: 1.6;
      color: var(--fg-2);
      margin: 0; max-width: 42ch;
    }
    .page-hero .meta-stack p strong { color: var(--innovia-navy); font-weight: 600; }
    .page-hero .meta-stack .reading {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3);
      letter-spacing: 0.1em; text-transform: uppercase;
    }

    /* TOC strap under hero */
    .toc-strap {
      margin-top: 56px;
      padding: 28px 0 0;
      border-top: 1px solid var(--border-subtle);
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 24px;
      align-items: start;
    }
    .toc-strap .label {
      font-family: var(--font-mono); font-size: 10px;
      color: var(--fg-3);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding-top: 4px;
    }
    .toc-strap .items {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      border-left: 1px solid var(--border-subtle);
    }
    .toc-strap .items a {
      padding: 4px 16px;
      border-right: 1px solid var(--border-subtle);
      display: flex; flex-direction: column; gap: 4px;
      transition: background .15s;
    }
    .toc-strap .items a:hover { background: rgba(149,208,49,0.10); }
    .toc-strap .items a:last-child { border-right: 0; }
    .toc-strap .items .n {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep);
      letter-spacing: 0.06em;
      font-weight: 700;
    }
    .toc-strap .items .t {
      font-family: var(--font-display); font-weight: 600;
      font-size: 13px;
      color: var(--innovia-navy);
      letter-spacing: -0.005em;
      line-height: 1.25;
    }

    /* ---------- Section base ---------- */
    .sec { padding: 112px 0; background: #fff; }
    .sec.cream { background: #FBFAF6; }
    .sec.navy { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .sec .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 56px;
    }
    .sec h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.4vw, 60px);
      letter-spacing: -0.028em;
      max-width: 18ch;
      margin: 14px 0 0;
    }
    .sec h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .sec.navy h2 { color: #fff; }
    .sec.navy h2 em { color: var(--innovia-green); font-style: normal; }
    .sec .head p {
      font-size: 17px; line-height: 1.6;
      color: var(--fg-2);
      max-width: 52ch; margin: 0;
    }
    .sec.navy .head p { color: rgba(255,255,255,0.74); }
    .sec .head p strong { color: var(--innovia-navy); font-weight: 600; }
    .sec.navy .head p strong { color: #fff; }

    /* ---------- 01 · DIAGRAM section ---------- */
    .diagram-section {
      padding: 96px 0 112px;
      background: #fff;
    }
    .diagram-section .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .diagram-section h2 {
      color: var(--innovia-navy);
      font-size: clamp(34px, 4vw, 52px);
      letter-spacing: -0.026em;
      max-width: 22ch; margin: 14px 0 0;
    }
    .diagram-section h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .diagram-section .head p {
      font-size: 16px; line-height: 1.6;
      color: var(--fg-2);
      max-width: 50ch; margin: 0;
    }
    .diagram-frame {
      background: #FBFAF6;
      border: 1px solid var(--border-subtle);
      padding: 64px 48px 56px;
      display: flex; flex-direction: column;
      align-items: center; gap: 32px;
    }
    .diagram-frame svg { width: 100%; max-width: 880px; height: auto; }
    .diagram-legend {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      padding-top: 28px;
      border-top: 1px solid var(--border-subtle);
      width: 100%;
    }
    .diagram-legend .item {
      display: flex; flex-direction: column; gap: 6px;
    }
    .diagram-legend .item .swatch {
      display: flex; align-items: center; gap: 10px;
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-navy);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .diagram-legend .item .swatch::before {
      content: "";
      width: 14px; height: 14px;
      display: inline-block;
      background: var(--c, var(--innovia-navy));
    }
    .diagram-legend .item p {
      font-size: 13px; line-height: 1.5;
      color: var(--fg-2);
      margin: 0;
    }

    /* ---------- 02 · WHAT A MANAGER DOES ---------- */
    .does-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    .does-card {
      background: #fff;
      border: 1px solid var(--border-subtle);
      padding: 36px 36px 32px;
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: 22px;
      transition: border-color .2s, box-shadow .2s;
    }
    .does-card:hover { border-color: var(--innovia-green); box-shadow: var(--shadow-2); }
    .does-card .icon {
      width: 56px; height: 56px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .does-card .body {
      display: flex; flex-direction: column; gap: 12px;
    }
    .does-card .body .num {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .does-card .body h3 {
      font-family: var(--font-display); font-weight: 800;
      font-size: 24px;
      color: var(--innovia-navy);
      letter-spacing: -0.016em;
      margin: 0;
      line-height: 1.15;
    }
    .does-card .body > p {
      font-size: 14.5px; line-height: 1.6;
      color: var(--fg-2);
      margin: 0;
      max-width: 56ch;
    }
    .does-card ul {
      margin: 8px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 18px;
    }
    .does-card ul li {
      font-size: 13.5px;
      color: var(--fg-2);
      line-height: 1.4;
      padding-left: 16px;
      position: relative;
    }
    .does-card ul li::before {
      content: "";
      position: absolute;
      left: 0; top: 9px;
      width: 6px; height: 1px;
      background: var(--innovia-green-deep);
    }

    /* ---------- 03 · WHAT A MANAGER DOESN'T DO ---------- */
    .doesnt-section {
      padding: 112px 0;
      background: #FBFAF6;
    }
    .doesnt-section .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .doesnt-section h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.4vw, 60px);
      letter-spacing: -0.028em;
      max-width: 18ch;
      margin: 14px 0 0;
    }
    .doesnt-section h2 em { color: var(--danger); font-style: italic; font-weight: 400; }
    .doesnt-section .head p {
      font-size: 17px; line-height: 1.6;
      color: var(--fg-2);
      max-width: 52ch; margin: 0;
    }
    .doesnt-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--danger);
      border-bottom: 1px solid var(--border-subtle);
      background: #fff;
    }
    .doesnt-card {
      padding: 36px 28px 32px;
      border-right: 1px solid var(--border-subtle);
      display: flex; flex-direction: column;
      gap: 14px;
    }
    .doesnt-card:last-child { border-right: 0; }
    .doesnt-card .x {
      width: 36px; height: 36px;
      background: rgba(178, 58, 58, 0.10);
      color: var(--danger);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 900;
      font-size: 20px;
    }
    .doesnt-card h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 19px;
      color: var(--innovia-navy);
      letter-spacing: -0.014em;
      line-height: 1.2;
      margin: 0;
    }
    .doesnt-card p {
      font-size: 13.5px; line-height: 1.6;
      color: var(--fg-2);
      margin: 0;
    }
    .doesnt-card .footnote {
      margin-top: auto;
      padding-top: 14px;
      border-top: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3);
      letter-spacing: 0.04em;
    }

    /* ---------- 04 · PRICING EXPLAINER ---------- */
    .pricing-section {
      padding: 112px 0;
      background: #fff;
    }
    .pricing-section .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .pricing-section h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.4vw, 60px);
      letter-spacing: -0.028em;
      max-width: 18ch;
      margin: 14px 0 0;
    }
    .pricing-section h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .pricing-section .head p {
      font-size: 17px; line-height: 1.6;
      color: var(--fg-2);
      max-width: 52ch; margin: 0;
    }
    .pricing-section .head p strong { color: var(--innovia-navy); font-weight: 600; }
    .pricing-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 0;
      background: #fff;
      border: 1px solid var(--border-subtle);
    }
    .pricing-grid .col {
      padding: 36px 32px 32px;
      border-right: 1px solid var(--border-subtle);
      display: flex; flex-direction: column;
      gap: 14px;
    }
    .pricing-grid .col:last-child { border-right: 0; }
    .pricing-grid .col .kind {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .pricing-grid .col h4 {
      font-family: var(--font-display); font-weight: 800;
      font-size: 22px;
      color: var(--innovia-navy);
      letter-spacing: -0.016em;
      margin: 0;
      line-height: 1.15;
    }
    .pricing-grid .col .range {
      font-family: var(--font-display); font-weight: 900;
      font-size: 32px;
      color: var(--innovia-green-deep);
      letter-spacing: -0.025em;
      line-height: 0.95;
    }
    .pricing-grid .col .range .lbl {
      display: block;
      font-family: var(--font-mono); font-size: 11px;
      font-weight: 400;
      color: var(--fg-3);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-top: 6px;
    }
    .pricing-grid .col p {
      font-size: 14px; line-height: 1.55;
      color: var(--fg-2);
      margin: 0;
    }
    .pricing-grid .col .what-includes {
      margin-top: auto;
      padding-top: 16px;
      border-top: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3);
      letter-spacing: 0.04em;
    }
    .pricing-grid .col.feat {
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
    }
    .pricing-grid .col.feat .kind { color: var(--innovia-green); }
    .pricing-grid .col.feat h4 { color: #fff; }
    .pricing-grid .col.feat .range { color: var(--innovia-green); }
    .pricing-grid .col.feat .range .lbl { color: rgba(255,255,255,0.5); }
    .pricing-grid .col.feat p { color: rgba(255,255,255,0.74); }
    .pricing-grid .col.feat .what-includes { border-top-color: rgba(255,255,255,0.18); color: rgba(255,255,255,0.5); }
    .pricing-footnote {
      margin-top: 14px;
      padding: 16px 20px;
      background: var(--innovia-green-soft);
      color: var(--innovia-navy);
      font-size: 13.5px;
      line-height: 1.55;
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 16px;
    }
    .pricing-footnote .k {
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .pricing-footnote p { margin: 0; }

    /* ---------- 05 · 8 SIGNS CHECKLIST ---------- */
    .checklist-section {
      padding: 112px 0;
      background: #FBFAF6;
    }
    .checklist-section .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .checklist-section h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.4vw, 60px);
      letter-spacing: -0.028em;
      max-width: 18ch;
      margin: 14px 0 0;
    }
    .checklist-section h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .checklist-section .head p {
      font-size: 17px; line-height: 1.6;
      color: var(--fg-2);
      max-width: 52ch; margin: 0;
    }
    .checks {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    .check {
      background: #fff;
      border: 1px solid var(--border-subtle);
      padding: 24px 28px;
      display: grid;
      grid-template-columns: 28px 36px 1fr;
      gap: 18px;
      align-items: start;
      transition: border-color .2s;
    }
    .check:hover { border-color: var(--innovia-green); }
    .check .n {
      font-family: var(--font-mono); font-size: 12px;
      color: var(--fg-3);
      letter-spacing: 0.04em;
      padding-top: 4px;
    }
    .check .tick {
      width: 28px; height: 28px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      margin-top: 0;
    }
    .check .body {
      display: flex; flex-direction: column; gap: 6px;
    }
    .check h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 16px;
      color: var(--innovia-navy);
      letter-spacing: -0.012em;
      margin: 0;
      line-height: 1.3;
    }
    .check p {
      font-size: 13.5px; line-height: 1.55;
      color: var(--fg-2);
      margin: 0;
    }

    /* ---------- 06 · INNOVIA BRIDGE (dark) ---------- */
    .bridge {
      padding: 112px 0;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
      position: relative; overflow: hidden;
    }
    .bridge::before {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 88% 8%, rgba(149,208,49,0.12) 0%, transparent 40%),
        radial-gradient(circle at 8% 92%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .bridge .container { position: relative; z-index: 1; }
    .bridge .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .bridge h2 {
      color: #fff;
      font-size: clamp(38px, 4.6vw, 60px);
      letter-spacing: -0.028em;
      max-width: 18ch;
      margin: 14px 0 0;
    }
    .bridge h2 em { color: var(--innovia-green); font-style: normal; }
    .bridge .head p {
      color: rgba(255,255,255,0.74);
      font-size: 17px; line-height: 1.6;
      max-width: 52ch; margin: 0;
    }
    .bridge .head p strong { color: #fff; font-weight: 600; }
    .bridge .three {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 2px solid var(--innovia-green);
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .bridge .three .item {
      padding: 36px 28px 28px;
      border-right: 1px solid rgba(255,255,255,0.12);
      display: flex; flex-direction: column;
      gap: 12px;
    }
    .bridge .three .item:last-child { border-right: 0; }
    .bridge .three .item .num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 44px;
      color: var(--innovia-green);
      letter-spacing: -0.03em;
      line-height: 0.9;
    }
    .bridge .three .item h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 20px;
      color: #fff;
      letter-spacing: -0.014em;
      margin: 0;
      line-height: 1.2;
    }
    .bridge .three .item p {
      font-size: 14px; line-height: 1.6;
      color: rgba(255,255,255,0.7);
      margin: 0;
    }
    .bridge .find {
      margin-top: 32px;
      display: flex; align-items: center;
      justify-content: space-between;
      gap: 32px;
      padding: 22px 28px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.14);
    }
    .bridge .find .lhs {
      display: flex; align-items: center; gap: 22px;
    }
    .bridge .find .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.6);
    }
    .bridge .find p {
      font-family: var(--font-display); font-weight: 500;
      font-size: 17px;
      color: #fff;
      margin: 0;
    }
    .bridge .find a {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 12px 22px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      font-family: var(--font-display);
      font-weight: 600; font-size: 14px;
      letter-spacing: 0.005em;
      transition: background .15s, transform .15s;
    }
    .bridge .find a:hover { background: var(--innovia-green-deep); }
    .bridge .find a .arrow { transition: transform .2s var(--ease-out); }
    .bridge .find a:hover .arrow { transform: translateX(3px); }

    /* ---------- 07 · CTA finale (green) ---------- */
    .cta-finale {
      padding: 140px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .cta-finale .frame {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 80px; align-items: center;
    }
    .cta-finale h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 5.4vw, 80px);
      letter-spacing: -0.03em;
      line-height: 0.98;
      max-width: 16ch;
      margin: 14px 0 0;
    }
    .cta-finale h2 em { color: #fff; font-style: normal; }
    .cta-finale .lead {
      max-width: 50ch; margin-top: 18px;
      font-size: 17px; line-height: 1.55;
      color: var(--innovia-navy);
      opacity: 0.82;
    }
    .cta-finale .actions { display: flex; flex-direction: column; gap: 10px; }
    .cta-finale .actions .btn { padding: 18px 28px; font-size: 16px; justify-content: center; }
    .cta-finale .actions .btn-navy { background: var(--innovia-navy); color: #fff; }
    .cta-finale .actions .btn-navy:hover { background: var(--innovia-navy-deep); }
    .cta-finale .actions .btn-outline { color: var(--innovia-navy); border-color: var(--innovia-navy); }
    .cta-finale .actions .btn-outline:hover { background: var(--innovia-navy); color: #fff; }

    @media (max-width: 1080px) {
      .page-hero .title-row,
