---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 56px; position: relative; overflow: hidden; }
    .page-hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 92% 8%, rgba(149,208,49,0.14) 0%, transparent 38%), radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%); pointer-events: none; }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 36px; }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light { display: block; margin-top: 8px; font-family: var(--font-body); font-weight: 300; font-style: italic; color: rgba(255,255,255,0.55); font-size: 0.48em; letter-spacing: -0.02em; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }
    
  
    .services-grid { padding: 24px 0 32px; }
    .services-grid .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border-top: 2px solid var(--innovia-green); border-bottom: 1px solid rgba(255,255,255,0.18); }
    .services-grid .svc { padding: 36px 32px; border-right: 1px solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 14px; text-decoration: none; color: inherit; transition: background .2s; }
    .services-grid .svc:last-child { border-right: 0; }
    .services-grid .svc:hover { background: rgba(149,208,49,0.06); }
    .services-grid .svc .ix { font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; }
    .services-grid .svc h3 { font-family: var(--font-display); font-weight: 700; font-size: 24px; color: #fff; letter-spacing: -0.014em; margin: 0; }
    .services-grid .svc p { font-size: 14px; line-height: 1.55; color: rgba(255,255,255,0.65); margin: 0; }
    .services-grid .svc .go { margin-top: auto; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.10); font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; }

    .sub-services { padding: 32px 0 96px; }
    .sub-services .head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 32px; }
    .sub-services h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(24px, 2.6vw, 32px); color: #fff; letter-spacing: -0.014em; margin: 0; }
    .sub-services .head p { color: rgba(255,255,255,0.6); font-size: 13px; font-family: var(--font-mono); letter-spacing: 0.04em; }
    .sub-services .row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .sub-services .sub { padding: 28px 30px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 10px; text-decoration: none; color: inherit; transition: border-color .15s, background .15s; }
    .sub-services .sub:hover { border-color: var(--innovia-green); background: rgba(149,208,49,0.06); }
    .sub-services .sub h4 { font-family: var(--font-display); font-weight: 700; font-size: 20px; color: #fff; letter-spacing: -0.01em; margin: 0; }
    .sub-services .sub p { font-size: 13px; line-height: 1.55; color: rgba(255,255,255,0.62); margin: 0; }

    .trust-band { background: var(--innovia-navy-deep); padding: 64px 0; border-top: 1px solid rgba(255,255,255,0.08); }
    .trust-band .row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
    .trust-band .cell { padding: 0 32px; border-right: 1px solid rgba(255,255,255,0.10); display: flex; flex-direction: column; gap: 8px; }
    .trust-band .cell:last-child { border-right: 0; }
    .trust-band .num { font-family: var(--font-display); font-weight: 900; font-size: 56px; line-height: 0.9; color: #fff; letter-spacing: -0.035em; }
    .trust-band .num .pct { color: var(--innovia-green); }
    .trust-band .label { font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,0.55); letter-spacing: 0.12em; text-transform: uppercase; }

    .cta-band { padding: 96px 0; background: var(--innovia-green); color: var(--innovia-navy); }
    .cta-band .frame { display: grid; grid-template-columns: 1.4fr 1fr; gap: 64px; align-items: center; }
    .cta-band h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(36px, 4vw, 56px); color: var(--innovia-navy); letter-spacing: -0.024em; margin: 0; max-width: 18ch; }
    .cta-band h2 em { font-style: italic; font-weight: 400; }
    .cta-band p { margin: 20px 0 0; font-size: 16px; line-height: 1.55; max-width: 50ch; }
    .cta-band .actions { display: flex; flex-direction: column; gap: 12px; }
    .cta-band .actions .btn { justify-content: center; padding: 16px 24px; font-size: 15px; }

    @media (max-width: 1080px) { .services-grid .grid, .sub-services .row, .trust-band .row, .cta-band .frame { grid-template-columns: 1fr; gap: 32px; } .services-grid .svc { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.12); } .trust-band .cell { border-right: 0; padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.10); } }
  </style>



  <section class="page-hero">
    <div class="container">
      
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <a href="/find-a-management-company/">For Boards</a>
        <span>/</span>
        <span style="color:#fff;">HOA Management Services</span>
      </div>
      <h1>HOA management <em>services.</em><span class="light">cooperatively backed. independently owned. locally delivered.</span></h1>
      <p class="lede">Every Innovia-backed management company delivers the same core services to the communities they serve &mdash; with the cooperative&rsquo;s training, vendor terms, and shared intelligence behind every contract. Pick the property type or sub-service below.</p>
    </div>
  </section>

  <section class="services-grid">
    <div class="container">
      <div class="grid">
        <a class="svc" href="/hoa-management-services/single-family-hoa/">
          <span class="ix">Service 01</span>
          <h3>Single-Family HOA Management</h3>
          <p>Covenants, common-area maintenance, capital planning, board support &mdash; for single-family-home associations of every size.</p>
          <span class="go">Read more &rarr;</span>
        </a>
        <a class="svc" href="/hoa-management-services/condominium-management/">
          <span class="ix">Service 02</span>
          <h3>Condominium Association Management</h3>
          <p>The building-level expertise condominiums need: structural reserves, statutory reporting, capital projects, and unit-owner communications.</p>
          <span class="go">Read more &rarr;</span>
        </a>
        <a class="svc" href="/hoa-management-services/townhome-management/">
          <span class="ix">Service 03</span>
          <h3>Townhome Association Management</h3>
          <p>The shared-wall, shared-yard middle ground: townhome and PUD management that respects both the homeowner and the association.</p>
          <span class="go">Read more &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="sub-services">
    <div class="container">
      <div class="head">
        <h2>Sub-services.</h2>
        <p>Targeted deliverables, not full management</p>
      </div>
      <div class="row">
        <a class="sub" href="/hoa-management-services/accounting-bookkeeping/">
          <h4>HOA Accounting &amp; Bookkeeping</h4>
          <p>Reserve studies, monthly close, board reporting, audit prep &mdash; from member firms with HOA-specific accounting teams.</p>
        </a>
        <a class="sub" href="/hoa-management-services/covenant-enforcement/">
          <h4>Covenant Enforcement</h4>
          <p>Notice, follow-up, hearing scheduling, and the documentation a board needs to enforce its CC&amp;Rs without making enemies.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="trust-band">
    <div class="container">
      <div class="row">
        <div class="cell"><span class="num">80<span class="pct">+</span></span><span class="label">Member companies</span></div>
        <div class="cell"><span class="num">1.4M<span class="pct">+</span></span><span class="label">Households served</span></div>
        <div class="cell"><span class="num">25+</span><span class="label">States represented</span></div>
        <div class="cell"><span class="num placeholder placeholder-inline">$24M<span class="pct">+</span></span><span class="label">Lifetime vendor savings</span></div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <div class="frame">
        <div>
          <h2>Find the <em>right member</em> for your community.</h2>
          <p>One inquiry. One match. The Innovia-backed company best positioned to serve your association reaches out within two business days.</p>
        </div>
        <div class="actions">
          <a href="/find-a-management-company/#request" class="btn btn-navy">Send the inquiry
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
          <a href="/board-education/" class="btn btn-outline" style="color: var(--innovia-navy); border-color: var(--innovia-navy);">Or read the board guides</a>
        </div>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="HOA Management Services · Innovia Co-op"
  description="HOA Management Services · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  ctaLabel="Send Inquiry"
  ctaHref="/find-a-management-company/#request"
>
  <Fragment set:html={html} />
</BaseLayout>
