---
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Client Name — Short tagline here"
  description="One sentence describing what the business does and who it serves."
>
  <section style="padding: 120px 32px; max-width: 960px; margin: 0 auto; text-align: center;">
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">Welcome to Your New Site</h1>
    <p style="font-size: 1.125rem; color: #555; margin-bottom: 2rem;">
      Replace this with your homepage content. Build page components in
      <code>src/components/pages/</code> and import them here.
    </p>
    <a href="/contact" style="display: inline-block; padding: 12px 28px; background: #333; color: #fff; border-radius: 6px; text-decoration: none;">
      Get in Touch
    </a>
  </section>
</BaseLayout>
