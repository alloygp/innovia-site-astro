---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    /* ====== Home B — "Manifesto" — page-specific ====== */
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Hero ---------- */
    .manifesto-hero {
      background: var(--innovia-navy);
      color: #fff;
      padding: 0;
      position: relative;
      overflow: hidden;
      isolation: isolate;
    }
    /* Video background */
    .manifesto-hero .bg-video {
      position: absolute; inset: 0; z-index: -2;
      overflow: hidden;
      background: #0F2447;
      pointer-events: none;
    }
    .manifesto-hero .bg-video iframe {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%) scale(1.02);
      /* 16:9 cover-fill — use whichever dimension is the larger constraint */
      width: max(100vw, calc(100vh * 16 / 9));
      height: max(100vh, calc(100vw * 9 / 16));
      border: 0;
      pointer-events: none;
      filter: saturate(0.9);
    }
    /* Legacy slideshow (kept for fallback only) */
    .manifesto-hero .slides {
      position: absolute; inset: 0; z-index: -2;
      overflow: hidden;
    }
    .manifesto-hero .slide {
      position: absolute; inset: 0;
      opacity: 0;
      transition: opacity 1.2s var(--ease-in-out);
      will-change: opacity, transform;
    }
    .manifesto-hero .slide.is-active { opacity: 1; }
    .manifesto-hero .slide img {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.9);
      transform: scale(1.08);
      transition: transform 12s linear;
    }
    .manifesto-hero .slide.is-active img {
      transform: scale(1.18);
    }
    .manifesto-hero::before {
      /* navy color wash — 88% so the photo is just a hint */
      content: ""; position: absolute; inset: 0; z-index: -1;
      background: rgba(15,36,71,0.88);
    }
    .manifesto-hero::after {
      content: ""; position: absolute; inset: 0; z-index: -1;
      background:
        radial-gradient(circle at 88% 8%, rgba(149,208,49,0.18) 0%, transparent 35%),
        radial-gradient(circle at 6% 92%, rgba(42, 74, 120, 0.7) 0%, transparent 45%);
      pointer-events: none;
    }
    .manifesto-hero .inner { position: relative; z-index: 1; padding: 60px 0; }
    .manifesto-hero .stamp {
      display: inline-flex; align-items: center; gap: 14px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
      margin-bottom: 56px;
      width: 100%;
      justify-content: space-between;
    }
    .manifesto-hero .stamp .left, .manifesto-hero .stamp .right {
      display: flex; align-items: center; gap: 14px;
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .manifesto-hero .stamp .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }
    .manifesto-hero .stamp { margin-bottom: 24px; }
    .manifesto-hero .pre-eyebrow {
      font-family: var(--font-body);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(18px, 1.5vw, 22px);
      line-height: 1.3;
      color: var(--innovia-green);
      letter-spacing: -0.012em;
      margin: 0 0 22px;
    }
    .manifesto-hero .stack {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(44px, 5.8vw, 92px);
      line-height: 0.96;
      letter-spacing: -0.035em;
      color: #fff;
      margin: 0;
      text-wrap: balance;
      max-width: 22ch;
    }
    .manifesto-hero .stack em { color: var(--innovia-green); font-style: normal; }
    .manifesto-hero .strap {
      margin: 24px 0 0;
      font-family: var(--font-body);
      font-size: clamp(17px, 1.4vw, 21px);
      line-height: 1.5;
      letter-spacing: -0.005em;
      color: rgba(255,255,255,0.78);
      max-width: 52ch;
    }
    .manifesto-hero .strap em {
      color: var(--innovia-green);
      font-style: normal;
      font-weight: 500;
    }
    .manifesto-hero .below {
      display: flex; justify-content: flex-end;
      gap: 12px;
      margin-top: 40px;
      padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .manifesto-hero .below .ctas {
      display: flex; flex-wrap: wrap; gap: 12px;
    }
    .manifesto-hero .below .btn-primary { padding: 16px 28px; font-size: 15px; }
    .manifesto-hero .below .btn-outline-light { padding: 16px 28px; font-size: 15px; }

    /* ---------- Stat band ---------- */
    .stat-band {
      background: var(--innovia-navy-deep);
      padding: 0;
      border-top: 1px solid rgba(255,255,255,0.06);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .stat-band .row {
      display: grid; grid-template-columns: repeat(4, 1fr);
    }
    .stat-band .cell {
      padding: 36px 32px;
      border-right: 1px solid rgba(255,255,255,0.08);
      display: flex; flex-direction: column; gap: 10px;
    }
    .stat-band .cell:last-child { border-right: 0; }
    .stat-band .num {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 64px;
      line-height: 1;
      color: #fff;
      letter-spacing: -0.035em;
    }
    .stat-band .num .pct { color: var(--innovia-green); font-size: 0.55em; vertical-align: top; }
    .stat-band .label {
      font-family: var(--font-display);
      font-size: 11px; font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .stat-band .placeholder::after { top: -22px; right: -4px; }

    /* ---------- Audience fork — CAMs primary lane, boards secondary lane ---------- */
    .audience-fork-b { padding: 0; }
    .audience-fork-b .grid {
      display: grid;
      grid-template-columns: 1.45fr 1fr;
    }
    .audience-fork-b .lane {
      padding: 64px 56px 56px;
      position: relative;
      isolation: isolate;
      overflow: hidden;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 32px;
      min-height: 460px;
      transition: transform .35s var(--ease-out);
      text-decoration: none;
      color: inherit;
    }
    .audience-fork-b .lane:hover { transform: translateY(-2px); }
    .audience-fork-b .lane.owners {
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .audience-fork-b .lane.boards {
      background: #FBFAF6;
      color: var(--innovia-navy);
    }

    /* Top eyebrow row */
    .audience-fork-b .lane .eyebrow-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding-bottom: 18px;
      border-bottom: 1px solid currentColor;
      opacity: 0.7;
    }
    .audience-fork-b .lane .who {
      font-family: var(--font-display);
      font-size: 12px; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
    }
    .audience-fork-b .lane .num {
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.06em;
    }

    /* Body — heading + lede + bullets */
    .audience-fork-b .lane .body { display: flex; flex-direction: column; gap: 20px; }
    .audience-fork-b .lane h2 {
      font-family: var(--font-display);
      font-weight: 700;
      color: inherit;
      letter-spacing: -0.024em;
      line-height: 1.02;
      margin: 0;
      max-width: 16ch;
      text-wrap: balance;
    }
    .audience-fork-b .lane.owners h2 { font-size: clamp(34px, 3.6vw, 50px); }
    .audience-fork-b .lane.boards h2 { font-size: clamp(28px, 3vw, 40px); }
    .audience-fork-b .lane .lede {
      font-size: 16px; line-height: 1.55;
      color: inherit; opacity: 0.78;
      margin: 0;
      max-width: 38ch;
    }
    .audience-fork-b .lane .unlocks {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 10px;
    }
    .audience-fork-b .lane .unlocks li {
      display: flex; align-items: baseline; gap: 12px;
      font-family: var(--font-body);
      font-size: 15px; line-height: 1.5;
      color: inherit;
      opacity: 0.88;
    }
    .audience-fork-b .lane .unlocks li::before {
      content: "—";
      flex-shrink: 0;
      font-family: var(--font-mono);
      font-weight: 700;
      opacity: 0.55;
    }
    .audience-fork-b .lane .unlocks li strong {
      font-family: var(--font-display); font-weight: 700;
      letter-spacing: -0.005em;
      margin-right: 4px;
    }

    /* CTA button anchored at bottom-left of each lane */
    .audience-fork-b .lane .btn {
      justify-self: start;
      align-self: start;
    }

    /* ---------- Manifesto — 'We stand apart' ---------- */
    .manifesto {
      background: var(--innovia-navy);
      padding: 160px 0;
      position: relative; overflow: hidden;
    }
    .manifesto::before {
      content: "";
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
    }
    .manifesto .container { position: relative; z-index: 1; }
    .manifesto .meta {
      display: flex; justify-content: center; gap: 16px;
      margin-bottom: 48px;
      font-family: var(--font-mono);
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .manifesto .meta .bar { width: 36px; height: 1px; background: rgba(255,255,255,0.3); align-self: center; }
    .manifesto h2 {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(64px, 9vw, 148px);
      line-height: 0.92;
      letter-spacing: -0.04em;
      color: #fff;
      text-align: center;
      margin: 0;
    }
    .manifesto h2 .gr { color: var(--innovia-green); }
    .manifesto h2 .small {
      display: block;
      font-size: 0.45em;
      font-weight: 400;
      font-family: var(--font-body);
      font-style: italic;
      color: rgba(255,255,255,0.5);
      letter-spacing: -0.015em;
      margin-top: 24px;
    }
    .manifesto .signoff {
      text-align: center;
      margin-top: 60px;
      font-family: var(--font-mono);
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ---------- Pillars stack ---------- */
    .pillars-stack {
      background: #FBFAF6;
      padding: 140px 0;
      color: var(--innovia-navy);
    }
    .pillars-stack .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 80px;
    }
    .pillars-stack .head h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 5vw, 64px);
      max-width: 14ch;
      letter-spacing: -0.028em;
    }
    .pillars-stack .head p { font-size: 18px; line-height: 1.55; color: var(--fg-2); max-width: 50ch; }
    .pillars-stack .pillar {
      display: grid; grid-template-columns: 200px 1fr 1fr;
      gap: 80px;
      padding: 72px 0;
      border-top: 1px solid var(--innovia-navy);
      align-items: start;
    }
    .pillars-stack .pillar:last-child { border-bottom: 1px solid var(--innovia-navy); }
    .pillars-stack .pillar .marker {
      display: flex; flex-direction: column; gap: 10px;
    }
    .pillars-stack .pillar .marker .num {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 96px;
      line-height: 0.85;
      color: var(--innovia-green-deep);
      letter-spacing: -0.04em;
    }
    .pillars-stack .pillar .marker .legacy {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3); letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .pillars-stack .pillar .marker .legacy s {
      color: var(--fg-3); opacity: 0.7;
    }
    .pillars-stack .pillar h3 {
      font-size: clamp(34px, 3.4vw, 48px);
      line-height: 1; color: var(--innovia-navy);
      margin: 0;
      letter-spacing: -0.025em;
    }
    .pillars-stack .pillar h3 small {
      display: block;
      margin-top: 18px;
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 17px;
      line-height: 1.55;
      color: var(--fg-2);
      letter-spacing: 0;
    }
    .pillars-stack .pillar .examples {
      display: grid; gap: 14px;
    }
    .pillars-stack .pillar .examples .ex {
      display: flex; gap: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border-subtle);
      font-size: 14px; line-height: 1.5;
      color: var(--fg-2);
    }
    .pillars-stack .pillar .examples .ex:last-child { border-bottom: 0; }
    .pillars-stack .pillar .examples .ex span {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--innovia-green-deep);
      flex-shrink: 0;
      padding-top: 2px;
    }

    /* ---------- Cinderella full-bleed ---------- */
    .cinderella-b {
      background: var(--innovia-navy-deep);
      color: rgba(255,255,255,0.78);
      padding: 160px 0;
      position: relative;
    }
    .cinderella-b .head {
      max-width: 980px;
      margin: 0 auto 80px;
      text-align: center;
    }
    .cinderella-b .head .kicker {
      display: inline-block;
      margin-bottom: 28px;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--innovia-green);
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .cinderella-b h2 {
      color: #fff;
      font-size: clamp(40px, 5.4vw, 72px);
      letter-spacing: -0.028em;
      margin: 0;
    }
    .cinderella-b h2 em { color: var(--innovia-green); font-style: normal; }
    .cinderella-b h2 .light { font-weight: 400; color: rgba(255,255,255,0.6); font-style: italic; }
    .cinderella-b .lead-c {
      max-width: 68ch;
      margin: 32px auto 0;
      text-align: center;
      font-size: 19px;
      line-height: 1.6;
      color: rgba(255,255,255,0.78);
    }
    .cinderella-b .roles {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      margin-top: 80px;
      border-top: 1px solid rgba(255,255,255,0.18);
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .cinderella-b .role {
      padding: 40px 24px;
      border-right: 1px solid rgba(255,255,255,0.10);
      display: flex; flex-direction: column; gap: 16px;
      position: relative;
    }
    .cinderella-b .role:last-child { border-right: 0; }
    .cinderella-b .role .glyph {
      width: 44px; height: 44px;
      border-radius: 999px;
      background: rgba(149,208,49,0.12);
      border: 1px solid rgba(149,208,49,0.3);
      display: flex; align-items: center; justify-content: center;
      color: var(--innovia-green);
    }
    .cinderella-b .role .name {
      font-family: var(--font-display); font-weight: 700;
      font-size: 17px; color: #fff;
      letter-spacing: -0.005em;
      line-height: 1.2;
    }
    .cinderella-b .role .desc {
      font-size: 13px; color: rgba(255,255,255,0.6);
      line-height: 1.5;
    }
    .cinderella-b .role .status {
      margin-top: auto;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--innovia-green);
      padding-top: 14px;
      border-top: 1px solid rgba(255,255,255,0.10);
    }
    .cinderella-b .quote {
      max-width: 880px;
      margin: 80px auto 0;
      text-align: center;
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(26px, 3vw, 38px);
      line-height: 1.3;
      letter-spacing: -0.018em;
      color: #fff;
    }
    .cinderella-b .quote cite {
      display: block;
      margin-top: 24px;
      font-family: var(--font-body);
      font-size: 13px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-style: normal;
    }

    /* ---------- Voice (big quote photo) ---------- */
    .voice-b {
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
      padding: 0;
      position: relative;
      overflow: hidden;
      min-height: 600px;
      display: flex; align-items: center;
    }
    .voice-b .photo {
      position: absolute; inset: 0; z-index: 0;
    }
    .voice-b .photo img {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.85);
    }
    .voice-b .photo::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(95deg, rgba(15,36,71,0.94) 0%, rgba(15,36,71,0.76) 40%, rgba(15,36,71,0.4) 100%);
    }
    .voice-b .container { position: relative; z-index: 1; padding: 100px 0; }
    .voice-b .frame { max-width: 880px; }
    .voice-b .kick {
      font-family: var(--font-mono); font-size: 12px;
      color: var(--innovia-green);
      letter-spacing: 0.16em; text-transform: uppercase;
      margin-bottom: 28px;
    }
    .voice-b blockquote {
      margin: 0;
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(28px, 3.4vw, 48px);
      line-height: 1.18;
      letter-spacing: -0.02em;
      color: #fff;
      text-wrap: balance;
    }
    .voice-b blockquote::before {
      content: "“";
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 1.2em;
      line-height: 0; color: var(--innovia-green);
      vertical-align: -0.18em;
      margin-right: 0.05em;
    }
    .voice-b .attr {
      margin-top: 36px;
      padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,0.2);
      display: flex; gap: 24px;
      font-size: 14px;
      color: rgba(255,255,255,0.74);
    }
    .voice-b .attr .name {
      font-family: var(--font-display); font-weight: 700;
      color: #fff;
    }

    /* ---------- Summit feature (editorial) ---------- */
    .summit-b {
      padding: 120px 0 140px;
      background: #0c1d3a;
      position: relative;
    }
    .summit-b .container { position: relative; z-index: 1; }
    .summit-b .head {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 64px;
      align-items: end;
      padding-bottom: 40px;
      border-bottom: 1px solid rgba(255,255,255,0.16);
      margin-bottom: 40px;
    }
    .summit-b .head h2 {
      color: #fff;
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(40px, 5vw, 64px);
      letter-spacing: -0.028em;
      line-height: 1.02;
      margin: 14px 0 0;
      text-wrap: balance;
    }
    .summit-b .head p {
      font-size: 17px; line-height: 1.6;
      color: rgba(255,255,255,0.74);
      max-width: 48ch;
      margin: 0;
    }

    /* Featured video — full-bleed within container */
    .summit-b .feature {
      position: relative;
      aspect-ratio: 16 / 9;
      background: var(--innovia-navy-deep);
      overflow: hidden;
      isolation: isolate;
    }
    .summit-b .feature img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.85) brightness(0.55);
      transition: filter .35s var(--ease-out);
    }
    .summit-b .feature:hover img { filter: saturate(0.95) brightness(0.7); }
    .summit-b .feature .label-top {
      position: absolute; top: 24px; left: 24px;
      display: inline-flex; align-items: center; gap: 10px;
      padding: 7px 14px;
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(6px);
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.9);
      letter-spacing: 0.14em; text-transform: uppercase;
    }
    .summit-b .feature .label-top .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 10px rgba(149,208,49,0.7);
    }
    .summit-b .feature .duration {
      position: absolute; top: 24px; right: 24px;
      padding: 6px 12px;
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(6px);
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.85);
      letter-spacing: 0.04em;
    }
    .summit-b .feature .play-row {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      padding: 32px 40px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: end;
    }
