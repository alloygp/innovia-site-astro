  <script>
    // Summit video — lazy-load the highlights iframe on click (Vimeo or YouTube)
    (function () {
      const tiles = document.querySelectorAll('.summit-b .feature, .summit-b .video-tile');
      tiles.forEach(tile => {
        function play() {
          if (tile.classList.contains('is-playing')) return;
          const vimeoId = tile.dataset.vimeo;
          const ytId = tile.dataset.yt;
          if (!vimeoId && !ytId) return;
          const iframe = document.createElement('iframe');
          if (vimeoId) {
            iframe.src = 'https://player.vimeo.com/video/' + vimeoId + '?autoplay=1&title=0&byline=0&portrait=0&dnt=1';
          } else {
            iframe.src = 'https://www.youtube-nocookie.com/embed/' + ytId + '?autoplay=1&rel=0&modestbranding=1';
          }
          iframe.title = 'Summit highlights';
          iframe.allow = 'autoplay; fullscreen; encrypted-media; picture-in-picture';
          iframe.allowFullscreen = true;
          tile.appendChild(iframe);
          tile.classList.add('is-playing');
        }
        tile.addEventListener('click', play);
        tile.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); play(); }
        });
      });
    })();
  </script>
  <script>
    // Hero is a YouTube background video; the slideshow fallback only runs
    // if the video container is absent.
    (function () {
      if (document.querySelector('.manifesto-hero .bg-video')) return;
      const slides = Array.from(document.querySelectorAll('.manifesto-hero .slide'));
      if (slides.length < 2) return;
      let i = 0;
      slides.forEach((s, n) => s.classList.toggle('is-active', n === 0));
      const DURATION = 5500;
      function tick() {
        const prev = i;
        i = (i + 1) % slides.length;
        slides[i].classList.add('is-active');
        slides[prev].classList.remove('is-active');
      }
      setInterval(tick, DURATION);
    })();
  </script>
