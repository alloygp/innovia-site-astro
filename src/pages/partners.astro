---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 56px; position: relative; overflow: hidden; }
    .page-hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 92% 8%, rgba(149,208,49,0.14) 0%, transparent 38%), radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%); pointer-events: none; }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 36px; }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light { display: block; margin-top: 8px; font-family: var(--font-body); font-weight: 300; font-style: italic; color: rgba(255,255,255,0.55); font-size: 0.48em; letter-spacing: -0.02em; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }
    
  
    .pillars-row { padding: 24px 0 96px; }
    .pillars-row .head { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; margin-bottom: 56px; align-items: end; }
    .pillars-row .head h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(32px, 4vw, 48px); color: #fff; letter-spacing: -0.022em; margin: 14px 0 0; max-width: 18ch; }
    .pillars-row .head h2 em { color: var(--innovia-green); font-style: italic; font-weight: 400; }
    .pillars-row .head p { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.74); max-width: 52ch; margin: 0; }
    .pillars-row .categories { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border-top: 1px solid rgba(255,255,255,0.18); border-bottom: 1px solid rgba(255,255,255,0.18); }
    .pillars-row .cat { padding: 32px 28px; border-right: 1px solid rgba(255,255,255,0.10); border-bottom: 1px solid rgba(255,255,255,0.10); display: flex; flex-direction: column; gap: 12px; }
    .pillars-row .cat:nth-child(3n) { border-right: 0; }
    .pillars-row .cat:nth-last-child(-n+3) { border-bottom: 0; }
    .pillars-row .cat .ix { font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; }
    .pillars-row .cat h3 { font-family: var(--font-display); font-weight: 700; font-size: 22px; color: #fff; letter-spacing: -0.012em; margin: 0; }
    .pillars-row .cat p { font-size: 14px; line-height: 1.55; color: rgba(255,255,255,0.62); margin: 0; }
    .pillars-row .cat .logo-slot { margin-top: auto; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.10); font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 0.12em; text-transform: uppercase; }

    .partner-cta { padding: 96px 0; background: var(--innovia-navy-deep); border-top: 1px solid rgba(255,255,255,0.08); }
    .partner-cta .frame { display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: center; }
    .partner-cta h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(32px, 4vw, 48px); color: #fff; letter-spacing: -0.022em; max-width: 20ch; }
    .partner-cta h2 em { color: var(--innovia-green); font-style: italic; font-weight: 400; }
    .partner-cta p { font-size: 16px; line-height: 1.6; color: rgba(255,255,255,0.74); max-width: 48ch; margin: 20px 0 0; }
    .partner-cta .actions { display: flex; flex-direction: column; gap: 12px; }
    .partner-cta .actions .btn { justify-content: center; padding: 16px 24px; font-size: 15px; }

    @media (max-width: 1080px) { .pillars-row .head, .pillars-row .categories, .partner-cta .frame { grid-template-columns: 1fr; gap: 32px; } .pillars-row .cat { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.10); } }
  </style>



  <section class="page-hero">
    <div class="container">
      
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <span style="color:#fff;">Partners</span>
      </div>
      <h1>The vendor program<span class="light">cooperatively curated. Member-rated. Reviewed annually.</span></h1>
      <p class="lede">Six categories of vendor partners, each curated by the member council to serve every level of a CAM company&rsquo;s operation. Partners earn the lineup year by year through member-rated performance, then defend the slot. The cooperative doesn&rsquo;t take vendor money for placement.</p>
    </div>
  </section>

  <section class="pillars-row">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 01</span><span class="rule-mini"></span>The six pillars</div>
          <h2>Six categories. <em>Hand-picked.</em></h2>
        </div>
        <p>Names and logos are kept inside the member portal until the annual lineup is published. <span class="placeholder placeholder-inline">Real partner names and lockup will land here once the client confirms the 2026 lineup.</span></p>
      </div>
      <div class="categories">
        
        <div class="cat">
          <span class="ix">01</span>
          <h3>Banking &amp; Treasury</h3>
          <p>Operating + reserve banking partners with CAM-fluent product teams and member-rate fee structures.</p>
          <div class="logo-slot placeholder placeholder-inline">Partner logo &middot; TBD</div>
        </div>
        <div class="cat">
          <span class="ix">02</span>
          <h3>Software &amp; AMS</h3>
          <p>Association management software, accounting platforms, and the integrations that connect them.</p>
          <div class="logo-slot placeholder placeholder-inline">Partner logo &middot; TBD</div>
        </div>
        <div class="cat">
          <span class="ix">03</span>
          <h3>AI &amp; Data Tooling</h3>
          <p>AI partners working specifically inside the back office of community association management.</p>
          <div class="logo-slot placeholder placeholder-inline">Partner logo &middot; TBD</div>
        </div>
        <div class="cat">
          <span class="ix">04</span>
          <h3>Staffing &amp; Talent</h3>
          <p>Recruiting and contract staffing partners who understand the seats CAM companies are trying to fill.</p>
          <div class="logo-slot placeholder placeholder-inline">Partner logo &middot; TBD</div>
        </div>
        <div class="cat">
          <span class="ix">05</span>
          <h3>Insurance</h3>
          <p>D&amp;O, GL, cyber, and crime carriers that price independently-owned CAM companies fairly.</p>
          <div class="logo-slot placeholder placeholder-inline">Partner logo &middot; TBD</div>
        </div>
        <div class="cat">
          <span class="ix">06</span>
          <h3>Security &amp; Compliance</h3>
          <p>Cybersecurity, payment security, and compliance partners audited for the data CAM companies hold.</p>
          <div class="logo-slot placeholder placeholder-inline">Partner logo &middot; TBD</div>
        </div>
      </div>
    </div>
  </section>

  <section class="partner-cta">
    <div class="container">
      <div class="frame">
        <div>
          <h2>Run a product or service for CAM companies? <em>Talk to us.</em></h2>
          <p>Vendor partnerships start with a member-council call. We&rsquo;re not looking for sponsorships &mdash; we&rsquo;re looking for products that materially improve a CAM company&rsquo;s day. Bring data.</p>
        </div>
        <div class="actions">
          <a href="/contact/" class="btn btn-primary">
            Talk to partnerships
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
          <a href="/for-cams/why-innovia/" class="btn btn-outline-light">Or join as a member firm</a>
        </div>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="Partners · Innovia Co-op"
  description="Partners · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  headerVariant="inverse"
  ctaLabel="Talk to Partnerships"
  ctaHref="/contact/"
>
  <Fragment set:html={html} />
</BaseLayout>
