---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    /* ============================================================
       Summit 2027 Teaser — warm, art-deco, Florida-coded.
       Keeps Innovia navy as the spine; introduces sun-amber and
       coral as event-specific accents only. No venue name on page.
       ============================================================ */

    :root {
      --sun-amber:   #F4B25A;
      --sun-amber-d: #C68A39;
      --sun-coral:   #E87D6E;
      --sun-peach:   #F4D2A3;
      --sun-cream:   #F8ECD4;
      --night-deep:  #0A1936;
      --night-indigo:#1E2A4F;
    }

    body {
      background: var(--night-deep);
      color: rgba(255,255,255,0.78);
    }

    .site-header {
      background: rgba(10,25,54,0.86);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: var(--sun-amber); color: var(--night-deep); }
    .site-header .btn-navy:hover { background: var(--sun-cream); }

    /* ===== HERO — sunset stage with art-deco curves ===== */
    .teaser-hero {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      padding: 40px 0 96px;
      min-height: 92vh;
      display: flex;
      flex-direction: column;
    }
    /* Painted sky: night → indigo → coral → amber from top to bottom */
    .teaser-hero::before {
      content: ""; position: absolute; inset: 0; z-index: -3;
      background:
        radial-gradient(ellipse 80% 60% at 78% 88%, rgba(244,178,90,0.85) 0%, rgba(244,178,90,0) 60%),
        radial-gradient(ellipse 100% 60% at 50% 100%, rgba(232,125,110,0.7) 0%, rgba(232,125,110,0) 70%),
        linear-gradient(180deg, var(--night-deep) 0%, var(--night-indigo) 38%, #4A3360 62%, #A14E5C 82%, var(--sun-coral) 96%);
    }
    /* Subtle vignette so navigation chrome reads */
    .teaser-hero::after {
      content: ""; position: absolute; inset: 0; z-index: -1;
      background:
        linear-gradient(180deg, rgba(10,25,54,0.5) 0%, transparent 24%),
        radial-gradient(ellipse 70% 50% at 50% 0%, rgba(10,25,54,0.6) 0%, transparent 80%);
      pointer-events: none;
    }

    /* Art-deco concentric sun, anchored bottom-right */
    .teaser-hero .deco-sun {
      position: absolute;
      right: -180px; bottom: -200px;
      width: 720px; height: 720px;
      z-index: -2;
      opacity: 0.65;
      pointer-events: none;
    }
    /* Subtle palm silhouettes left edge */
    .teaser-hero .deco-palms {
      position: absolute;
      left: -40px; bottom: -10px;
      width: 320px; height: 360px;
      z-index: -2;
      opacity: 0.32;
      pointer-events: none;
    }

    /* Top stamp row */
    .teaser-hero .stamp-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 32px 0 24px;
      border-bottom: 1px solid rgba(255,255,255,0.16);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
    }
    .teaser-hero .stamp-row .left,
    .teaser-hero .stamp-row .right {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .teaser-hero .stamp-row .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--sun-amber);
      box-shadow: 0 0 14px rgba(244,178,90,0.8);
    }

    /* The mark */
    .teaser-hero .mark-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 0 56px;
      position: relative;
    }
    .teaser-hero .pre {
      font-family: var(--font-body);
      font-style: italic;
      font-size: clamp(15px, 1.2vw, 18px);
      color: rgba(255,255,255,0.7);
      max-width: 36ch;
      margin: 0 0 28px;
      letter-spacing: 0.005em;
    }
    .teaser-hero .summit-mark {
      font-family: var(--font-summit);
      font-weight: 700;
      font-size: clamp(72px, 11vw, 196px);
      line-height: 0.86;
      letter-spacing: 0.02em;
      color: #fff;
      text-transform: uppercase;
      margin: 0;
    }
    .teaser-hero .summit-mark .yr {
      color: var(--sun-amber);
      display: inline-block;
      position: relative;
    }
    .teaser-hero .summit-mark .yr::after {
      content: "";
      position: absolute;
      left: 4%; right: 4%;
      bottom: 0.1em;
      height: 0.06em;
      background: linear-gradient(90deg, transparent, var(--sun-amber), transparent);
      opacity: 0.5;
    }

    .teaser-hero .theme-bar {
      margin-top: 36px;
      padding: 20px 0 0;
      border-top: 1px solid rgba(255,255,255,0.18);
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 64px;
      align-items: start;
    }
    .teaser-hero .theme-bar .label {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--sun-amber); letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .teaser-hero .theme-bar h2 {
      font-family: var(--font-display);
      font-weight: 700;
      color: #fff;
      font-size: clamp(22px, 2.4vw, 32px);
      letter-spacing: -0.015em;
      line-height: 1.18;
      margin: 8px 0 0;
      text-wrap: balance;
    }
    .teaser-hero .theme-bar h2 em {
      color: var(--sun-amber);
      font-style: normal;
    }
    .teaser-hero .theme-bar .strap {
      font-size: 17px;
      line-height: 1.6;
      color: rgba(255,255,255,0.82);
      max-width: 52ch;
      margin: 0;
    }

    /* Bottom row: dates · format · CTA */
    .teaser-hero .below {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr auto;
      gap: 40px;
      align-items: end;
      padding-top: 36px;
      margin-top: 56px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .teaser-hero .below .cell {
      display: flex; flex-direction: column; gap: 6px;
    }
    .teaser-hero .below .k {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.14em; text-transform: uppercase;
    }
    .teaser-hero .below .v {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(18px, 1.6vw, 22px);
      color: #fff;
      letter-spacing: -0.005em;
      line-height: 1.2;
    }
    .teaser-hero .below .v small {
      display: block;
      font-family: var(--font-body); font-weight: 400;
      font-size: 13px;
      color: rgba(255,255,255,0.6);
      margin-top: 4px;
    }
    .teaser-hero .below .cta-cell .btn {
      padding: 16px 28px;
      font-size: 15px;
    }
    .teaser-hero .below .btn-amber {
      background: var(--sun-amber);
      color: var(--night-deep);
      border: 1px solid var(--sun-amber);
      box-shadow: 0 12px 32px -8px rgba(244,178,90,0.6);
    }
    .teaser-hero .below .btn-amber:hover {
      background: var(--sun-cream);
      border-color: var(--sun-cream);
    }

    /* ===== INTRIGUE — Venue tease (no name) ===== */
    .intrigue {
      position: relative;
      background: var(--sun-cream);
      color: var(--night-deep);
      padding: 140px 0 160px;
      overflow: hidden;
    }
    .intrigue::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 100% 50%, rgba(232,125,110,0.18) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 0% 100%, rgba(244,178,90,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .intrigue .layout {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 96px;
      align-items: start;
      position: relative;
    }
    .intrigue .eyebrow-w {
      display: flex; align-items: center; gap: 12px;
      font-family: var(--font-mono); font-size: 11px;
      color: var(--sun-amber-d); letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .intrigue .eyebrow-w .pill {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      background: var(--night-deep);
      color: var(--sun-amber);
      letter-spacing: 0.16em;
      font-size: 10px;
    }
    .intrigue h2 {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(38px, 4.4vw, 64px);
      color: var(--night-deep);
      letter-spacing: -0.024em;
      line-height: 1.05;
      margin: 22px 0 0;
      max-width: 16ch;
      text-wrap: balance;
    }
    .intrigue h2 em {
      color: var(--sun-coral);
      font-style: italic;
      font-weight: 400;
    }
    .intrigue .lede {
      font-family: var(--font-body);
      font-size: 18px;
      line-height: 1.62;
      color: var(--night-indigo);
      margin: 24px 0 0;
      max-width: 38ch;
    }
    .intrigue .lede::first-letter {
      font-family: var(--font-display); font-weight: 900;
      font-size: 64px; float: left;
      line-height: 0.85;
      margin: 6px 12px 0 0;
      color: var(--sun-coral);
    }

    .intrigue .clues {
      display: flex; flex-direction: column;
      gap: 0;
      border-top: 1px solid rgba(10,25,54,0.18);
    }
    .intrigue .clue {
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 24px;
      padding: 28px 0;
      border-bottom: 1px solid rgba(10,25,54,0.18);
      align-items: start;
    }
    .intrigue .clue .num {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--sun-amber-d);
      letter-spacing: 0.06em;
      padding-top: 6px;
    }
    .intrigue .clue h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 22px;
      color: var(--night-deep);
      letter-spacing: -0.01em;
      margin: 0 0 6px;
      line-height: 1.25;
    }
    .intrigue .clue p {
      font-family: var(--font-body);
      font-size: 15px; line-height: 1.6;
      color: var(--night-indigo);
      margin: 0;
      max-width: 50ch;
    }
    .intrigue .clue p em {
      font-style: italic;
      color: var(--sun-coral);
    }

    .intrigue .seal {
      margin-top: 36px;
      display: inline-flex; align-items: center; gap: 14px;
      padding: 14px 18px;
      background: var(--night-deep);
      color: var(--sun-amber);
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
    }
    .intrigue .seal svg { width: 14px; height: 14px; }

    /* ===== THEME — Benchmarks & Beyond ===== */
    .theme-section {
      background: var(--night-deep);
      color: rgba(255,255,255,0.8);
      padding: 140px 0 160px;
      position: relative;
      overflow: hidden;
    }
    .theme-section::before {
      content: "";
      position: absolute; inset: 0;
      background:
        radial-gradient(circle at 92% 12%, rgba(244,178,90,0.16) 0%, transparent 36%),
        radial-gradient(circle at 8% 88%, rgba(232,125,110,0.14) 0%, transparent 40%);
      pointer-events: none;
    }
    .theme-section .head {
      max-width: 1000px;
      margin: 0 auto 80px;
      text-align: center;
      position: relative;
    }
    .theme-section .head .label {
      display: inline-block;
      padding: 6px 14px;
      background: rgba(244,178,90,0.16);
      color: var(--sun-amber);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 28px;
    }
    .theme-section h2 {
      font-family: var(--font-display);
      font-weight: 700;
      color: #fff;
      font-size: clamp(38px, 5.4vw, 78px);
      letter-spacing: -0.026em;
      line-height: 1;
      margin: 0;
      text-wrap: balance;
    }
    .theme-section h2 em {
      color: var(--sun-amber);
      font-style: italic;
      font-weight: 400;
    }
    .theme-section .sub {
      font-family: var(--font-body);
      font-size: 19px;
      line-height: 1.6;
      max-width: 56ch;
      margin: 28px auto 0;
      color: rgba(255,255,255,0.78);
    }
    .theme-section .pillars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      margin-top: 80px;
      border-top: 1px solid rgba(255,255,255,0.18);
      border-bottom: 1px solid rgba(255,255,255,0.18);
      position: relative;
    }
    .theme-section .pillar {
      padding: 48px 36px;
      border-right: 1px solid rgba(255,255,255,0.18);
      display: flex; flex-direction: column;
      gap: 14px;
    }
    .theme-section .pillar:last-child { border-right: 0; }
    .theme-section .pillar .ix {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--sun-amber); letter-spacing: 0.06em;
    }
    .theme-section .pillar h3 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 26px; color: #fff;
      letter-spacing: -0.014em; line-height: 1.2;
      margin: 0;
    }
    .theme-section .pillar p {
      font-size: 15px; line-height: 1.6;
      color: rgba(255,255,255,0.7);
      margin: 0;
    }
    .theme-section .pillar .quiet {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.04em;
      margin-top: auto; padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.10);
    }

    /* ===== PAST SUMMITS — archive + highlights ===== */
    .past {
      background: #FBFAF6;
      color: var(--fg-2);
      padding: 140px 0;
    }
    .past .head {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 64px;
      align-items: end;
      margin-bottom: 64px;
    }
    .past .head h2 {
      font-family: var(--font-display); font-weight: 700;
      color: var(--innovia-navy);
      font-size: clamp(36px, 4.4vw, 60px);
      letter-spacing: -0.024em;
      line-height: 1.04;
      max-width: 14ch;
      margin: 14px 0 0;
    }
    .past .head p {
      font-size: 17px;
      line-height: 1.62;
      color: var(--fg-2);
      max-width: 52ch;
      margin: 0;
    }

    .past .featured {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 0;
      margin-bottom: 24px;
      border: 1px solid var(--border-subtle);
      background: #fff;
      overflow: hidden;
    }
    .past .featured .photo {
      position: relative;
      min-height: 460px;
      overflow: hidden;
    }
    .past .featured .photo img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: saturate(0.95);
    }
    .past .featured .photo .stamp {
      position: absolute;
      top: 24px; left: 24px;
      padding: 8px 14px;
      background: rgba(10,25,54,0.92);
      color: #fff;
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
    }
    .past .featured .photo .stamp .dot {
      display: inline-block;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--sun-amber);
      margin-right: 10px;
      vertical-align: middle;
    }
    .past .featured .body {
      padding: 48px;
      display: flex; flex-direction: column;
      gap: 18px;
    }
    .past .featured .ix {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep); letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .past .featured h3 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 32px;
      color: var(--innovia-navy);
      letter-spacing: -0.018em;
      line-height: 1.15;
      margin: 0;
    }
    .past .featured p {
      font-size: 15px; line-height: 1.6;
      color: var(--fg-2);
      margin: 0;
    }
    .past .featured .stats {
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      gap: 0;
      margin-top: 8px;
      padding-top: 20px;
      border-top: 1px solid var(--border-subtle);
    }
    .past .featured .stats > div {
      padding-right: 16px;
      border-right: 1px solid var(--border-subtle);
      display: flex; flex-direction: column; gap: 4px;
    }
    .past .featured .stats > div:last-child { border-right: 0; }
    .past .featured .stats .k {
      font-family: var(--font-mono); font-size: 10px;
      color: var(--fg-3);
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .past .featured .stats .v {
      font-family: var(--font-display); font-weight: 800;
      font-size: 26px;
      color: var(--innovia-navy);
      letter-spacing: -0.014em;
      line-height: 1;
    }
    .past .featured .actions {
      margin-top: auto;
      display: flex; flex-wrap: wrap; gap: 12px;
    }

    /* Older editions row */
    .past .archive-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 24px;
    }
    .past .edition {
      background: #fff;
      border: 1px solid var(--border-subtle);
      padding: 28px;
      display: flex; flex-direction: column; gap: 14px;
      text-decoration: none;
      color: inherit;
      transition: border-color .2s, transform .2s;
    }
    .past .edition:hover {
      border-color: var(--innovia-navy);
      transform: translateY(-2px);
    }
    .past .edition .yr {
      font-family: var(--font-summit); font-weight: 700;
      font-size: 56px;
      color: var(--innovia-navy);
      line-height: 0.9;
      letter-spacing: 0.02em;
    }
    .past .edition .v {
      font-family: var(--font-display); font-weight: 600;
      font-size: 17px;
      color: var(--innovia-navy);
      letter-spacing: -0.005em;
    }
    .past .edition .m {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3); letter-spacing: 0.04em;
    }
    .past .edition .hl {
      font-size: 14px; line-height: 1.55;
      color: var(--fg-2);
      margin-top: auto;
      padding-top: 16px;
      border-top: 1px solid var(--border-subtle);
    }

    .past .external-link {
      margin-top: 36px;
      padding: 24px 28px;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.85);
      display: flex; justify-content: space-between; align-items: center;
      gap: 24px; flex-wrap: wrap;
    }
    .past .external-link h5 {
      font-family: var(--font-display); font-weight: 700;
      color: #fff;
      font-size: 19px;
      letter-spacing: -0.005em;
      margin: 0 0 4px;
    }
    .past .external-link p {
      font-size: 14px;
      color: rgba(255,255,255,0.7);
      margin: 0;
    }
    .past .external-link .url {
      font-family: var(--font-mono);
      color: var(--innovia-green);
    }
    .past .external-link a.btn {
      background: var(--innovia-green);
      color: var(--innovia-navy);
      padding: 14px 22px;
      font-size: 14px;
    }
    .past .external-link a.btn:hover { background: #fff; }

    /* ===== NOTIFY — email capture ===== */
    .notify {
      background:
        radial-gradient(ellipse 80% 60% at 80% 100%, rgba(244,178,90,0.5) 0%, transparent 60%),
        linear-gradient(180deg, var(--night-deep) 0%, #1A2546 70%, #503560 100%);
      color: rgba(255,255,255,0.85);
      padding: 140px 0 160px;
      position: relative;
      overflow: hidden;
    }
    .notify::before {
      content: "";
      position: absolute;
      right: -180px; bottom: -240px;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(244,178,90,0.6) 0%, transparent 65%);
      pointer-events: none;
    }
    .notify .frame {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 96px;
      align-items: center;
      position: relative;
    }
    .notify .copy .label {
      display: inline-flex; align-items: center; gap: 12px;
      padding: 6px 14px;
      background: rgba(244,178,90,0.16);
      color: var(--sun-amber);
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      margin-bottom: 28px;
    }
    .notify h2 {
      font-family: var(--font-display); font-weight: 700;
      color: #fff;
      font-size: clamp(38px, 5vw, 68px);
      letter-spacing: -0.026em;
      line-height: 1.02;
      margin: 0;
      text-wrap: balance;
      max-width: 14ch;
    }
    .notify h2 em {
      color: var(--sun-amber);
      font-style: italic;
      font-weight: 400;
    }
    .notify .strap {
      font-size: 17px; line-height: 1.62;
      color: rgba(255,255,255,0.8);
      max-width: 48ch;
      margin: 22px 0 0;
    }
    .notify form {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.16);
      padding: 32px;
      backdrop-filter: blur(6px);
    }
    .notify form .row {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-bottom: 14px;
    }
    .notify form label {
      display: flex; flex-direction: column; gap: 6px;
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255,255,255,0.65);
    }
    .notify form .single { grid-template-columns: 1fr; }
    .notify form input, .notify form select {
      background: rgba(0,0,0,0.22);
      border: 1px solid rgba(255,255,255,0.18);
      padding: 14px 16px;
      color: #fff;
      font-family: var(--font-body); font-size: 15px;
      letter-spacing: 0;
      text-transform: none;
      transition: border-color .15s;
    }
    .notify form input:focus, .notify form select:focus {
      outline: none;
      border-color: var(--sun-amber);
      box-shadow: 0 0 0 3px rgba(244,178,90,0.25);
    }
    .notify form input::placeholder { color: rgba(255,255,255,0.4); }
    .notify form .submit-row {
      display: flex; justify-content: space-between; align-items: center;
      gap: 16px;
      margin-top: 22px;
      padding-top: 22px;
      border-top: 1px solid rgba(255,255,255,0.14);
    }
    .notify form .submit-row small {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      max-width: 32ch;
    }
    .notify form button {
      background: var(--sun-amber);
      color: var(--night-deep);
      border: 0;
      padding: 16px 28px;
      font-family: var(--font-display); font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .15s;
      display: inline-flex; align-items: center; gap: 10px;
    }
    .notify form button:hover { background: var(--sun-cream); }
    .notify form button svg { width: 14px; height: 14px; }

    /* ===== Site footer overrides for this page ===== */
    .site-footer {
      background: var(--night-deep);
    }

    /* ===== Responsive ===== */
    @media (max-width: 1080px) {
      .teaser-hero .theme-bar,
      .teaser-hero .below,
      .intrigue .layout,
      .theme-section .pillars,
      .past .head,
      .past .featured,
      .past .archive-row,
      .notify .frame {
        grid-template-columns: 1fr !important;
        gap: 32px;
      }
      .teaser-hero .summit-mark { font-size: clamp(64px, 14vw, 120px); }
      .teaser-hero .deco-sun { width: 480px; height: 480px; bottom: -160px; right: -140px; }
      .past .featured .photo { min-height: 280px; }
      .past .featured .body { padding: 32px; }
      .past .featured .stats { grid-template-columns: 1fr 1fr 1fr; }
      .notify form .row { grid-template-columns: 1fr; }
    }
    @media (max-width: 720px) {
      .teaser-hero .stamp-row { flex-direction: column; align-items: flex-start; gap: 12px; }
      .teaser-hero .below { gap: 24px; }
      .past .featured .stats { grid-template-columns: 1fr; }
      .past .featured .stats > div { border-right: 0; padding: 12px 0; border-bottom: 1px solid var(--border-subtle); }
      .past .featured .stats > div:last-child { border-bottom: 0; }
    }
  </style>


  <!-- ============== HERO ============== -->
  <section class="teaser-hero">

    <!-- art-deco sun (concentric arcs + radii) -->
    <svg class="deco-sun" viewBox="0 0 720 720" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <radialGradient id="sunGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#F8ECD4" stop-opacity="0.9"/>
          <stop offset="40%" stop-color="#F4B25A" stop-opacity="0.8"/>
          <stop offset="100%" stop-color="#E87D6E" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <circle cx="360" cy="360" r="280" fill="url(#sunGlow)"/>
      <g fill="none" stroke="#F8ECD4" stroke-opacity="0.4" stroke-width="1.5">
        <circle cx="360" cy="360" r="160"/>
        <circle cx="360" cy="360" r="200"/>
        <circle cx="360" cy="360" r="240"/>
        <circle cx="360" cy="360" r="288"/>
        <circle cx="360" cy="360" r="332"/>
      </g>
      <!-- radii -->
      <g stroke="#F8ECD4" stroke-opacity="0.32" stroke-width="1.5" stroke-linecap="round">
        <line x1="360" y1="40" x2="360" y2="120"/>
        <line x1="360" y1="600" x2="360" y2="680"/>
        <line x1="40" y1="360" x2="120" y2="360"/>
        <line x1="600" y1="360" x2="680" y2="360"/>
        <line x1="128" y1="128" x2="184" y2="184"/>
        <line x1="536" y1="184" x2="592" y2="128"/>
        <line x1="128" y1="592" x2="184" y2="536"/>
        <line x1="536" y1="536" x2="592" y2="592"/>
      </g>
    </svg>

    <!-- palm silhouettes -->
    <svg class="deco-palms" viewBox="0 0 320 360" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g fill="#0A1936">
        <!-- trunk left -->
        <path d="M62 360 Q60 240 58 200 Q56 160 50 130 L46 130 Q52 160 54 200 Q56 240 58 360 Z"/>
        <!-- fronds -->
        <path d="M50 130 Q10 110 -6 70 Q24 92 56 116 Z"/>
        <path d="M50 130 Q22 100 6 50 Q34 80 60 116 Z"/>
        <path d="M50 130 Q60 90 86 64 Q66 96 60 124 Z"/>
        <path d="M50 130 Q86 110 122 96 Q88 124 62 130 Z"/>
        <path d="M50 130 Q92 138 130 156 Q92 142 62 134 Z"/>
        <!-- trunk right (shorter) -->
        <path d="M178 360 Q176 280 174 240 Q170 198 158 168 L154 170 Q166 200 170 240 Q174 280 174 360 Z"/>
        <path d="M158 168 Q120 152 100 116 Q138 138 168 156 Z"/>
        <path d="M158 168 Q188 138 226 124 Q196 156 172 162 Z"/>
        <path d="M158 168 Q138 130 134 88 Q156 130 168 158 Z"/>
        <path d="M158 168 Q190 178 220 200 Q188 184 168 170 Z"/>
      </g>
    </svg>

    <div class="container">
      <div class="stamp-row">
        <div class="left">
          <span class="dot"></span>
          <span>Innovia &middot; Annual Summit</span>
        </div>
        <div class="right">
          <span>Annual Summit</span>
          <span style="opacity: 0.4;">/</span>
          <span>By invitation</span>
          <span style="opacity: 0.4;">/</span>
          <span>Save the date</span>
        </div>
      </div>

      <div class="mark-wrap">
        <p class="pre">Trade the winter cold for Florida sunshine. The cooperative gathers again&hellip;</p>
        <h1 class="summit-mark">
          Innovia<br>
          Summit <span class="yr">2027</span>
        </h1>

        <div class="theme-bar">
          <div>
            <span class="label">2027 Theme</span>
            <h2><em>Benchmarks</em> &amp; Beyond.</h2>
          </div>
          <p class="strap">Knowing your numbers. Owning your future. Three days of working sessions, founder-only conversations, and the unhurried hospitality the cooperative is known for &mdash; in a city designed for it.</p>
        </div>
      </div>

      <div class="below">
        <div class="cell">
          <span class="k">When</span>
          <span class="v">February 2027<small>First week &middot; exact dates with invite</small></span>
        </div>
        <div class="cell">
          <span class="k">Where</span>
          <span class="v">Tampa, Florida<small>Venue reveal coming soon</small></span>
        </div>
        <div class="cell">
          <span class="k">Format</span>
          <span class="v">3 days &middot; closed-door<small>Founder &amp; senior-operator only</small></span>
        </div>
        <div class="cell cta-cell">
          <a href="#notify" class="btn btn-amber">
            Get Notified
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== INTRIGUE — venue tease ============== -->
  <section class="intrigue">
    <div class="container">
      <div class="layout">
        <div>
          <div class="eyebrow-w">
            <span class="pill">Venue &middot; Coming Soon</span>
            <span>The reveal</span>
          </div>
          <h2>A venue that <em>makes a statement.</em></h2>
          <p class="lede">Picture a 5-star property designed by the visionary behind Studio 54 &mdash; the pioneer of the modern boutique hotel. Art-deco curves throughout. A jungle-like lobby. A rooftop overlooking the bay. The kind of room that signals: this is not a typical industry conference.</p>

          <div class="seal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span>Full hotel reveal &middot; coming with invitations</span>
          </div>
        </div>

        <div class="clues">
          <div class="clue">
            <span class="num">01</span>
            <div>
              <h4>A city in the sun.</h4>
              <p>The architect&rsquo;s words for it. February in the Sunshine State, with seven on-site bars and restaurants &mdash; one of them <em>Michelin-starred</em> &mdash; and a rooftop pool terrace overlooking the bay.</p>
            </div>
          </div>
          <div class="clue">
            <span class="num">02</span>
            <div>
              <h4>Simple and pure. Nothing superfluous.</h4>
              <p>The designer&rsquo;s philosophy &mdash; and a fit for the way the cooperative runs its Summit. No vendor floors. No sponsor logos on lanyards. Just the work, the conversations, and the room they happen in.</p>
            </div>
          </div>
          <div class="clue">
            <span class="num">03</span>
            <div>
              <h4>Named Best New Hotel in the World.</h4>
              <p>By <em>Travel + Leisure.</em> Three hundred and fifty hand-hung disco balls in the lounge. Twenty-foot ceilings in the lobby. Bold curves everywhere. We&rsquo;ll show you the rest in February.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== THEME ============== -->
  <section class="theme-section">
    <div class="container">
      <div class="head">
        <span class="label">2027 &middot; Program direction</span>
        <h2>Knowing your numbers.<br><em>Owning your future.</em></h2>
        <p class="sub">The 2027 program is built around the operating intelligence members have been asking for: real benchmarks, real margin math, and the working sessions to do something with both. The cooperative isn&rsquo;t just for the CEO &mdash; it&rsquo;s for the manager, the controller, the facility lead. Every seat in the room is doing the work.</p>
      </div>

      <div class="pillars">
        <div class="pillar">
          <span class="ix">Track 01</span>
          <h3>Benchmarks &amp; Margin Math</h3>
          <p>Member-only operating benchmarks across portfolios, regions, and revenue lines. Pricing, retention, and the spreadsheet you couldn&rsquo;t build alone.</p>
          <span class="quiet">Closed-door &middot; founders &amp; senior ops</span>
        </div>
        <div class="pillar">
          <span class="ix">Track 02</span>
          <h3>The Cinderella Cohorts</h3>
          <p>Manager, accounting, and facility-lead development &mdash; the roles every CAM company is losing. Dedicated breakouts. Peer cohorts that continue past Sunday.</p>
          <span class="quiet">Cross-functional &middot; all levels</span>
        </div>
        <div class="pillar">
          <span class="ix">Track 03</span>
          <h3>Owning the Future</h3>
          <p>Independence in an age of acquisition. Vendor-program intelligence. The five things the membership puts on the 2028 calendar before the rooftop sends us home.</p>
          <span class="quiet">Whole co-op &middot; member governance</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== PAST SUMMITS ============== -->
  <section class="past" id="past">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow"><span class="num">No. 04</span><span class="rule-mini"></span>Past summits</div>
          <h2>Every edition, in one place.</h2>
        </div>
        <p>The 2027 Summit returns to the same format &mdash; one room, the whole co-op, member-submitted topics, no vendor floor &mdash; refined year over year. The 2026 recap is the clearest picture of what to expect.</p>
      </div>

      <!-- Featured: 2026 -->
      <article class="featured">
        <div class="photo">
          <img src="/assets/photos/reception-rooftop-evening.jpg" alt="">
          <span class="stamp"><span class="dot"></span>Most recent &middot; 2026</span>
        </div>
        <div class="body">
          <span class="ix">Annual Summit &middot; Feb 4&ndash;6, 2026</span>
          <h3>Lido House, Newport Beach</h3>
          <p>The 2026 Summit gathered 45 founders and senior operators on the California coast for three days of working sessions across Technology &amp; AI, Financial innovation, HR &amp; Talent Management, and Business Intelligence &mdash; plus the founder-only conversations the cooperative is built around.</p>
          <div class="stats">
            <div><span class="k">Attendees</span><span class="v">45</span></div>
            <div><span class="k">Member cos.</span><span class="v">31</span></div>
            <div><span class="k">States</span><span class="v">25+</span></div>
          </div>
          <div class="actions">
            <a href="/summit/2026/" class="btn btn-primary">
              View 2026 Recap
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
            <a href="/summit/2026/#sessions" class="btn btn-outline">Session highlights</a>
          </div>
        </div>
      </article>

      <!-- Older editions -->
      <div class="archive-row">
        <a class="edition" href="/summit/2026/">
          <span class="yr">25</span>
          <span class="v placeholder placeholder-inline">Park Hyatt &middot; Aviara</span>
          <span class="m"><span class="placeholder placeholder-inline">Annual Summit</span> &middot; <span class="placeholder placeholder-inline">Mar 2025</span></span>
          <span class="hl placeholder placeholder-inline">The Cinderella program launched here &mdash; manager, accounting, and facility cohorts that members continue today.</span>
        </a>
        <a class="edition" href="/summit/2026/">
          <span class="yr">24</span>
          <span class="v placeholder placeholder-inline">Montage &middot; Laguna Beach</span>
          <span class="m"><span class="placeholder placeholder-inline">Annual Summit</span> &middot; <span class="placeholder placeholder-inline">Apr 2024</span></span>
          <span class="hl placeholder placeholder-inline">The vendor program restructure &mdash; banking, software, and insurance terms rebuilt around member rates.</span>
        </a>
        <a class="edition" href="/summit/2026/">
          <span class="yr">23</span>
          <span class="v placeholder placeholder-inline">Rosewood &middot; Miramar</span>
          <span class="m"><span class="placeholder placeholder-inline">Annual Summit</span> &middot; <span class="placeholder placeholder-inline">May 2023</span></span>
          <span class="hl placeholder placeholder-inline">First closed-door founder fireside on staying independent in the age of the PE roll-up.</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ============== NOTIFY ============== -->
  <section class="notify" id="notify">
    <div class="container">
      <div class="frame">
        <div class="copy">
          <span class="label">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 6 12 13 2 6"/><path d="M2 6h20v12H2z"/></svg>
            Stay tuned
          </span>
          <h2>The invitation list <em>opens first</em> to the people on this list.</h2>
          <p class="strap">Drop your details and we&rsquo;ll send the venue reveal, dates, and member-referral path the moment they&rsquo;re live. Member companies are notified first; prospective members are looped in after.</p>
        </div>

        <form onsubmit="event.preventDefault(); this.querySelector('button').textContent='Thanks — we\\u2019ll be in touch';">
          <div class="row">
            <label>First name
              <input type="text" placeholder="Jordan" autocomplete="given-name" required>
            </label>
            <label>Last name
              <input type="text" placeholder="Reyes" autocomplete="family-name" required>
            </label>
          </div>
          <div class="row single">
            <label>Work email
              <input type="email" placeholder="you@yourcompany.com" autocomplete="email" required>
            </label>
          </div>
          <div class="row">
            <label>Company
              <input type="text" placeholder="Your CAM company" autocomplete="organization" required>
            </label>
            <label>Relationship
              <select required>
                <option value="">Choose one</option>
                <option>Innovia member company</option>
                <option>Prospective member</option>
                <option>Vendor partner</option>
                <option>Other</option>
              </select>
            </label>
          </div>
          <div class="submit-row">
            <small>By invitation only. We won&rsquo;t share your details.</small>
            <button type="submit">
              Get the reveal
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ============== FOOTER ============== -->
  <!-- FOOTER -->
  


  
`;
---
<BaseLayout
  title="Innovia Summit 2027 · Coming February · Innovia Co-op"
  description="Innovia Summit 2027 — the annual closed-door convening of the cooperative. First week of February. A venue designed by the visionary behind Studio 54."
  ogImage="/assets/og/option-1-type-led.png"
  headerVariant="inverse"
  activeNav="summit"
  ctaLabel="Get Notified"
  ctaHref="#notify"
>
  <Fragment set:html={html} />
</BaseLayout>
