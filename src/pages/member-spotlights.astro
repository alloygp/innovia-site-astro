---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Hero ---------- */
    .page-hero {
      padding: 40px 0 40px;
      position: relative; overflow: hidden;
    }
    .page-hero::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 92% 8%, rgba(149,208,49,0.16) 0%, transparent 40%),
        radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
      margin-bottom: 28px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero .crumb .right {
      margin-left: auto;
      display: flex; align-items: center; gap: 12px;
    }
    .page-hero .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }
    .page-hero h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(40px, 5.4vw, 88px);
      line-height: 0.95;
      letter-spacing: -0.035em;
      color: #fff; margin: 0;
      text-wrap: balance;
    }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light {
      display: block;
      margin-top: 10px;
      font-family: var(--font-body);
      font-weight: 300;
      font-style: italic;
      font-size: 0.46em;
      line-height: 1.25;
      color: var(--innovia-green);
      letter-spacing: -0.02em;
    }
    .page-hero .below {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 56px;
      align-items: end;
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .below p {
      font-size: clamp(17px, 1.3vw, 19px);
      line-height: 1.55;
      color: rgba(255,255,255,0.78);
      max-width: 56ch;
      margin: 0;
    }
    .page-hero .below .filters {
      display: flex; flex-direction: column; gap: 16px;
    }
    .page-hero .below .filter-row {
      display: flex; gap: 8px; flex-wrap: wrap;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .below .filter-row .pill {
      padding: 7px 14px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.16);
      font-family: var(--font-body);
      font-size: 13px;
      color: rgba(255,255,255,0.78);
      letter-spacing: 0.01em;
      transition: all .15s;
      cursor: pointer;
    }
    .page-hero .below .filter-row .pill:hover { border-color: var(--innovia-green); color: #fff; }
    .page-hero .below .filter-row .pill.active {
      background: var(--innovia-green); color: var(--innovia-navy);
      border-color: var(--innovia-green);
      font-weight: 600;
    }
    .page-hero .below .filter-label {
      font-family: var(--font-display); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      font-weight: 600;
    }

    /* ---------- Bento grid ---------- */
    .bento {
      padding: 24px 0 96px;
    }
    .bento .grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: 240px;
      gap: 14px;
    }
    .bento .card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.12);
      overflow: hidden;
      position: relative;
      transition: border-color .2s, transform .25s, box-shadow .25s;
      display: flex; flex-direction: column;
      isolation: isolate;
      text-decoration: none;
      color: inherit;
    }
    .bento .card.linked { cursor: pointer; }
    .bento .card.linked:hover {
      border-color: var(--innovia-green);
      transform: translateY(-4px);
      box-shadow: 0 24px 56px rgba(0,0,0,0.4);
    }
    .bento .card .pending-stamp {
      position: absolute; top: 14px; right: 14px;
      font-family: var(--font-mono); font-size: 9px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.12);
      padding: 4px 8px;
      z-index: 2;
    }

    /* Featured (big photo + name + tagline + CTA) */
    .card.featured {
      grid-column: span 8;
      grid-row: span 2;
      background: var(--innovia-navy);
    }
    .card.featured .photo {
      position: absolute; inset: 0; z-index: 0;
    }
    .card.featured .photo img {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.92);
    }
    .card.featured .photo::after {
      content: ""; position: absolute; inset: 0;
      background:
        linear-gradient(95deg, rgba(15,36,71,0.85) 0%, rgba(15,36,71,0.55) 55%, rgba(15,36,71,0.2) 100%),
        linear-gradient(180deg, rgba(15,36,71,0.05) 50%, rgba(15,36,71,0.6) 100%);
    }
    .card.featured .body {
      position: relative; z-index: 1;
      padding: 40px 44px;
      flex: 1;
      display: flex; flex-direction: column;
      justify-content: space-between;
      gap: 24px;
      color: #fff;
    }
    .card.featured .feat-row {
      display: flex; align-items: center; justify-content: space-between;
    }
    .card.featured .feat-tag {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-display);
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--innovia-green);
      background: rgba(149,208,49,0.16);
      padding: 6px 12px;
    }
    .card.featured .feat-tag .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 8px rgba(149,208,49,0.7);
    }
    .card.featured .mark {
      width: 56px; height: 56px;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 800;
      font-size: 20px; letter-spacing: -0.02em;
    }
    .card.featured h3 {
      color: #fff;
      font-size: clamp(34px, 4vw, 56px);
      line-height: 0.98;
      letter-spacing: -0.028em;
      margin: 0;
      max-width: 16ch;
      text-wrap: balance;
    }
    .card.featured .quote {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 19px;
      line-height: 1.4;
      color: rgba(255,255,255,0.88);
      max-width: 50ch;
      margin: 0;
      letter-spacing: -0.005em;
    }
    .card.featured .foot {
      display: flex; justify-content: space-between; align-items: center;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .card.featured .loc {
      font-size: 14px; color: rgba(255,255,255,0.7);
      display: flex; align-items: center; gap: 8px;
    }
    .card.featured .visit {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 18px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      font-family: var(--font-display); font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.04em; text-transform: uppercase;
      transition: background .2s;
    }
    .card.linked.featured:hover .visit { background: var(--innovia-green-deep); }

    /* Quote card — medium portrait */
    .card.quote-card {
      grid-column: span 4;
      grid-row: span 2;
      padding: 32px;
      display: flex; flex-direction: column; gap: 18px;
      justify-content: space-between;
      background: var(--innovia-navy-deep);
    }
    .card.quote-card .top {
      display: flex; justify-content: space-between; align-items: flex-start;
    }
    .card.quote-card .mark {
      width: 48px; height: 48px;
      background: rgba(149,208,49,0.16);
      color: var(--innovia-green);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 800;
      font-size: 16px;
    }
    .card.quote-card .meta-tag {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .card.quote-card .q {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 21px;
      line-height: 1.32;
      letter-spacing: -0.012em;
      color: #fff;
      margin: 0;
    }
    .card.quote-card .q::before {
      content: "“";
      font-family: var(--font-display);
      font-weight: 900;
      color: var(--innovia-green);
      margin-right: 2px;
    }
    .card.quote-card .foot {
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.18);
      display: flex; flex-direction: column; gap: 4px;
    }
    .card.quote-card .name {
      font-family: var(--font-display); font-weight: 700;
      font-size: 16px; color: #fff;
      letter-spacing: -0.005em;
    }
    .card.quote-card .loc {
      font-size: 12px; color: rgba(255,255,255,0.55);
    }

    /* Place card — wide w/ photo strip */
    .card.place {
      grid-column: span 6;
      grid-row: span 1;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr 200px;
      background: rgba(255,255,255,0.04);
    }
    .card.place .text-side {
      padding: 28px;
      display: flex; flex-direction: column;
      gap: 12px;
      justify-content: space-between;
    }
    .card.place .top-row {
      display: flex; align-items: center; justify-content: space-between;
    }
    .card.place .mark {
      width: 44px; height: 44px;
      background: rgba(149,208,49,0.16);
      color: var(--innovia-green);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 800;
      font-size: 14px;
    }
    .card.place .meta-tag {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .card.place h4 {
      font-size: 22px;
      color: #fff;
      letter-spacing: -0.015em;
      line-height: 1.18;
      margin: 0;
      max-width: 20ch;
    }
    .card.place .foot {
      display: flex; gap: 16px; align-items: center;
      padding-top: 12px;
      border-top: 1px solid rgba(255,255,255,0.10);
      font-size: 13px;
      color: rgba(255,255,255,0.7);
    }
    .card.place .photo-side {
      background: var(--innovia-navy);
      position: relative;
      overflow: hidden;
    }
    .card.place .photo-side img {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.85);
    }
    .card.place .photo-side::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(90deg, rgba(15,36,71,0.5) 0%, transparent 100%);
    }

    /* Compact card — name + mark + city */
    .card.compact {
      grid-column: span 3;
      grid-row: span 1;
      padding: 24px;
      display: flex; flex-direction: column; gap: 12px;
      justify-content: space-between;
      background: rgba(255,255,255,0.04);
    }
    .card.compact .top {
      display: flex; align-items: center; justify-content: space-between;
    }
    .card.compact .mark {
      width: 40px; height: 40px;
      background: rgba(149,208,49,0.16);
      color: var(--innovia-green);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 800;
      font-size: 13px;
    }
    .card.compact .meta-tag {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .card.compact h4 {
      font-size: 17px;
      color: #fff;
      letter-spacing: -0.012em;
      line-height: 1.18;
      margin: 0;
    }
    .card.compact .foot {
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px;
      color: rgba(255,255,255,0.55);
      padding-top: 12px;
      border-top: 1px solid rgba(255,255,255,0.10);
    }
    .card.compact .arrow { color: rgba(255,255,255,0.4); }
    .card.compact.linked:hover .arrow { color: var(--innovia-green); transform: translateX(2px); }

    /* Wide quote card with green accent */
    .card.green-feature {
      grid-column: span 6;
      grid-row: span 1;
      padding: 32px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      display: flex; flex-direction: column;
      justify-content: space-between;
      gap: 16px;
    }
    .card.green-feature .meta-tag {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-navy);
      opacity: 0.65;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .card.green-feature h4 {
      color: var(--innovia-navy);
      font-size: 28px;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0;
      max-width: 22ch;
    }
    .card.green-feature .foot {
      display: flex; justify-content: space-between; align-items: center;
      padding-top: 14px;
      border-top: 1px solid rgba(24,51,94,0.3);
      font-size: 13px;
      color: var(--innovia-navy);
    }
    .card.green-feature .foot strong {
      font-family: var(--font-display); font-weight: 700;
    }

    /* ---------- Closing CTA ---------- */
    .closing {
      padding: 96px 0;
      background: var(--innovia-navy-deep);
    }
    .closing .frame {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 64px; align-items: center;
    }
    .closing h2 {
      color: #fff;
      font-size: clamp(36px, 4.4vw, 56px);
      letter-spacing: -0.025em;
      max-width: 22ch;
    }
    .closing h2 em { color: var(--innovia-green); font-style: normal; }
    .closing p {
      color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.55;
      margin: 18px 0 0;
      max-width: 50ch;
    }
    .closing .actions {
      display: flex; flex-direction: column; gap: 10px;
    }
    .closing .actions .btn { padding: 16px 24px; font-size: 15px; justify-content: center; }

    @media (max-width: 1080px) {
      .page-hero .below, .closing .frame { grid-template-columns: 1fr; gap: 32px; }
      .bento .grid { grid-template-columns: repeat(6, 1fr); grid-auto-rows: 220px; }
      .card.featured { grid-column: span 6; }
      .card.quote-card { grid-column: span 6; }
      .card.place { grid-column: span 6; }
      .card.green-feature { grid-column: span 6; }
      .card.compact { grid-column: span 3; }
    }
    @media (max-width: 720px) {
      .bento .grid { grid-template-columns: 1fr; }
      .card.featured, .card.quote-card, .card.place, .card.green-feature, .card.compact { grid-column: span 1; }
      .card.place { grid-template-columns: 1fr; }
      .card.place .photo-side { display: none; }
    }
  </style>


  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a><span>/</span>
        <a href="/for-cams/why-innovia/">For CAMs</a><span>/</span>
        <span style="color:#fff;">Member Spotlights</span>
        <div class="right">
          <span class="dot"></span>
          <span class="placeholder placeholder-inline">8</span>&nbsp;featured stories &middot; <span class="placeholder placeholder-inline">22</span>&nbsp;films in production
        </div>
      </div>
      <h1>
        Members <em>in action.</em><br>
        <span class="light">the cooperative, made visible through the companies inside it.</span>
      </h1>
      <div class="below">
        <p>The cooperative grows by introduction &mdash; and once you&rsquo;re inside, the proof is the work. These are member companies in their own communities: the operating practices, the leadership, the ways they show up for boards and homeowners. Eight articles below; <span class="placeholder placeholder-inline">twenty-two summit-shot films arrive across 2026</span>.</p>
        <div class="filters">
          <div class="filter-label">Browse by theme</div>
          <div class="filter-row">
            <span class="pill active">All themes</span>
            <span class="pill">Leadership</span>
            <span class="pill">Practice</span>
            <span class="pill">Community</span>
            <span class="pill">Innovation</span>
            <span class="pill">For boards</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BENTO GRID — 8 real member spotlights from innoviaco-op.com/blog -->
  <section class="bento">
    <div class="container">
      <div class="grid">

        <!-- 1. FEATURED — Nova Association Management Partners · Nov 2025 -->
        <a class="card featured linked" href="https://innoviaco-op.com/blog/" target="_blank" rel="noopener">
          <div class="photo" aria-hidden="true">
            <img src="/assets/photos/applause-engaged.jpg" alt="">
          </div>
          <div class="body">
            <div class="feat-row">
              <span class="feat-tag"><span class="dot"></span>Latest spotlight &middot; Nov 2025</span>
              <span class="mark">NA</span>
            </div>
            <div>
              <h3>Honoring excellence and innovation.</h3>
              <p class="quote" style="margin-top: 18px;">Inside <strong>Nova Association Management Partners&rsquo;</strong> Core Value Awards &mdash; the internal recognition program a member company built around the people who do the work. The kind of practice the cooperative now shares across the network.</p>
            </div>
            <div class="foot">
              <span class="loc">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Nova Association Management Partners &middot; Innovia member
              </span>
              <span class="visit">
                Read the article
                <svg class="arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
              </span>
            </div>
          </div>
        </a>

        <!-- 2. QUOTE — Wise Property Solutions · Aug 2025 -->
        <a class="card quote-card linked" href="https://innoviaco-op.com/blog/" target="_blank" rel="noopener" style="text-decoration: none;">
          <div class="top">
            <span class="mark">WP</span>
            <span class="meta-tag">Practice &middot; Aug 2025</span>
          </div>
          <p class="q">Twelve performance measures for an HOA&rsquo;s annual checkup &mdash; the operating practice <strong>Wise Property Solutions</strong> walks every community through, year after year.</p>
          <div class="foot">
            <span class="name">Wise Property Solutions</span>
            <span class="loc">Innovia member &middot; read on innoviaco-op.com &rarr;</span>
          </div>
        </a>

        <!-- 3. GREEN FEATURE — cooperative advantage band -->
        <div class="card green-feature">
          <span class="meta-tag">The Innovia difference</span>
          <h4>Independently owned. Cooperatively backed. Members bring more to every community than a company working alone could.</h4>
          <div class="foot">
            <span><strong class="placeholder placeholder-inline">80<span style="opacity:.6">+</span></strong> companies</span>
            <span><strong class="placeholder placeholder-inline">38</strong> states</span>
            <span><strong class="placeholder placeholder-inline">1.2M<span style="opacity:.6">+</span></strong> households</span>
          </div>
        </div>

        <!-- 4. PLACE — Great North Property Management · Jul 2025 -->
        <a class="card place linked" href="https://innoviaco-op.com/blog/" target="_blank" rel="noopener" style="text-decoration: none;">
          <div class="text-side">
            <div class="top-row">
              <span class="mark">GN</span>
              <span class="meta-tag">Leadership &middot; Jul 2025</span>
            </div>
            <h4>A remarkable example of leadership.</h4>
            <div class="foot">
              <span>Great North Property Management</span>
              <span>Read article &rarr;</span>
            </div>
          </div>
          <div class="photo-side" aria-hidden="true">
            <img src="/assets/photos/panel-discussion.jpg" alt="">
          </div>
        </a>

        <!-- 5. PLACE — CPE Property Management Solutions · Jul 2025 -->
        <a class="card place linked" href="https://innoviaco-op.com/blog/" target="_blank" rel="noopener" style="text-decoration: none;">
          <div class="text-side">
            <div class="top-row">
              <span class="mark">CPE</span>
              <span class="meta-tag">Practice &middot; Jul 2025</span>
            </div>
            <h4>Clear communication. Proactive planning.</h4>
            <div class="foot">
              <span>CPE Property Management Solutions</span>
              <span>Read article &rarr;</span>
            </div>
          </div>
          <div class="photo-side" aria-hidden="true">
            <img src="/assets/photos/roundtable-discussion.jpg" alt="">
          </div>
        </a>

        <!-- 6. PLACE — Association Management Group (AMG) · Jun 2025 -->
        <a class="card place linked" href="https://innoviaco-op.com/blog/" target="_blank" rel="noopener" style="text-decoration: none;">
          <div class="text-side">
            <div class="top-row">
              <span class="mark">AMG</span>
