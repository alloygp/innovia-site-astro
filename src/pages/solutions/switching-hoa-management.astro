---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 56px; position: relative; overflow: hidden; }
    .page-hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 92% 8%, rgba(149,208,49,0.14) 0%, transparent 38%), radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%); pointer-events: none; }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 36px; }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light { display: block; margin-top: 8px; font-family: var(--font-body); font-weight: 300; font-style: italic; color: rgba(255,255,255,0.55); font-size: 0.48em; letter-spacing: -0.02em; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }
    
  
    .article-body { padding: 32px 0 96px; }
    .article-body .layout { display: grid; grid-template-columns: 220px 1fr; gap: 64px; align-items: start; }
    .article-body .toc { position: sticky; top: 96px; }
    .article-body .toc h6 { font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.45); letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.14); }
    .article-body .toc ol { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; counter-reset: tocnum; }
    .article-body .toc li { counter-increment: tocnum; }
    .article-body .toc a { font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; padding-left: 22px; position: relative; display: block; line-height: 1.4; transition: color .15s; }
    .article-body .toc a::before { content: counter(tocnum, decimal-leading-zero); position: absolute; left: 0; color: var(--innovia-green); font-size: 10px; }
    .article-body .toc a:hover { color: #fff; }

    .article-body .content { max-width: 64ch; }
    .article-body .content h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 3vw, 38px); color: #fff; letter-spacing: -0.018em; margin: 48px 0 16px; line-height: 1.1; scroll-margin-top: 96px; }
    .article-body .content h2:first-child { margin-top: 0; }
    .article-body .content h3 { font-family: var(--font-display); font-weight: 700; font-size: 20px; color: #fff; letter-spacing: -0.008em; margin: 32px 0 10px; }
    .article-body .content p { font-size: 17px; line-height: 1.66; color: rgba(255,255,255,0.78); margin: 0 0 18px; }
    .article-body .content .pull { font-family: var(--font-display); font-weight: 500; font-size: 22px; line-height: 1.4; color: #fff; padding: 22px 0; margin: 32px 0; border-top: 3px solid var(--innovia-green); border-bottom: 1px solid rgba(255,255,255,0.14); letter-spacing: -0.01em; }
    .article-body .content ul.checklist { list-style: none; padding: 24px 28px; margin: 28px 0; background: rgba(149,208,49,0.06); border: 1px solid rgba(149,208,49,0.32); display: flex; flex-direction: column; gap: 12px; }
    .article-body .content ul.checklist li { padding-left: 30px; position: relative; font-size: 15px; line-height: 1.5; color: rgba(255,255,255,0.85); }
    .article-body .content ul.checklist li::before { content: "✓"; position: absolute; left: 0; top: 0; color: var(--innovia-green); font-weight: 700; font-size: 18px; }
    .article-body .content ul.steps { list-style: none; padding: 0; margin: 24px 0; counter-reset: stepnum; }
    .article-body .content ul.steps li { counter-increment: stepnum; padding: 18px 0 18px 56px; position: relative; border-bottom: 1px solid rgba(255,255,255,0.10); font-size: 16px; line-height: 1.55; color: rgba(255,255,255,0.8); }
    .article-body .content ul.steps li::before { content: counter(stepnum, decimal-leading-zero); position: absolute; left: 0; top: 18px; font-family: var(--font-mono); font-size: 14px; color: var(--innovia-green); font-weight: 700; letter-spacing: 0.06em; }
    .article-body .content ul.steps li strong { color: #fff; font-family: var(--font-display); font-weight: 700; display: block; margin-bottom: 4px; }

    .inline-cta { margin: 48px 0; padding: 28px 32px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; gap: 28px; align-items: center; justify-content: space-between; flex-wrap: wrap; }
    .inline-cta strong { display: block; font-family: var(--font-display); font-weight: 700; color: #fff; font-size: 17px; }
    .inline-cta span { font-size: 14px; color: rgba(255,255,255,0.7); margin-top: 4px; display: block; }

    .related-pages { padding: 80px 0 96px; background: var(--innovia-navy-deep); border-top: 1px solid rgba(255,255,255,0.08); }
    .related-pages h2 { font-family: var(--font-display); font-weight: 700; font-size: 28px; color: #fff; margin: 0 0 24px; letter-spacing: -0.014em; }
    .related-pages .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .related-pages a { padding: 22px 26px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 6px; text-decoration: none; color: inherit; transition: border-color .15s; }
    .related-pages a:hover { border-color: var(--innovia-green); }
    .related-pages a .ix { font-family: var(--font-mono); font-size: 10px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; }
    .related-pages a h4 { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff; letter-spacing: -0.008em; margin: 0; }

    @media (max-width: 1080px) { .article-body .layout { grid-template-columns: 1fr; gap: 32px; } .article-body .toc { position: static; } .related-pages .grid { grid-template-columns: 1fr; } }
  </style>



  <section class="page-hero">
    <div class="container">
      
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <a href="/board-education/">Board Resources</a>
        <span>/</span>
        <a href="#">Solutions</a>
        <span>/</span>
        <span style="color:#fff;">Switching HOA Management</span>
      </div>
      <h1>How to change<br>your <em>HOA management</em><br><span class="light">company &mdash; without the chaos.</span></h1>
      <p class="lede">A board-level playbook for the transition most boards dread. Six steps, two warnings, one printable checklist. Written by member-company founders who have been on both sides of this.</p>
    </div>
  </section>

  <section class="article-body">
    <div class="container">
      <div class="layout">
        <aside class="toc">
          <h6>In this guide</h6>
          <ol>
            <li><a href="#why">Why boards switch</a></li>
            <li><a href="#timing">Timing &amp; notice</a></li>
            <li><a href="#evaluate">Evaluating candidates</a></li>
            <li><a href="#transition">The transition plan</a></li>
            <li><a href="#data">Data &amp; records</a></li>
            <li><a href="#first-90">The first 90 days</a></li>
          </ol>
        </aside>

        <article class="content">
          <h2 id="why">Why boards switch.</h2>
          <p>Most board-level management changes don&rsquo;t happen because of a single failure. They happen because of accumulated friction &mdash; slow responsiveness, missed reserve milestones, a manager who doesn&rsquo;t return calls, board meetings that consistently go off-script.</p>
          <p class="pull"><span class="placeholder placeholder-inline">A switch is rarely an emergency. It&rsquo;s a decision that&rsquo;s been forming for months. The work is making it deliberate.</span></p>

          <h2 id="timing">Timing &amp; notice.</h2>
          <p>Most management contracts include a 60&ndash;90 day termination clause. Read yours carefully. The clock matters &mdash; and so does the way notice is communicated.</p>
          <ul class="checklist">
            <li><span class="placeholder placeholder-inline">Review the termination clause in your current management agreement (page 2 of the standard template).</span></li>
            <li><span class="placeholder placeholder-inline">Confirm the next fiscal year boundary &mdash; transitions are cleaner at year-end.</span></li>
            <li><span class="placeholder placeholder-inline">Document the board vote to begin a search before issuing notice.</span></li>
            <li><span class="placeholder placeholder-inline">Plan a 60-day overlap if possible &mdash; old company exits as new company onboards.</span></li>
          </ul>

          <h2 id="evaluate">Evaluating candidates.</h2>
          <p>Avoid the temptation to issue an RFP to twelve companies. Three to five is the right number. Make sure at least one is Innovia-backed &mdash; the cooperative&rsquo;s vendor terms and shared intelligence are a meaningful differentiator at the contract level.</p>

          <ul class="steps">
            <li><strong>Define the must-haves</strong>Reserve study cadence, audit prep, board reporting frequency, after-hours support &mdash; pick the three or four that actually matter to your community.</li>
            <li><strong>Build a short list</strong>Three to five candidates max. Local references over national brand. Ask the manager you would actually work with to come to a board meeting.</li>
            <li><strong>Standardize the proposals</strong>Same questions, same scope, same template. Otherwise you&rsquo;re comparing apples to differently-sliced apples.</li>
            <li><strong>Ask for the failure modes</strong>What was their last contract loss? What would they do differently? The candidates worth hiring will answer honestly.</li>
          </ul>

          <div class="inline-cta">
            <div>
              <strong>Skip the search.</strong>
              <span>Innovia routes your community to the best-positioned member firm in your area &mdash; one match, two business days, no call lists.</span>
            </div>
            <a href="/find-a-management-company/#request" class="btn btn-primary">Send the inquiry
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
          </div>

          <h2 id="transition">The transition plan.</h2>
          <p><span class="placeholder placeholder-inline">[Section content TBD. Cover: who&rsquo;s responsible during the handoff, banking signature changes, vendor reassignment, where the documents go.]</span></p>

          <h2 id="data">Data &amp; records.</h2>
          <p><span class="placeholder placeholder-inline">[Section content TBD. Cover: governing documents, financials, reserve studies, vendor contracts, key inventories. Include a downloadable handoff checklist.]</span></p>

          <h2 id="first-90">The first 90 days.</h2>
          <p><span class="placeholder placeholder-inline">[Section content TBD. Cover: what to watch in the first 30, 60, 90 days under new management. How to know it&rsquo;s working.]</span></p>
        </article>
      </div>
    </div>
  </section>

  <section class="related-pages">
    <div class="container">
      <h2>Related guides.</h2>
      <div class="grid">
        <a href="/solutions/self-managed-to-pro/">
          <span class="ix">Solution &middot; 02</span>
          <h4>From self-managed to professional HOA management.</h4>
        </a>
        <a href="/solutions/choosing-hoa-management-company/">
          <span class="ix">Solution &middot; 03</span>
          <h4>How to choose an HOA management company.</h4>
        </a>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="How to Change HOA Management Companies · Innovia Co-op"
  description="How to Change HOA Management Companies · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  ctaLabel="Send Inquiry"
  ctaHref="/find-a-management-company/#request"
>
  <Fragment set:html={html} />
</BaseLayout>
