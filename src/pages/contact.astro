---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 48px; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 32px; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }

    .routes { padding: 24px 0 96px; }
    .routes .grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border-top: 1px solid rgba(255,255,255,0.18); border-bottom: 1px solid rgba(255,255,255,0.18); }
    .routes .route { padding: 36px 32px; border-right: 1px solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 14px; text-decoration: none; color: inherit; transition: background .15s; }
    .routes .route:last-child { border-right: 0; }
    .routes .route:hover { background: rgba(149,208,49,0.06); }
    .routes .route .ix { font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.14em; text-transform: uppercase; }
    .routes .route h3 { font-family: var(--font-display); font-weight: 700; font-size: 24px; color: #fff; letter-spacing: -0.018em; line-height: 1.2; margin: 0; max-width: 18ch; }
    .routes .route p { font-size: 14px; line-height: 1.55; color: rgba(255,255,255,0.65); margin: 0; }
    .routes .route .go { margin-top: auto; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.10); font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }

    .direct { padding: 96px 0; background: var(--innovia-navy-deep); border-top: 1px solid rgba(255,255,255,0.08); }
    .direct .frame { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .direct h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(34px, 4vw, 48px); letter-spacing: -0.024em; color: #fff; margin: 0; max-width: 18ch; }
    .direct h2 em { color: var(--innovia-green); font-style: italic; font-weight: 400; }
    .direct .lines { display: flex; flex-direction: column; gap: 18px; }
    .direct .line { display: grid; grid-template-columns: 100px 1fr; gap: 18px; padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.10); }
    .direct .line .k { font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,0.5); letter-spacing: 0.14em; text-transform: uppercase; padding-top: 4px; }
    .direct .line .v { font-size: 16px; color: #fff; line-height: 1.5; }
    .direct .line .v a { color: var(--innovia-green); }

    @media (max-width: 1080px) {
      .routes .grid, .direct .frame { grid-template-columns: 1fr; gap: 32px; }
      .routes .route { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.12); }
      .routes .route:last-child { border-bottom: 0; }
    }
  </style>



  <section class="page-hero">
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <span style="color:#fff;">Contact</span>
      </div>
      <h1>Get in <em>touch.</em></h1>
      <p class="lede">Three audiences, three places to start. Pick the one that fits and the right person will get back to you.</p>
    </div>
  </section>

  <section class="routes">
    <div class="container">
      <div class="grid">
        <a class="route" href="/for-cams/why-innovia/#talk">
          <span class="ix">For CAM Companies</span>
          <h3>Schedule a Conversation.</h3>
          <p>Independent CAM owners exploring the cooperative. A 30-minute call with a member-owner. Confidential. By introduction.</p>
          <span class="go">Start the conversation <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
        </a>
        <a class="route" href="/find-a-management-company/#request">
          <span class="ix">For HOA &amp; Condo Boards</span>
          <h3>Find a management company.</h3>
          <p>Tell us about your community and we&rsquo;ll route the inquiry to the Innovia-backed member best positioned to serve it.</p>
          <span class="go">Send the inquiry <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
        </a>
        <a class="route" href="/partners/">
          <span class="ix">For Vendor Partners</span>
          <h3>Partner with the cooperative.</h3>
          <p>Vendor partnerships are member-curated and reviewed annually. If your product or service serves CAM companies, start here.</p>
          <span class="go">Talk to partnerships <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <section class="direct">
    <div class="container">
      <div class="frame">
        <h2>Or reach us <em>directly.</em></h2>
        <div class="lines">
          <div class="line"><span class="k">General</span><span class="v"><a href="mailto:hello@innovia.co-op" class="placeholder placeholder-inline">hello@innovia.co-op</a></span></div>
          <div class="line"><span class="k">Press &amp; Media</span><span class="v"><a href="mailto:press@innovia.co-op" class="placeholder placeholder-inline">press@innovia.co-op</a></span></div>
          <div class="line"><span class="k">Membership</span><span class="v"><a href="mailto:members@innovia.co-op" class="placeholder placeholder-inline">members@innovia.co-op</a></span></div>
          <div class="line"><span class="k">Office</span><span class="v"><span>Manchester, NH</span></span></div>
          <div class="line"><span class="k">Hours</span><span class="v">Mon&ndash;Fri &middot; 9am&ndash;5pm <span>Eastern Time</span></span></div>
        </div>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="Contact · Innovia Co-op"
  description="Contact · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  ctaLabel="Schedule a Conversation"
  ctaHref="/for-cams/why-innovia/#talk"
>
  <Fragment set:html={html} />
</BaseLayout>
