---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/testimonials.css';
const html = `


  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <span style="color:#fff;">Testimonials</span>
        <div class="right">
          <span class="dot"></span>
          10&nbsp;voices on record &middot; 22 Summit films in production
        </div>
      </div>

      <div class="title-row">
        <h1>
          What members <em>actually say</em> when the recorder is on.
        </h1>
      </div>

    </div>
  </section>

  <div class="filter-sticky">
    <div class="container">
      <div class="filter-band">
        <div class="row" data-filter-group="voice">
          <span class="label">Voice</span>
          <div class="pills">
            <button class="pill active" data-filter="all">All (9)</button>
            <button class="pill" data-filter="cam-owner">CAM owners (3)</button>
            <button class="pill" data-filter="senior-operator">Senior operators (2)</button>
            <button class="pill" data-filter="board-member">Board members (4)</button>
          </div>
        </div>
        <div class="row" data-filter-group="topic">
          <span class="label">Topic</span>
          <div class="pills">
            <button class="pill active" data-filter="all">All</button>
            <button class="pill" data-filter="Joining Innovia">Joining Innovia</button>
            <button class="pill" data-filter="The peer council">The peer council</button>
            <button class="pill" data-filter="Business growth">Business growth</button>
            <button class="pill" data-filter="Board member">Board member</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- FEATURED QUOTE -->
  <section class="featured-quote-section">
    <div class="container">
      <article class="featured-quote">
        <span class="kind"><span class="dot"></span>Featured testimonial &middot; PS Management</span>
        <div class="quote-mark">&ldquo;</div>
        <blockquote>
          Since joining Innovia we&rsquo;ve doubled our business by implementing the programs and best-practice strategies we&rsquo;ve been exposed to as a member. We need to evolve and continue to grow as a company &mdash; Innovia provides us with the tools to do just that.
        </blockquote>
        <div class="attrib">
          <div class="who">
            <div class="details">
              <span class="name">Ricky Zilem</span>
              <span class="role">Managing Partner</span>
              <span class="firm">PS Management &middot; Texas</span>
            </div>
          </div>
          <div class="recorded">
            <span class="k">Company</span>
            <span class="v">PS Management, Texas</span>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- STAT STRAP -->
  <section class="stat-strap">
    <div class="container">
      <div class="frame">
        <div class="stat"><span class="v">10</span><span class="k">Voices on record</span></div>
        <div class="stat"><span class="v">22</span><span class="k">Summit films in production</span></div>
        <div class="stat"><span class="v">25+</span><span class="k">States represented</span></div>
        <div class="stat"><span class="v">80+</span><span class="k">Member firms eligible to be quoted</span></div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL GRID -->
  <section class="listing">
    <div class="container">
      <div class="tcards">

        <article class="tcard long" data-voice="cam-owner" data-topic="Joining Innovia">
          <span class="kind">Joining Innovia</span>
          <blockquote>CFM&rsquo;s goal is to remain independent and completely focused on the personal needs of each of our clients. To help us achieve this goal, we have invested in a Co-op membership with Innovia &mdash; which allows us to remain independent, while having buying power and thought leadership from other independent companies across the United States.</blockquote>
          <div class="attrib">
            <span class="initials">SD</span>
            <div class="who">
              <span class="name">Stacie Donnelly, PCAM, CCAM</span>
              <span class="firm">Condominium Financial Management, Inc.</span>
            </div>
          </div>
        </article>

        <article class="tcard" data-voice="senior-operator" data-topic="The peer council">
          <span class="kind">The peer council</span>
          <blockquote>Through Innovia, we&rsquo;ve been able to explore new opportunities, unlock cost efficiencies, and elevate our position in the marketplace with peer-driven collaboration while feeling part of a forward-thinking community; participation has been truly transformative.</blockquote>
          <div class="attrib">
            <span class="initials">JA</span>
            <div class="who">
              <span class="name">Jeffrey Annon, Vice President</span>
              <span class="firm">Southern States Management Group &middot; Florida</span>
            </div>
          </div>
        </article>

        <article class="tcard long" data-voice="cam-owner" data-topic="Business growth">
          <span class="kind">Business growth</span>
          <blockquote>I knew the &ldquo;big-box&rdquo; management companies were eventually going to be in my market, but as a member of Innovia we were prepared and remain competitive. We&rsquo;ve really benefited from the peer-to-peer networking opportunities to exchange experiences and ideas and collaborate with like-minded colleagues. Surrounding ourselves with a powerful network has better positioned us for future success.</blockquote>
          <div class="attrib">
            <span class="initials">RK</span>
            <div class="who">
              <span class="name">Robert Klages, Chief Executive Officer</span>
              <span class="firm">Community Property Management &middot; Missouri</span>
            </div>
          </div>
        </article>

        <article class="tcard" data-voice="senior-operator" data-topic="Joining Innovia">
          <span class="kind">Joining Innovia</span>
          <blockquote>If you are looking to keep your independent identity and values, stay competitive in the marketplace and be on top of new innovations in our industry &mdash; Innovia Co-op is the group for you.</blockquote>
          <div class="attrib">
            <span class="initials">JL</span>
            <div class="who">
              <span class="name">Jeffrey Luther, Vice President</span>
              <span class="firm">Vanguard Management Associates Inc. &middot; Maryland</span>
            </div>
          </div>
        </article>

        <article class="tcard long" data-voice="cam-owner" data-topic="Business growth">
          <span class="kind">Business growth</span>
          <blockquote>Innovia has truly inspired me to step out of my own way and build a bigger, better company. It has been an absolute pleasure to be part of this organization through which I have gained invaluable insights into how successful businesses grow. The business-to-business relationships formed through Innovia are one of the most valuable aspects for owners.</blockquote>
          <div class="attrib">
            <span class="initials">MC</span>
            <div class="who">
              <span class="name">Michael Carnahan, Owner &amp; Manager</span>
              <span class="firm">RedBrick Property Management &middot; Illinois</span>
            </div>
          </div>
        </article>

        <article class="tcard board" data-voice="board-member" data-topic="Board member">
          <span class="kind">Board member</span>
          <blockquote>Changing our management company to Landmarc was the best decision our Board ever made. We have been with Landmarc over 15 years and that statement still holds true today. They are a great company staffed with a team of exceptional professionals.</blockquote>
          <div class="attrib">
            <span class="initials">DB</span>
            <div class="who">
              <span class="name">Dennis B.</span>
              <span class="firm">Landmarc Real Estate</span>
            </div>
          </div>
        </article>

        <article class="tcard board" data-voice="board-member" data-topic="Board member">
          <span class="kind">Board member</span>
          <blockquote>Wise Property Solutions has been by far the best HOA management company I&rsquo;ve dealt with in my 14 years of property management. They are easy to work and communicate with, effectively and efficiently handle any problems that may arise, and their professionalism is astounding.</blockquote>
          <div class="attrib">
            <span class="initials">ML</span>
            <div class="who">
              <span class="name">Miranda Lewis</span>
              <span class="firm">Wise Property Solutions</span>
            </div>
          </div>
        </article>

        <article class="tcard board" data-voice="board-member" data-topic="Board member">
          <span class="kind">Board member</span>
          <blockquote>As President of our subdivision, I could not be more pleased with CMA. Its service is superior and I have yet to experience anything other than complete professionalism in resolving any issues. I couldn&rsquo;t serve my community effectively without CMA.</blockquote>
          <div class="attrib">
            <span class="initials">CF</span>
            <div class="who">
              <span class="name">Charlie Foxman</span>
              <span class="firm">Community Managers Associates (CMA)</span>
            </div>
          </div>
        </article>

        <article class="tcard board long" data-voice="board-member" data-topic="Board member">
          <span class="kind">Board member</span>
          <blockquote>I am very grateful to the staff at CPE Property Management Solutions. Joel has been exceptional in handling our financial accounts with his superb professionalism, knowledge and reliability. The same can be said for Sarah, our property manager &mdash; committed to resolving issues quickly and judiciously. As president of Foxwood II Condominium Association, I could not ask for two better people to work and cooperate with.</blockquote>
          <div class="attrib">
            <span class="initials">DB</span>
            <div class="who">
              <span class="name">David Boyle</span>
              <span class="firm">CPE Property Management Solutions</span>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- MEMBER SPOTLIGHTS TEASER -->
  <section class="spotlights-teaser">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 02</span><span class="rule-mini"></span>Member Spotlights</div>
          <h2 style="margin-top: 14px;">Members <em>in action.</em></h2>
        </div>
        <p>The cooperative grows by introduction &mdash; and once you&rsquo;re inside, the proof is the work. Eight member spotlights published; more arriving across 2026.</p>
      </div>
      <div class="spotlight-grid">
        <a class="spotlight-card" href="/member-spotlights/">
          <span class="sp-tag">Nov 2025</span>
          <h4>Honoring excellence and innovation.</h4>
          <p>Nova Association Management Partners &middot; Core Value Awards</p>
        </a>
        <a class="spotlight-card" href="/member-spotlights/">
          <span class="sp-tag">Aug 2025</span>
          <h4>Twelve performance measures for an HOA&rsquo;s annual checkup.</h4>
          <p>Wise Property Solutions &middot; Practice</p>
        </a>
        <a class="spotlight-card" href="/member-spotlights/">
          <span class="sp-tag">Jul 2025</span>
          <h4>A remarkable example of leadership.</h4>
          <p>Great North Property Management &middot; Leadership</p>
        </a>
        <a class="spotlight-card spotlight-cta" href="/member-spotlights/">
          <span>See all 8 spotlights</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- METHODOLOGY -->
  <section class="methodology">
    <div class="container">
      <div class="frame">
        <div>
          <div class="eyebrow"><span class="num">No. 03</span><span class="rule-mini"></span>How we collect quotes</div>
          <h2>Attributed, dated, &amp; <em>approved.</em></h2>
        </div>
        <div class="body">
          <p>Every testimonial on this page was recorded with the member&rsquo;s knowledge and reviewed by the member firm before publication. <strong>No paraphrasing, no composite quotes, no marketing rewrites.</strong> If a quote is here, the person whose name is on it signed off on it.</p>
          <p>Members can request a quote be removed or updated at any time. The cooperative does not own the words; the members do.</p>
          <div class="rules">
            <div class="rule"><span class="k">Rule 01</span><span class="v">Real names. Real firms. No anonymous quotes.</span></div>
            <div class="rule"><span class="k">Rule 02</span><span class="v">The speaker has final approval before publish.</span></div>
            <div class="rule"><span class="k">Rule 03</span><span class="v">Every quote is dated and contextualised.</span></div>
            <div class="rule"><span class="k">Rule 04</span><span class="v">Members can pull their quote at any time.</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-finale">
    <div class="container">
      <div class="frame">
        <div>
          <div class="eyebrow" style="color: var(--innovia-navy); opacity: 0.65;"><span class="num" style="color: var(--innovia-navy);">No. 04</span><span class="rule-mini"></span>Share your voice</div>
          <h2>Members: <em>on the record</em> when you&rsquo;re ready.</h2>
          <p class="lead">If you&rsquo;re an Innovia member with something to say about how the co-op has affected your firm &mdash; for better or for worse &mdash; the council wants it on the record. Boards: read the quotes, then talk to the firms behind them.</p>
        </div>
        <div class="actions">
          <a href="/for-cams/why-innovia/#talk" class="btn btn-navy">
            For members &middot; Submit a quote
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
          <a href="/find-a-management-company/" class="btn btn-outline">For boards &middot; Find the firm behind a quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  


  
`;
---
<BaseLayout
  title="Testimonials &amp; Member Voices · Innovia Co-op"
  description="Testimonials &amp; Member Voices · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  ctaLabel="Schedule a Conversation"
  ctaHref="/schedule-a-conversation/"
>
  <Fragment set:html={html} />
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // Track header visual position in real time so the sticky filter
      // flows with the header slide-in/slide-out animation.
      var header = document.querySelector('.site-header');
      var filterSticky = document.querySelector('.filter-sticky');
      if (header && filterSticky) {
        (function sync() {
          filterSticky.style.top = Math.max(0, header.getBoundingClientRect().bottom) + 'px';
          requestAnimationFrame(sync);
        })();
      }

      // Filters
      var activeVoice = 'all';
      var activeTopic = 'all';

      function applyFilters() {
        document.querySelectorAll('.tcard').forEach(function(card) {
          var voiceOk = activeVoice === 'all' || card.dataset.voice === activeVoice;
          var topicOk = activeTopic === 'all' || card.dataset.topic === activeTopic;
          card.style.display = (voiceOk && topicOk) ? '' : 'none';
        });
      }

      document.querySelectorAll('[data-filter-group="voice"] .pill').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('[data-filter-group="voice"] .pill').forEach(function(p) { p.classList.remove('active'); });
          btn.classList.add('active');
          activeVoice = btn.dataset.filter;
          applyFilters();
        });
      });

      document.querySelectorAll('[data-filter-group="topic"] .pill').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('[data-filter-group="topic"] .pill').forEach(function(p) { p.classList.remove('active'); });
          btn.classList.add('active');
          activeTopic = btn.dataset.filter;
          applyFilters();
        });
      });
    });
  </script>
</BaseLayout>
