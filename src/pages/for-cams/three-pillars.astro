---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 56px; position: relative; overflow: hidden; }
    .page-hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 92% 8%, rgba(149,208,49,0.14) 0%, transparent 38%), radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%); pointer-events: none; }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 36px; }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light { display: block; margin-top: 8px; font-family: var(--font-body); font-weight: 300; font-style: italic; color: rgba(255,255,255,0.55); font-size: 0.48em; letter-spacing: -0.02em; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }
    
  
    .three-pillars { padding: 24px 0 96px; }
    .three-pillars .row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border-top: 2px solid var(--innovia-green); border-bottom: 1px solid rgba(255,255,255,0.18); }
    .three-pillars .pillar { padding: 48px 32px 48px; border-right: 1px solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 18px; text-decoration: none; color: inherit; transition: background .2s; }
    .three-pillars .pillar:last-child { border-right: 0; }
    .three-pillars .pillar:hover { background: rgba(149,208,49,0.06); }
    .three-pillars .num { font-family: var(--font-display); font-weight: 900; font-size: 64px; letter-spacing: -0.04em; color: var(--innovia-green); line-height: 0.85; }
    .three-pillars .legacy { font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,0.5); letter-spacing: 0.06em; }
    .three-pillars .legacy s { color: rgba(255,255,255,0.35); }
    .three-pillars h3 { font-family: var(--font-display); font-weight: 700; font-size: 30px; color: #fff; letter-spacing: -0.018em; margin: 0; }
    .three-pillars .desc { font-size: 15px; line-height: 1.6; color: rgba(255,255,255,0.7); margin: 0; }
    .three-pillars ul { list-style: none; padding: 0; margin: 8px 0 0; display: flex; flex-direction: column; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.7); }
    .three-pillars ul li::before { content: "—"; margin-right: 10px; color: rgba(255,255,255,0.4); }
    .three-pillars .go { margin-top: auto; padding-top: 18px; border-top: 1px solid rgba(255,255,255,0.12); font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    @media (max-width: 1080px) { .three-pillars .row { grid-template-columns: 1fr; } .three-pillars .pillar { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.12); } }
  </style>



  <section class="page-hero">
    <div class="container">
      
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <a href="/for-cams/why-innovia/">For CAMs</a>
        <span>/</span>
        <span style="color:#fff;">The Three Pillars</span>
      </div>
      <h1>Three pillars. <em>One stake</em><span class="light">in the outcome.</span></h1>
      <p class="lede">Innovia&rsquo;s legacy framing was networking, lead-gen, and the vendor program. The refresh sharpens what members have always come for &mdash; and what they stay for.</p>
    </div>
  </section>

  <section class="three-pillars">
    <div class="container">
      <div class="row">
        <a class="pillar" href="/for-cams/three-pillars/elite-community/">
          <span class="num">01</span>
          <h3>Elite Community</h3>
          <p class="desc">An invitation-only circle of the country&rsquo;s best independent operators &mdash; structured into peer groups, retreats, and the annual Summit.</p>
          <ul><li>Peer focus groups &middot; closed-door, founder-only</li><li>The Annual Summit</li><li>Curated, not open enrollment</li></ul>
          <span class="go">Read more <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
        </a>
        <a class="pillar" href="/for-cams/three-pillars/business-growth/">
          <span class="num">02</span>
          <h3>Business Growth</h3>
          <p class="desc">A national platform that attracts board inquiries searching for management &mdash; and routes them to the nearest member firm. Plus benchmarking and pricing intelligence members couldn&rsquo;t build alone.</p>
          <ul><li>Find a Management Company lead routing</li><li>Member-only benchmarking</li><li>1-match board lead routing</li></ul>
          <span class="go">Read more <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
        </a>
        <a class="pillar" href="/for-cams/three-pillars/vendor-program/">
          <span class="num">03</span>
          <h3>Vendor Program</h3>
          <p class="desc">Pre-negotiated agreements with vetted partners across the line items every CAM company runs. Industry-specific. Member-only. Reviewed annually.</p>
          <ul><li>Six vendor pillars</li><li>Member-rated, annually re-earned</li><li>No vendor money for placement</li></ul>
          <span class="go">Read more <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="The Three Pillars · Innovia Co-op"
  description="The Three Pillars · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  activeNav="cams"
  ctaLabel="Schedule a Conversation"
  ctaHref="/schedule-a-conversation/"
>
  <Fragment set:html={html} />
</BaseLayout>
