---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Page hero ---------- */
    .page-hero {
      padding: 96px 0 64px;
      position: relative; overflow: hidden;
    }
    .page-hero::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 92% 8%, rgba(149,208,49,0.16) 0%, transparent 38%),
        radial-gradient(circle at 4% 96%, rgba(42,74,120,0.6) 0%, transparent 50%);
      pointer-events: none;
    }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
      margin-bottom: 56px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero .crumb .right {
      margin-left: auto;
      display: flex; align-items: center; gap: 12px;
    }
    .page-hero .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }
    .page-hero h1 {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(72px, 10vw, 160px);
      line-height: 0.9;
      letter-spacing: -0.045em;
      color: #fff;
      margin: 0;
      text-wrap: balance;
    }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light {
      font-family: var(--font-body);
      font-weight: 300; font-style: italic;
      color: rgba(255,255,255,0.5);
      letter-spacing: -0.025em;
    }
    .page-hero .below {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 80px;
      align-items: end;
      margin-top: 56px;
      padding-top: 32px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .below p {
      font-size: clamp(17px, 1.4vw, 20px);
      line-height: 1.55;
      color: rgba(255,255,255,0.78);
      max-width: 52ch;
      margin: 0;
    }
    .page-hero .below .actions {
      display: flex; gap: 12px; flex-wrap: wrap;
      justify-content: flex-end;
    }
    .page-hero .below .btn { padding: 16px 26px; font-size: 15px; }

    /* ---------- Stat band ---------- */
    .stat-band {
      background: var(--innovia-navy-deep);
      border-top: 1px solid rgba(255,255,255,0.06);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .stat-band .row { display: grid; grid-template-columns: repeat(4, 1fr); }
    .stat-band .cell {
      padding: 36px 32px;
      border-right: 1px solid rgba(255,255,255,0.08);
      display: flex; flex-direction: column; gap: 10px;
    }
    .stat-band .cell:last-child { border-right: 0; }
    .stat-band .num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 60px; line-height: 1; color: #fff;
      letter-spacing: -0.035em;
    }
    .stat-band .num .pct { color: var(--innovia-green); font-size: 0.55em; vertical-align: top; }
    .stat-band .label {
      font-family: var(--font-display); font-size: 11px;
      font-weight: 600; letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .stat-band .placeholder::after { top: -22px; right: -4px; }

    /* ---------- Industry pressures (cream block) ---------- */
    .industry-state {
      background: #FBFAF6;
      color: var(--fg-2);
      padding: 120px 0;
    }
    .industry-state .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 64px;
    }
    .industry-state h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 4.8vw, 64px);
      letter-spacing: -0.028em;
      max-width: 14ch;
    }
    .industry-state .head p {
      font-size: 17px; line-height: 1.6; color: var(--fg-2);
      max-width: 52ch;
    }
    .industry-state .pressures {
      display: grid; grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--innovia-navy);
      border-bottom: 2px solid var(--innovia-navy);
    }
    .industry-state .pressure {
      padding: 36px 28px 36px;
      border-right: 1px solid var(--border-subtle);
      display: flex; flex-direction: column; gap: 18px;
      position: relative;
    }
    .industry-state .pressure::before {
      content: "";
      position: absolute; top: -7px; left: 0;
      width: 12px; height: 12px;
      background: var(--innovia-green);
      transform: translateY(-50%);
    }
    .industry-state .pressure:last-child { border-right: 0; }
    .industry-state .pressure .num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 48px; color: var(--innovia-green-deep);
      letter-spacing: -0.03em; line-height: 1;
    }
    .industry-state .pressure h4 {
      font-size: 22px; color: var(--innovia-navy);
      margin: 0; letter-spacing: -0.014em;
    }
    .industry-state .pressure p {
      margin: 0; font-size: 14px; line-height: 1.55;
      color: var(--fg-2);
    }
    .industry-state .pressure .meta {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3); letter-spacing: 0.04em;
      margin-top: auto;
      padding-top: 12px;
      border-top: 1px solid var(--border-subtle);
    }

    /* ---------- Manifesto strap ---------- */
    .manifesto-strap {
      padding: 120px 0;
      background: var(--innovia-navy);
      position: relative; overflow: hidden;
    }
    .manifesto-strap::before {
      content: ""; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
    }
    .manifesto-strap .container { position: relative; z-index: 1; text-align: center; }
    .manifesto-strap .creed-meta {
      display: flex; justify-content: center; gap: 16px;
      margin-bottom: 36px;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .manifesto-strap .creed-meta .bar { width: 36px; height: 1px; background: rgba(255,255,255,0.3); align-self: center; }
    .manifesto-strap h2 {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(48px, 7vw, 112px);
      line-height: 0.94;
      letter-spacing: -0.038em;
      color: #fff;
      margin: 0;
      max-width: 18ch;
      margin-left: auto; margin-right: auto;
    }
    .manifesto-strap h2 em { color: var(--innovia-green); font-style: normal; }

    /* ---------- Pillars deep stack ---------- */
    .pillars-deep {
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .pillars-deep .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 64px;
    }
    .pillars-deep h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 4.8vw, 60px);
      letter-spacing: -0.028em;
      max-width: 16ch;
    }
    .pillars-deep .head p { font-size: 17px; line-height: 1.6; max-width: 52ch; }
    .pillars-deep .pillar {
      display: grid;
      grid-template-columns: 200px 1fr 1fr;
      gap: 64px;
      padding: 72px 0;
      border-top: 1px solid var(--innovia-navy);
      align-items: start;
    }
    .pillars-deep .pillar:last-child { border-bottom: 1px solid var(--innovia-navy); }
    .pillars-deep .pillar .marker {
      display: flex; flex-direction: column; gap: 10px;
    }
    .pillars-deep .pillar .marker .num {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 112px;
      line-height: 0.84;
      color: var(--innovia-green-deep);
      letter-spacing: -0.045em;
    }
    .pillars-deep .pillar .marker .legacy {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3); letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .pillars-deep .pillar .marker .legacy s { color: var(--fg-3); opacity: 0.7; }
    .pillars-deep .pillar .body h3 {
      color: var(--innovia-navy);
      font-size: clamp(34px, 3.4vw, 48px);
      letter-spacing: -0.028em;
      margin: 0 0 16px;
      line-height: 0.98;
    }
    .pillars-deep .pillar .body p {
      color: var(--fg-2); font-size: 16px;
      line-height: 1.6; margin: 0;
    }
    .pillars-deep .pillar .unlocks {
      display: grid; gap: 0;
    }
    .pillars-deep .pillar .unlocks .unlock {
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: 18px;
      padding: 16px 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .pillars-deep .pillar .unlocks .unlock:last-child { border-bottom: 0; }
    .pillars-deep .pillar .unlocks .unlock .tag {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep); letter-spacing: 0.06em;
      padding-top: 4px;
    }
    .pillars-deep .pillar .unlocks .unlock .v {
      color: var(--innovia-navy); font-family: var(--font-display);
      font-weight: 600;
      font-size: 16px; line-height: 1.4;
      letter-spacing: -0.005em;
    }

    .pillars-deep .pillar .body .deep-link {
      display: inline-flex; align-items: center; gap: 8px;
      margin-top: 22px;
      font-family: var(--font-mono); font-size: 12px;
      color: var(--innovia-green-deep);
      letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none;
      border-bottom: 1px solid var(--innovia-green);
      padding-bottom: 4px;
      transition: gap .15s, color .15s;
    }
    .pillars-deep .pillar .body .deep-link:hover { gap: 14px; color: var(--innovia-navy); }
    .pillars-deep .pillar .body .deep-link svg { width: 12px; height: 12px; flex: 0 0 auto; }
    .pillars-deep .pillar .unlocks .unlock .v small {
      display: block;
      margin-top: 4px;
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 13px; color: var(--fg-3);
    }

    /* ---------- Shape (green block) ---------- */
    .shape {
      padding: 120px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .shape .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 56px;
    }
    .shape h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 4.8vw, 64px);
      letter-spacing: -0.028em;
      max-width: 14ch;
    }
    .shape .head p { font-size: 17px; line-height: 1.6; max-width: 50ch; }
    .shape .timeline {
      display: grid; grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--innovia-navy);
      position: relative;
    }
    .shape .step {
      padding: 36px 28px 32px;
      border-right: 1px solid rgba(24,51,94,0.15);
      position: relative;
    }
    .shape .step:last-child { border-right: 0; }
    .shape .step::before {
      content: "";
      position: absolute; top: -7px; left: 0;
      width: 12px; height: 12px;
      background: var(--innovia-navy);
      border-radius: 50%;
      transform: translateY(-50%);
    }
    .shape .step .when {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-navy); opacity: 0.65;
      letter-spacing: 0.04em;
      margin-bottom: 8px;
    }
    .shape .step h4 {
      color: var(--innovia-navy);
      font-size: 22px; letter-spacing: -0.014em;
      margin: 0 0 12px;
    }
    .shape .step p {
      font-size: 14px; line-height: 1.55;
      color: var(--innovia-navy); opacity: 0.85;
      margin: 0;
    }

    /* ---------- Voices grid (navy with white cards) ---------- */
    .voices-grid {
      padding: 120px 0;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
    }
    .voices-grid .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 56px;
    }
    .voices-grid h2 { color: #fff; }
    .voices-grid .head p { color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.55; }
    .voices-grid .grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .voices-grid .quote-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.12);
      padding: 32px;
      display: flex; flex-direction: column; gap: 20px;
      transition: border-color .2s, transform .2s;
    }
    .voices-grid .quote-card:hover {
      border-color: var(--innovia-green);
      transform: translateY(-2px);
    }
    .voices-grid .quote-card .q {
      font-family: var(--font-display); font-weight: 500;
      font-size: 19px; line-height: 1.4;
      color: #fff; letter-spacing: -0.012em;
      margin: 0;
    }
    .voices-grid .quote-card .q::before {
      content: "“"; display: inline;
      font-weight: 900; color: var(--innovia-green);
      margin-right: 2px;
    }
    .voices-grid .quote-card .attr {
      display: flex; gap: 14px; align-items: center;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.12);
      margin-top: auto;
    }
    .voices-grid .quote-card .photo {
      width: 44px; height: 44px; border-radius: 999px;
      background: var(--innovia-navy-deep);
      flex-shrink: 0; overflow: hidden;
    }
    .voices-grid .quote-card .photo img { width: 100%; height: 100%; object-fit: cover; }
    .voices-grid .quote-card .name {
      font-family: var(--font-display); font-weight: 700;
      font-size: 14px; color: #fff;
    }
    .voices-grid .quote-card .role { font-size: 12px; color: rgba(255,255,255,0.6); }

    /* ---------- FAQ ---------- */
    .faq {
      padding: 120px 0;
      background: var(--innovia-navy-deep);
      color: rgba(255,255,255,0.78);
    }
    .faq .head {
      max-width: 780px;
      margin: 0 0 56px;
    }
    .faq h2 { color: #fff; }
    .faq .list { border-top: 2px solid var(--innovia-green); }
    .faq details {
      border-bottom: 1px solid rgba(255,255,255,0.18);
      padding: 24px 0;
    }
    .faq summary {
      display: grid; grid-template-columns: 48px 1fr 24px;
      gap: 16px; align-items: center;
      cursor: pointer;
      list-style: none;
      padding: 8px 0;
    }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary .num {
      font-family: var(--font-mono); font-size: 12px;
      color: var(--innovia-green);
      letter-spacing: 0.04em;
    }
    .faq summary .q {
      font-family: var(--font-display); font-weight: 600;
      font-size: 22px; color: #fff;
      letter-spacing: -0.014em;
      line-height: 1.25;
    }
    .faq summary .chev {
      transition: transform .25s var(--ease-out);
      color: var(--innovia-green);
    }
    .faq details[open] summary .chev { transform: rotate(180deg); }
    .faq .a {
      padding: 16px 0 8px 64px;
      max-width: 70ch;
      font-size: 16px; line-height: 1.62;
      color: rgba(255,255,255,0.78);
    }
    .faq .a .placeholder { color: rgba(255,255,255,0.78); }

    /* ---------- Connect / CAM lead form ---------- */
    .connect {
      padding: 120px 0 140px;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
      position: relative; overflow: hidden;
    }
    .connect::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 6% 12%, rgba(149,208,49,0.10) 0%, transparent 40%),
        radial-gradient(circle at 96% 92%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .connect .container { position: relative; z-index: 1; }
    .connect .layout {
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 80px;
      align-items: start;
    }
    .connect .pitch h2 {
      color: #fff;
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(40px, 5vw, 72px);
      letter-spacing: -0.03em;
      line-height: 1.0;
      margin: 14px 0 0;
      max-width: 14ch;
      text-wrap: balance;
    }
    .connect .pitch h2 em { color: var(--innovia-green); font-style: italic; font-weight: 400; }
    .connect .pitch > p {
      font-size: 17px; line-height: 1.62;
      color: rgba(255,255,255,0.78);
      max-width: 44ch;
      margin: 24px 0 0;
    }
    .connect .pitch .how {
      margin-top: 36px;
      display: flex; flex-direction: column;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .connect .pitch .step {
      padding: 22px 0;
      border-bottom: 1px solid rgba(255,255,255,0.18);
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 18px;
      align-items: start;
    }
    .connect .pitch .step .ix {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green); letter-spacing: 0.06em;
      padding-top: 4px;
    }
    .connect .pitch .step h5 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 16px; color: #fff;
      letter-spacing: -0.005em;
      line-height: 1.3;
      margin: 0 0 4px;
    }
    .connect .pitch .step p {
      font-size: 13px; line-height: 1.55;
      color: rgba(255,255,255,0.65);
      margin: 0; max-width: 42ch;
    }
    .connect .pitch .summit-aside {
      margin-top: 28px;
      padding: 20px 22px;
      background: rgba(149,208,49,0.10);
      border: 1px solid rgba(149,208,49,0.32);
      display: grid; grid-template-columns: 1fr auto;
      gap: 18px; align-items: center;
    }
    .connect .pitch .summit-aside p {
      margin: 0;
      font-size: 13px; line-height: 1.5;
      color: rgba(255,255,255,0.85);
    }
    .connect .pitch .summit-aside p strong {
      display: block;
      font-family: var(--font-display); font-weight: 700;
      font-size: 14px;
      color: var(--innovia-green);
      margin-bottom: 3px;
      letter-spacing: 0.04em; text-transform: uppercase;
    }
    .connect .pitch .summit-aside a {
      color: var(--innovia-green);
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.08em; text-transform: uppercase;
      white-space: nowrap;
      display: inline-flex; align-items: center; gap: 6px;
    }

    /* The form */
    .connect-form {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.14);
      padding: 36px 36px 28px;
    }
    .connect-form .form-head {
      display: flex; justify-content: space-between; align-items: center;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.14);
      margin-bottom: 24px;
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
    }
    .connect-form .form-label { color: var(--innovia-green); }
    .connect-form .form-count { color: rgba(255,255,255,0.5); }
    .connect-form fieldset {
      border: 0; padding: 0; margin: 0 0 24px;
      display: flex; flex-direction: column; gap: 14px;
    }
    .connect-form legend {
      font-family: var(--font-display); font-weight: 700;
      font-size: 13px; color: rgba(255,255,255,0.55);
      letter-spacing: 0.04em; text-transform: uppercase;
      padding: 0 0 8px;
      border-bottom: 1px solid rgba(255,255,255,0.10);
      width: 100%; margin-bottom: 4px;
    }
    .connect-form label {
      display: flex; flex-direction: column; gap: 6px;
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.65);
      letter-spacing: 0.08em; text-transform: uppercase;
    }
    .connect-form label .opt {
      font-family: var(--font-body); font-size: 10px;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.04em; text-transform: none;
      font-style: italic; margin-left: 8px;
    }
    .connect-form .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .connect-form input,
    .connect-form select,
    .connect-form textarea {
      background: rgba(0,0,0,0.22);
      border: 1px solid rgba(255,255,255,0.18);
      padding: 13px 14px;
      color: #fff;
      font-family: var(--font-body); font-size: 15px;
      letter-spacing: 0; text-transform: none;
