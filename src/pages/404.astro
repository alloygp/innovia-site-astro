---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); margin: 0; }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .four-oh-four {
      min-height: calc(100vh - 76px);
      padding: 80px 0 120px;
      display: flex; align-items: center;
      position: relative; overflow: hidden;
      isolation: isolate;
    }
    .four-oh-four::before {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 92% 8%, rgba(149,208,49,0.16) 0%, transparent 40%),
        radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none; z-index: -1;
    }
    .four-oh-four .layout {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .four-oh-four .stamp {
      display: flex; align-items: center; gap: 14px;
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green); letter-spacing: 0.14em;
      text-transform: uppercase;
      padding-bottom: 16px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
      margin-bottom: 36px;
    }
    .four-oh-four .stamp .dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }
    .four-oh-four .big {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(140px, 22vw, 320px);
      line-height: 0.88;
      letter-spacing: -0.05em;
      color: #fff;
      margin: 0;
    }
    .four-oh-four .big em {
      color: var(--innovia-green);
      font-style: normal;
    }
    .four-oh-four h1 {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(36px, 4vw, 56px);
      color: #fff;
      letter-spacing: -0.024em;
      line-height: 1.04;
      margin: 0 0 24px;
      max-width: 18ch;
      text-wrap: balance;
    }
    .four-oh-four h1 em {
      color: var(--innovia-green);
      font-style: italic;
      font-weight: 400;
    }
    .four-oh-four .lede {
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.62;
      color: rgba(255,255,255,0.74);
      margin: 0 0 36px;
      max-width: 44ch;
    }

    .four-oh-four .paths {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.18);
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .four-oh-four .paths a {
      padding: 20px 22px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      text-decoration: none;
      color: inherit;
      border-right: 1px solid rgba(255,255,255,0.12);
      transition: background .15s;
    }
    .four-oh-four .paths a:nth-child(2n) { border-right: 0; }
    .four-oh-four .paths a:nth-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.12); }
    .four-oh-four .paths a:hover { background: rgba(149,208,49,0.06); }
    .four-oh-four .paths .label {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.14em; text-transform: uppercase;
    }
    .four-oh-four .paths .what {
      font-family: var(--font-display); font-weight: 700;
      font-size: 17px;
      color: #fff;
      letter-spacing: -0.005em;
      display: inline-flex; align-items: center; gap: 10px;
    }
    .four-oh-four .paths .what svg {
      width: 13px; height: 13px;
      color: var(--innovia-green);
      transition: transform .15s;
    }
    .four-oh-four .paths a:hover .what svg { transform: translateX(3px); }

    .four-oh-four .foot {
      margin-top: 28px;
      font-family: var(--font-mono);
      font-size: 12px;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.04em;
    }
    .four-oh-four .foot a {
      color: var(--innovia-green);
      text-decoration: none;
    }

    @media (max-width: 880px) {
      .four-oh-four .layout { grid-template-columns: 1fr; gap: 40px; }
      .four-oh-four .big { font-size: clamp(120px, 28vw, 200px); }
      .four-oh-four .paths { grid-template-columns: 1fr; }
      .four-oh-four .paths a { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.12); }
      .four-oh-four .paths a:last-child { border-bottom: 0; }
    }
  </style>


  <section class="four-oh-four">
    <div class="container">
      <div class="layout">

        <div>
          <div class="stamp">
            <span class="dot"></span>
            HTTP 404 &middot; Page not found
          </div>
          <p class="big"><em>404.</em></p>
          <p class="big" style="font-size: clamp(28px, 2.4vw, 36px); margin-top: 12px; max-width: 24ch; color: rgba(255,255,255,0.6); line-height: 1.2; letter-spacing: -0.005em;">
            <span style="font-family: var(--font-body); font-style: italic; font-weight: 400;">Not the room you were looking for.</span>
          </p>
        </div>

        <div>
          <h1>This page isn&rsquo;t in the cooperative&rsquo;s nav.</h1>
          <p class="lede">It may have moved during the site refresh, or the link you followed is older than the rebuild. Here&rsquo;s the path back &mdash; pick whichever fits.</p>

          <nav class="paths" aria-label="Site navigation">
            <a href="/">
              <span class="label">Home</span>
              <span class="what">The cooperative <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
            </a>
            <a href="/for-cams/why-innovia/">
              <span class="label">For CAMs</span>
              <span class="what">Why members join <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
            </a>
            <a href="/find-a-management-company/">
              <span class="label">For Boards</span>
              <span class="what">Find management <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
            </a>
            <a href="/summit/">
              <span class="label">Annual Summit</span>
              <span class="what">Summit 2027 <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
            </a>
          </nav>

          <p class="foot">Or <a href="mailto:hello@innovia.co-op">drop us a note</a> if you came in through a broken link &mdash; we&rsquo;ll fix it.</p>
        </div>

      </div>
    </div>
  </section>


`;
---
<BaseLayout
  title="Not the room you were looking for · Innovia Co-op"
  description="Not the room you were looking for · Innovia Co-op"
  headerVariant="inverse"
  ctaLabel="Back to home"
  ctaHref="/"
  robots="noindex"
>
  <Fragment set:html={html} />
</BaseLayout>
