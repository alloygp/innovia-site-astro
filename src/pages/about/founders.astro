---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Hero ---------- */
    .page-hero {
      padding: 64px 0 0;
      position: relative; overflow: hidden;
    }
    .page-hero::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 92% 6%, rgba(149,208,49,0.16) 0%, transparent 40%),
        radial-gradient(circle at 4% 92%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .page-hero .container { position: relative; z-index: 1; }

    .page-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
      margin-bottom: 56px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero .crumb .right {
      margin-left: auto;
      display: flex; align-items: center; gap: 12px;
    }
    .page-hero .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }

    .page-hero .title-row {
      display: grid; grid-template-columns: 1.5fr 1fr;
      gap: 80px;
      align-items: end;
    }
    .page-hero h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(54px, 7.6vw, 124px);
      line-height: 0.92;
      letter-spacing: -0.04em;
      color: #fff; margin: 0;
      text-wrap: balance;
    }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .amp {
      color: var(--innovia-green);
      font-family: var(--font-display);
      font-style: italic;
      font-weight: 300;
      padding: 0 0.06em;
    }
    .page-hero .meta-stack {
      display: flex; flex-direction: column; gap: 22px;
      padding-bottom: 6px;
    }
    .page-hero .meta-stack .ind {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.1em; text-transform: uppercase;
    }
    .page-hero .meta-stack .ind .green { color: var(--innovia-green); }
    .page-hero .meta-stack p {
      font-size: 16px; line-height: 1.6;
      color: rgba(255,255,255,0.78);
      margin: 0;
      max-width: 38ch;
    }

    /* Portrait band */
    .portrait-band {
      margin-top: 80px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: rgba(255,255,255,0.10);
      border-top: 1px solid rgba(255,255,255,0.18);
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .portrait-band .portrait {
      background: var(--innovia-navy-deep);
      padding: 36px 36px 28px;
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 28px;
      align-items: stretch;
    }
    .portrait .frame {
      background: var(--innovia-navy);
      aspect-ratio: 3 / 4;
      border: 1px solid rgba(255,255,255,0.15);
      position: relative;
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .portrait .frame .mark {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 32px;
      color: var(--innovia-green);
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .portrait .frame .mark .lo {
      font-family: var(--font-mono);
      font-weight: 400;
      font-size: 9px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      display: block;
      margin-top: 8px;
    }
    .portrait .frame::after {
      content: "";
      position: absolute;
      inset: 8px;
      border: 1px dashed rgba(255,255,255,0.18);
      pointer-events: none;
    }
    .portrait .body {
      display: flex; flex-direction: column;
      gap: 10px;
      min-width: 0;
    }
    .portrait .body .role {
      font-family: var(--font-mono); font-size: 10px;
      color: var(--innovia-green); letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .portrait .body h3 {
      font-family: var(--font-display); font-weight: 800;
      font-size: clamp(26px, 2.6vw, 34px);
      color: #fff; margin: 0;
      letter-spacing: -0.018em; line-height: 1.05;
    }
    .portrait .body .lifespan {
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.02em;
    }
    .portrait .body .bio {
      font-size: 14px; line-height: 1.6;
      color: rgba(255,255,255,0.72);
      margin: 0;
    }
    .portrait .body .creds {
      margin-top: auto;
      padding-top: 14px;
      border-top: 1px solid rgba(255,255,255,0.12);
      display: flex; flex-wrap: wrap; gap: 6px;
    }
    .portrait .body .cred {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.06em;
      padding: 4px 8px;
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(0,0,0,0.16);
    }

    /* ---------- Long-form narrative (cream) ---------- */
    .narrative {
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .narrative .layout {
      display: grid; grid-template-columns: 0.85fr 1.15fr;
      gap: 96px;
      align-items: start;
    }
    .narrative .left {
      position: sticky; top: 120px;
    }
    .narrative h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.4vw, 60px);
      letter-spacing: -0.028em;
      margin: 14px 0 0;
      max-width: 14ch;
    }
    .narrative h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .narrative .left .toc {
      margin-top: 36px;
      display: flex; flex-direction: column;
      border-top: 1px solid var(--border-subtle);
    }
    .narrative .left .toc a {
      display: flex;
      gap: 16px;
      padding: 14px 0;
      border-bottom: 1px solid var(--border-subtle);
      font-family: var(--font-display);
      font-size: 14px;
      color: var(--fg-2);
      font-weight: 500;
      transition: color .15s;
    }
    .narrative .left .toc a:hover { color: var(--innovia-navy); }
    .narrative .left .toc .num {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3); letter-spacing: 0.06em;
      flex-shrink: 0;
      min-width: 28px;
    }
    .narrative .body p {
      font-size: 18px;
      line-height: 1.7;
      color: var(--fg-2);
      margin: 0 0 22px;
    }
    .narrative .body p:first-of-type::first-letter {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 96px;
      float: left;
      line-height: 0.78;
      margin: 8px 14px 0 0;
      color: var(--innovia-navy);
    }
    .narrative .body h3 {
      font-family: var(--font-display); font-weight: 800;
      font-size: clamp(24px, 2.4vw, 32px);
      color: var(--innovia-navy);
      letter-spacing: -0.018em;
      margin: 56px 0 18px;
      max-width: 22ch;
    }
    .narrative .body .pull {
      font-family: var(--font-display); font-weight: 500;
      font-size: clamp(22px, 2.2vw, 28px);
      line-height: 1.35;
      letter-spacing: -0.014em;
      color: var(--innovia-navy);
      padding: 28px 0;
      margin: 36px 0;
      border-top: 4px solid var(--innovia-green);
      border-bottom: 1px solid var(--border-subtle);
      max-width: 40ch;
    }
    .narrative .body .pull cite {
      display: block;
      margin-top: 14px;
      font-family: var(--font-mono); font-size: 12px;
      color: var(--fg-3);
      font-style: normal;
      letter-spacing: 0.04em;
      font-weight: 400;
    }

    /* ---------- Hall of Fame (navy timeline) ---------- */
    .hof {
      padding: 120px 0;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
      position: relative; overflow: hidden;
    }
    .hof::before {
      content: ""; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 96px 96px;
      mask-image: radial-gradient(ellipse at 70% 30%, #000 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at 70% 30%, #000 30%, transparent 80%);
    }
    .hof .container { position: relative; z-index: 1; }
    .hof .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 64px;
    }
    .hof h2 {
      color: #fff;
      font-size: clamp(38px, 4.6vw, 60px);
      letter-spacing: -0.028em;
      max-width: 18ch;
    }
    .hof h2 em { color: var(--innovia-green); font-style: normal; }
    .hof .head p { color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.6; max-width: 52ch; }
    .hof .head p strong { color: #fff; font-weight: 600; }

    .hof .roll {
      border-top: 2px solid var(--innovia-green);
    }
    .hof .inductee {
      display: grid;
      grid-template-columns: 120px 1fr 1.4fr 220px;
      gap: 48px;
      padding: 36px 0;
      border-bottom: 1px solid rgba(255,255,255,0.14);
      align-items: start;
    }
    .hof .inductee .year {
      font-family: var(--font-display); font-weight: 900;
      font-size: 44px;
      color: var(--innovia-green);
      letter-spacing: -0.025em;
      line-height: 0.9;
    }
    .hof .inductee .name {
      display: flex; flex-direction: column; gap: 6px;
    }
    .hof .inductee .name h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 22px;
      color: #fff;
      letter-spacing: -0.014em;
      margin: 0;
      line-height: 1.15;
    }
    .hof .inductee .name .firm {
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.04em;
    }
    .hof .inductee .citation {
      font-size: 14.5px; line-height: 1.6;
      color: rgba(255,255,255,0.78);
      margin: 0;
    }
    .hof .inductee .citation em {
      color: #fff;
      font-style: normal;
      font-weight: 500;
    }
    .hof .inductee .tags {
      display: flex; flex-direction: column;
      gap: 6px;
      align-items: flex-start;
    }
    .hof .inductee .tags .t {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.06em;
      padding: 4px 8px;
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(0,0,0,0.16);
    }
    .hof .inductee.founder {
      background: linear-gradient(90deg, rgba(149,208,49,0.07) 0%, transparent 70%);
    }
    .hof .inductee.founder .year { color: var(--innovia-green); }
    .hof .inductee.founder .name h4::after {
      content: "Founder";
      display: inline-block;
      margin-left: 12px;
      vertical-align: middle;
      font-family: var(--font-mono); font-size: 10px;
      color: var(--innovia-navy);
      background: var(--innovia-green);
      letter-spacing: 0.08em;
      padding: 3px 6px;
      text-transform: uppercase;
      font-weight: 700;
      position: relative;
      top: -3px;
    }

    .hof .footer-note {
      margin-top: 36px;
      padding: 22px 28px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
      display: grid;
      grid-template-columns: 200px 1fr auto;
      gap: 28px;
      align-items: center;
    }
    .hof .footer-note .k {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green); letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .hof .footer-note p {
      font-size: 14.5px;
      color: rgba(255,255,255,0.74);
      line-height: 1.5;
      margin: 0;
      max-width: 62ch;
    }
    .hof .footer-note a {
      font-family: var(--font-display); font-weight: 600;
      font-size: 13px;
      color: var(--innovia-green);
      border-bottom: 1px solid var(--innovia-green);
      padding-bottom: 4px;
      letter-spacing: 0.005em;
      white-space: nowrap;
    }
    .hof .footer-note a:hover { color: #fff; border-color: #fff; }

    /* ---------- Founding principles (cream grid) ---------- */
    .principles {
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .principles .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .principles h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.6vw, 60px);
      letter-spacing: -0.028em;
      max-width: 16ch;
      margin: 0;
    }
    .principles h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .principles .head p {
      font-size: 17px; line-height: 1.6;
      color: var(--fg-2);
      max-width: 52ch;
      margin: 0;
    }
    .principles .grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--innovia-green);
      border-bottom: 1px solid var(--border-subtle);
      background: #fff;
    }
    .principles .card {
      padding: 32px 28px 30px;
      border-right: 1px solid var(--border-subtle);
      display: flex; flex-direction: column;
      gap: 14px;
      border-radius: 0;
    }
    .principles .card:hover { border-color: var(--border-subtle); box-shadow: none; transform: none; }
    .principles .card:last-child { border-right: 0; }
    .principles .card .num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 56px;
      color: var(--innovia-navy);
      letter-spacing: -0.035em;
      line-height: 0.85;
    }
    .principles .card h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 21px;
      color: var(--innovia-navy);
      letter-spacing: -0.014em;
      margin: 0;
      line-height: 1.2;
      text-wrap: balance;
    }
    .principles .card p {
      font-size: 14px; line-height: 1.6;
      color: var(--fg-2);
      margin: 0;
    }
    .principles .card .meta {
      margin-top: auto;
      padding-top: 14px;
      border-top: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3);
      letter-spacing: 0.04em;
    }

    /* ---------- Creed strap ---------- */
    .creed {
      padding: 140px 0;
      background: var(--innovia-navy);
      position: relative; overflow: hidden;
    }
    .creed::before {
      content: ""; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
    }
    .creed .container { position: relative; z-index: 1; text-align: center; }
    .creed .meta {
      display: inline-flex; justify-content: center; gap: 16px;
      margin-bottom: 36px;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .creed .meta .bar { width: 36px; height: 1px; background: rgba(255,255,255,0.3); align-self: center; }
    .creed blockquote {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(38px, 5.4vw, 88px);
      line-height: 1.02;
      letter-spacing: -0.034em;
      color: #fff;
      margin: 0 auto;
      max-width: 22ch;
      text-wrap: balance;
    }
    .creed blockquote em { color: var(--innovia-green); font-style: normal; }
    .creed cite {
      display: block;
      margin-top: 36px;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-style: normal;
    }
    .creed cite .who {
      color: var(--innovia-green);
    }

    /* ---------- Continuing the legacy ---------- */
    .legacy {
      padding: 120px 0;
      background: #FBFAF6;
    }
    .legacy .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .legacy h2 {
      color: var(--innovia-navy);
      font-size: clamp(34px, 3.8vw, 52px);
      letter-spacing: -0.026em;
      margin: 0;
      max-width: 20ch;
    }
    .legacy h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .legacy .head p {
      font-size: 16px; line-height: 1.6;
      color: var(--fg-2);
      max-width: 50ch;
      margin: 0;
    }
    .legacy .next {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    .legacy .next-card {
      background: #fff;
      border: 1px solid var(--border-subtle);
      padding: 28px 28px 24px;
      display: flex; flex-direction: column;
      gap: 14px;
      transition: border-color .2s, transform .2s, box-shadow .2s;
      text-decoration: none;
      color: inherit;
    }
    .legacy .next-card:hover {
      border-color: var(--innovia-green);
      transform: translateY(-3px);
      box-shadow: var(--shadow-2);
    }
    .legacy .next-card .kind {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .legacy .next-card h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 22px;
      color: var(--innovia-navy);
      letter-spacing: -0.014em;
      line-height: 1.18;
      margin: 0;
    }
    .legacy .next-card p {
      font-size: 14px; line-height: 1.55;
      color: var(--fg-2);
      margin: 0;
    }
    .legacy .next-card .go {
      margin-top: auto;
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-display); font-weight: 600;
      font-size: 13px;
      color: var(--innovia-navy);
      padding-top: 14px;
      border-top: 1px solid var(--border-subtle);
    }
    .legacy .next-card .go .arrow { transition: transform .2s var(--ease-out); }
    .legacy .next-card:hover .go .arrow { transform: translateX(3px); }

    /* ---------- CTA finale ---------- */
    .cta-finale {
      padding: 140px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .cta-finale .frame {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 80px; align-items: center;
    }
    .cta-finale h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 5.4vw, 80px);
      letter-spacing: -0.03em;
      line-height: 0.98;
      max-width: 18ch;
      margin: 14px 0 0;
    }
    .cta-finale h2 em { color: #fff; font-style: normal; }
    .cta-finale .lead {
      max-width: 50ch; margin-top: 18px;
      font-size: 17px; line-height: 1.55;
      color: var(--innovia-navy);
      opacity: 0.82;
    }
    .cta-finale .actions {
      display: flex; flex-direction: column; gap: 10px;
    }
    .cta-finale .actions .btn { padding: 18px 28px; font-size: 16px; justify-content: center; }
    .cta-finale .actions .btn-navy { background: var(--innovia-navy); color: #fff; }
    .cta-finale .actions .btn-navy:hover { background: var(--innovia-navy-deep); }
    .cta-finale .actions .btn-outline { color: var(--innovia-navy); border-color: var(--innovia-navy); }
    .cta-finale .actions .btn-outline:hover { background: var(--innovia-navy); color: #fff; }

    @media (max-width: 1080px) {
      .page-hero .title-row,
      .narrative .layout,
      .hof .head,
      .principles .head,
      .legacy .head,
      .cta-finale .frame { grid-template-columns: 1fr; gap: 32px; }
      .narrative .left { position: static; }
      .portrait-band { grid-template-columns: 1fr; }
      .principles .grid { grid-template-columns: repeat(2, 1fr); }
      .principles .card:nth-child(2) { border-right: 0; }
      .principles .card:nth-child(-n+2) { border-bottom: 1px solid var(--border-subtle); }
