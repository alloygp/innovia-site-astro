---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 56px; position: relative; overflow: hidden; }
    .page-hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 92% 8%, rgba(149,208,49,0.14) 0%, transparent 38%), radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%); pointer-events: none; }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 36px; }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light { display: block; margin-top: 8px; font-family: var(--font-body); font-weight: 300; font-style: italic; color: rgba(255,255,255,0.55); font-size: 0.48em; letter-spacing: -0.02em; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }
    
  
    .lead-section { padding: 32px 0 96px; }
    .lead-section .grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 64px; align-items: start; }
    .lead-section .pitch h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(32px, 3.6vw, 48px); letter-spacing: -0.022em; color: #fff; line-height: 1.04; margin: 0 0 22px; max-width: 16ch; }
    .lead-section .pitch p { font-size: 16px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 44ch; margin: 0 0 18px; }
    .lead-section .how { margin-top: 28px; border-top: 1px solid rgba(255,255,255,0.18); }
    .lead-section .step { padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,0.18); display: grid; grid-template-columns: 48px 1fr; gap: 18px; align-items: start; }
    .lead-section .step .ix { font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); padding-top: 4px; letter-spacing: 0.06em; }
    .lead-section .step h5 { font-family: var(--font-display); font-weight: 700; font-size: 15px; color: #fff; margin: 0 0 4px; }
    .lead-section .step p { font-size: 13px; line-height: 1.5; color: rgba(255,255,255,0.62); margin: 0; }

    /* form (lifted from connect-form pattern) */
    .lead-section form { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); padding: 36px; }
    .lead-section form .head { display: flex; justify-content: space-between; padding-bottom: 18px; border-bottom: 1px solid rgba(255,255,255,0.14); margin-bottom: 24px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--innovia-green); }
    .lead-section form fieldset { border: 0; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 14px; }
    .lead-section form legend { font-family: var(--font-display); font-weight: 700; font-size: 13px; color: rgba(255,255,255,0.55); letter-spacing: 0.04em; text-transform: uppercase; padding: 0 0 8px; border-bottom: 1px solid rgba(255,255,255,0.10); width: 100%; margin-bottom: 4px; }
    .lead-section form label { display: flex; flex-direction: column; gap: 6px; font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,0.65); letter-spacing: 0.08em; text-transform: uppercase; }
    .lead-section form .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .lead-section form input, .lead-section form select, .lead-section form textarea { background: rgba(0,0,0,0.22); border: 1px solid rgba(255,255,255,0.18); padding: 13px 14px; color: #fff; font-family: var(--font-body); font-size: 15px; text-transform: none; }
    .lead-section form input:focus, .lead-section form select:focus, .lead-section form textarea:focus { outline: none; border-color: var(--innovia-green); box-shadow: 0 0 0 3px rgba(149,208,49,0.22); }
    .lead-section form button[type="submit"] { background: var(--innovia-green); color: var(--innovia-navy); border: 0; padding: 16px 26px; font-family: var(--font-display); font-weight: 700; font-size: 14px; letter-spacing: 0.04em; text-transform: uppercase; cursor: pointer; margin-top: 18px; display: inline-flex; align-items: center; gap: 10px; }
    .lead-section form button[type="submit"]:hover { background: var(--innovia-green-deep); color: #fff; }

    @media (max-width: 1080px) {
      .lead-section .grid { grid-template-columns: 1fr; gap: 32px; }
      .lead-section form .row { grid-template-columns: 1fr; }
    }
  </style>



  <section class="page-hero">
    <div class="container">
      
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <a href="/for-cams/why-innovia/">For CAMs</a>
        <span>/</span>
        <span style="color:#fff;">Schedule a Conversation</span>
      </div>
      <h1>Schedule a <em>conversation.</em><span class="light">No slide deck. No sequence. An honest read.</span></h1>
      <p class="lede">A 30-minute call with a member-owner of the cooperative. Confidential. We route your inquiry to the founder closest to your region and your situation. Five business-day response.</p>
    </div>
  </section>

  <section class="lead-section">
    <div class="container">
      <div class="grid">
        <div class="pitch">
          <h2>You don&rsquo;t have to <em>go it alone.</em></h2>
          <p>Innovia is invitation-only. Conversations are confidential, low-pressure, and always lead with the cooperative&rsquo;s working questions: what your company is up against, what you already have figured out, and whether the cooperative would actually move the needle.</p>
          <div class="how">
            <div class="step"><span class="ix">01</span><div><h5>You tell us about your company.</h5><p>Headquarters, portfolio size, the line items where you wish you had more leverage.</p></div></div>
            <div class="step"><span class="ix">02</span><div><h5>We route you to a member-owner.</h5><p>Not a salesperson. A founder in or near your region whose company looks like yours.</p></div></div>
            <div class="step"><span class="ix">03</span><div><h5>You take the call if it fits.</h5><p>Within five business days. If now isn&rsquo;t the moment, we keep you on the Summit list.</p></div></div>
          </div>
        </div>
        <form onsubmit="event.preventDefault(); this.querySelector('button[type=submit]').textContent='Thanks \\u2014 we\\u2019ll be in touch';">
          <div class="head"><span>Member-company inquiry</span><span style="color:rgba(255,255,255,0.5);">10 fields &middot; ~3 min</span></div>
          <fieldset><legend>About you</legend>
            <div class="row"><label>First name<input type="text" placeholder="Jordan" required></label><label>Last name<input type="text" placeholder="Reyes" required></label></div>
            <div class="row"><label>Work email<input type="email" placeholder="you@yourcompany.com" required></label><label>Phone<input type="tel" placeholder="(555) 555-0123"></label></div>
          </fieldset>
          <fieldset><legend>About your company</legend>
            <div class="row"><label>Company name<input type="text" required></label><label>Headquartered<input type="text" placeholder="City, State" required></label></div>
            <div class="row"><label>Portfolio size<select required><option value="">Households managed</option><option>Under 1,000</option><option>1,000–5,000</option><option>5,000–15,000</option><option>15,000–40,000</option><option>Over 40,000</option></select></label><label>States we operate in<input type="text" placeholder="e.g. CA, NV, AZ" required></label></div>
          </fieldset>
          <fieldset><legend>The conversation</legend>
            <label>Were you referred by a member?<input type="text" placeholder="Member company or founder name"></label>
            <label>What&rsquo;s prompting the conversation?<textarea rows="3" placeholder="Margin, talent, vendor terms, the long view — what's on your mind"></textarea></label>
          </fieldset>
          <button type="submit">Schedule a Conversation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </button>
        </form>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="Schedule a Conversation · Innovia Co-op"
  description="Schedule a Conversation · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  headerVariant="inverse"
  activeNav="cams"
  ctaLabel="Find a Member"
  ctaHref="/find-a-management-company/#request"
>
  <Fragment set:html={html} />
</BaseLayout>
