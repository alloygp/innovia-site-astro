---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Hero ---------- */
    .page-hero {
      padding: 64px 0 32px;
      position: relative; overflow: hidden;
    }
    .page-hero::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 88% 6%, rgba(149,208,49,0.14) 0%, transparent 38%),
        radial-gradient(circle at 4% 92%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
      margin-bottom: 40px;
      padding-bottom: 16px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero .crumb .right {
      margin-left: auto;
      display: flex; align-items: center; gap: 12px;
    }
    .page-hero .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }

    .page-hero .title-row {
      display: grid; grid-template-columns: 1.5fr 1fr;
      gap: 80px;
      align-items: end;
    }
    .page-hero h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(48px, 6.6vw, 104px);
      line-height: 0.95;
      letter-spacing: -0.038em;
      color: #fff; margin: 0;
      text-wrap: balance;
    }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light {
      display: block;
      margin-top: 12px;
      font-family: var(--font-body);
      font-weight: 300;
      font-style: italic;
      font-size: 0.42em;
      line-height: 1.25;
      color: rgba(255,255,255,0.6);
      letter-spacing: -0.018em;
      max-width: 24ch;
    }
    .page-hero .meta-stack {
      display: flex; flex-direction: column; gap: 18px;
      padding-bottom: 8px;
    }
    .page-hero .meta-stack p {
      font-size: 16px; line-height: 1.6;
      color: rgba(255,255,255,0.78);
      margin: 0;
      max-width: 42ch;
    }
    .page-hero .meta-stack .pub {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.1em; text-transform: uppercase;
    }

    /* Filters */
    .filter-band {
      padding: 28px 0 32px;
      border-top: 1px solid rgba(255,255,255,0.18);
      margin-top: 56px;
    }
    .filter-band .row {
      display: grid;
      grid-template-columns: 90px 1fr;
      gap: 24px;
      align-items: start;
      padding: 14px 0;
    }
    .filter-band .row + .row {
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .filter-band .label {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding-top: 8px;
    }
    .filter-band .pills {
      display: flex; gap: 8px; flex-wrap: wrap;
    }
    .filter-band .pill {
      padding: 7px 14px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.16);
      font-family: var(--font-body);
      font-size: 13px;
      color: rgba(255,255,255,0.78);
      letter-spacing: 0.005em;
      transition: all .15s;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .filter-band .pill:hover { border-color: var(--innovia-green); color: #fff; }
    .filter-band .pill.active {
      background: var(--innovia-green); color: var(--innovia-navy);
      border-color: var(--innovia-green);
      font-weight: 600;
    }
    .filter-band .pill .ct {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.04em;
    }
    .filter-band .pill.active .ct { color: rgba(24,51,94,0.6); }

    /* ---------- Stat strap ---------- */
    .stat-strap {
      padding: 24px 0 64px;
      background: var(--innovia-navy);
    }
    .stat-strap .frame {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--innovia-green);
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .stat-strap .stat {
      padding: 24px 24px 22px;
      border-right: 1px solid rgba(255,255,255,0.12);
      display: flex; flex-direction: column; gap: 6px;
    }
    .stat-strap .stat:last-child { border-right: 0; }
    .stat-strap .stat .v {
      font-family: var(--font-display); font-weight: 900;
      font-size: 36px;
      color: var(--innovia-green);
      letter-spacing: -0.025em;
      line-height: 0.95;
    }
    .stat-strap .stat .k {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.06em;
    }

    /* ---------- Listing ---------- */
    .listing {
      padding: 24px 0 96px;
      background: var(--innovia-navy);
    }

    /* Featured card (big) */
    .featured-case {
      background: linear-gradient(135deg, var(--innovia-navy-deep) 0%, var(--innovia-navy) 60%);
      border: 1px solid rgba(255,255,255,0.14);
      padding: 0;
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition: border-color .2s;
      position: relative;
    }
    .featured-case:hover { border-color: var(--innovia-green); }
    .featured-case::before {
      content: "Featured Case";
      position: absolute;
      top: 0; left: 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      font-family: var(--font-mono); font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 7px 14px;
      z-index: 2;
    }
    .featured-case .left {
      padding: 64px 56px 48px;
      display: flex; flex-direction: column; gap: 28px;
      justify-content: center;
    }
    .featured-case .left .kind {
      display: inline-flex; align-items: center; gap: 10px;
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .featured-case .left .kind .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .featured-case .left h2 {
      font-family: var(--font-display); font-weight: 800;
      font-size: clamp(28px, 3.4vw, 44px);
      line-height: 1.08;
      letter-spacing: -0.022em;
      color: #fff;
      margin: 0;
      max-width: 22ch;
    }
    .featured-case .left .firm {
      display: flex; align-items: center; gap: 14px;
      padding-top: 18px;
      border-top: 1px solid rgba(255,255,255,0.14);
    }
    .featured-case .left .firm .mark {
      width: 44px; height: 44px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      font-family: var(--font-display); font-weight: 900;
      font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      letter-spacing: -0.01em;
    }
    .featured-case .left .firm .who {
      display: flex; flex-direction: column; gap: 2px;
    }
    .featured-case .left .firm .name {
      font-family: var(--font-display); font-weight: 700;
      color: #fff;
      font-size: 15px;
      letter-spacing: -0.005em;
    }
    .featured-case .left .firm .loc {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.04em;
    }
    .featured-case .left .read {
      display: inline-flex; align-items: center; gap: 8px;
      margin-top: 12px;
      font-family: var(--font-display); font-weight: 600;
      font-size: 14px;
      color: var(--innovia-green);
      border-bottom: 1px solid var(--innovia-green);
      padding-bottom: 4px;
      align-self: flex-start;
    }
    .featured-case .left .read .arrow { transition: transform .2s var(--ease-out); }
    .featured-case:hover .left .read .arrow { transform: translateX(3px); }

    .featured-case .right {
      background: var(--innovia-navy-deep);
      padding: 64px 48px 48px;
      display: flex; flex-direction: column; gap: 22px;
      border-left: 1px solid rgba(255,255,255,0.10);
    }
    .featured-case .right .by-numbers {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 700;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .featured-case .right .metric {
      display: grid;
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 14px 0;
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .featured-case .right .metric:last-of-type { border-bottom: 0; }
    .featured-case .right .metric .v {
      font-family: var(--font-display); font-weight: 900;
      font-size: 38px;
      color: #fff;
      letter-spacing: -0.025em;
      line-height: 1;
    }
    .featured-case .right .metric .v em {
      color: var(--innovia-green);
      font-style: normal;
    }
    .featured-case .right .metric .k {
      font-family: var(--font-body);
      font-size: 13px;
      color: rgba(255,255,255,0.72);
      line-height: 1.4;
    }

    /* Cards grid */
    .case-grid {
      margin-top: 24px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    .case-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.12);
      padding: 28px 28px 26px;
      display: flex; flex-direction: column; gap: 16px;
      text-decoration: none;
      color: inherit;
      transition: border-color .2s, transform .2s, box-shadow .2s;
      position: relative;
      min-height: 320px;
    }
    .case-card:hover {
      border-color: var(--innovia-green);
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(0,0,0,0.32);
    }
    .case-card .kind-row {
      display: flex; align-items: center; justify-content: space-between;
      gap: 12px;
    }
    .case-card .kind {
      font-family: var(--font-mono); font-size: 10px;
      color: var(--innovia-green);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .case-card .date {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.06em;
    }
    .case-card .headline {
      font-family: var(--font-display); font-weight: 700;
      font-size: 22px;
      color: #fff;
      letter-spacing: -0.014em;
      line-height: 1.18;
      margin: 0;
    }
    .case-card .headline em { color: var(--innovia-green); font-style: normal; }
    .case-card .firm {
      display: flex; align-items: center; gap: 12px;
      margin-top: auto;
      padding-top: 18px;
      border-top: 1px solid rgba(255,255,255,0.10);
    }
    .case-card .firm .mark {
      width: 32px; height: 32px;
      background: rgba(149,208,49,0.18);
      color: var(--innovia-green);
      font-family: var(--font-display); font-weight: 800;
      font-size: 14px;
      display: flex; align-items: center; justify-content: center;
      letter-spacing: -0.01em;
    }
    .case-card .firm .who {
      display: flex; flex-direction: column; gap: 2px;
      min-width: 0;
    }
    .case-card .firm .name {
      font-family: var(--font-display); font-weight: 700;
      color: #fff;
      font-size: 14px;
      letter-spacing: -0.005em;
    }
    .case-card .firm .loc {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.04em;
    }
    .case-card .stat-row {
      display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
      padding: 14px 0;
      border-top: 1px solid rgba(255,255,255,0.10);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .case-card .stat {
      display: flex; flex-direction: column; gap: 2px;
    }
    .case-card .stat .v {
      font-family: var(--font-display); font-weight: 800;
      font-size: 22px;
      color: var(--innovia-green);
      letter-spacing: -0.018em;
      line-height: 1;
    }
    .case-card .stat .k {
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .case-card .read {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--font-display); font-weight: 600;
      font-size: 12px;
      color: rgba(255,255,255,0.85);
      letter-spacing: 0.005em;
    }
    .case-card .read .arrow { transition: transform .2s var(--ease-out); }
    .case-card:hover .read { color: var(--innovia-green); }
    .case-card:hover .read .arrow { transform: translateX(3px); }

    /* Coming-soon variant */
    .case-card.pending {
      background: rgba(255,255,255,0.02);
      border-style: dashed;
      border-color: rgba(255,255,255,0.18);
      cursor: default;
    }
    .case-card.pending:hover {
      transform: none;
      box-shadow: none;
      border-color: rgba(255,255,255,0.18);
    }
    .case-card.pending .headline { color: rgba(255,255,255,0.75); }
    .case-card.pending .stamp {
      position: absolute; top: 16px; right: 16px;
      font-family: var(--font-mono); font-size: 9px;
      color: rgba(255,255,255,0.5);
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.16);
      padding: 4px 8px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .case-card.pending .stat .v { color: rgba(255,255,255,0.45); }
    .case-card.pending .read { color: rgba(255,255,255,0.4); }

    /* ---------- Methodology strap ---------- */
    .methodology {
      padding: 96px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .methodology .frame {
      display: grid; grid-template-columns: 1fr 1.6fr;
      gap: 96px;
      align-items: start;
    }
    .methodology h2 {
      color: var(--innovia-navy);
      font-size: clamp(30px, 3.4vw, 44px);
      letter-spacing: -0.024em;
      max-width: 14ch;
      margin: 14px 0 0;
    }
    .methodology h2 em { color: var(--innovia-green-deep); font-style: italic; font-weight: 400; }
    .methodology .body {
      display: flex; flex-direction: column; gap: 22px;
    }
    .methodology .body p {
      font-size: 16px; line-height: 1.65;
      color: var(--fg-2);
      margin: 0;
      max-width: 64ch;
    }
    .methodology .body p strong { color: var(--innovia-navy); font-weight: 600; }
    .methodology .body .rules {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
      margin-top: 12px;
    }
    .methodology .body .rule {
      padding: 18px 20px;
      background: #fff;
      border: 1px solid var(--border-subtle);
      display: flex; flex-direction: column; gap: 6px;
    }
    .methodology .body .rule .k {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .methodology .body .rule .v {
      font-family: var(--font-display); font-weight: 600;
      font-size: 15px;
      color: var(--innovia-navy);
      line-height: 1.4;
      letter-spacing: -0.005em;
    }

    /* ---------- CTA finale ---------- */
    .cta-finale {
      padding: 140px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .cta-finale .frame {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 80px; align-items: center;
    }
    .cta-finale h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 5.4vw, 80px);
      letter-spacing: -0.03em;
      line-height: 0.98;
      max-width: 16ch;
      margin: 14px 0 0;
    }
    .cta-finale h2 em { color: #fff; font-style: normal; }
    .cta-finale .lead {
      max-width: 50ch; margin-top: 18px;
      font-size: 17px; line-height: 1.55;
      color: var(--innovia-navy);
      opacity: 0.82;
    }
    .cta-finale .actions {
      display: flex; flex-direction: column; gap: 10px;
    }
    .cta-finale .actions .btn { padding: 18px 28px; font-size: 16px; justify-content: center; }
    .cta-finale .actions .btn-navy { background: var(--innovia-navy); color: #fff; }
    .cta-finale .actions .btn-navy:hover { background: var(--innovia-navy-deep); }
    .cta-finale .actions .btn-outline { color: var(--innovia-navy); border-color: var(--innovia-navy); }
    .cta-finale .actions .btn-outline:hover { background: var(--innovia-navy); color: #fff; }

    @media (max-width: 1080px) {
      .page-hero .title-row,
      .featured-case,
      .methodology .frame,
      .cta-finale .frame { grid-template-columns: 1fr; gap: 32px; }
      .featured-case .right { border-left: 0; border-top: 1px solid rgba(255,255,255,0.10); }
      .case-grid { grid-template-columns: repeat(2, 1fr); }
      .stat-strap .frame { grid-template-columns: repeat(2, 1fr); }
      .stat-strap .stat:nth-child(2) { border-right: 0; }
      .stat-strap .stat:nth-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.12); }
      .filter-band .row { grid-template-columns: 1fr; gap: 12px; }
      .methodology .body .rules { grid-template-columns: 1fr; }
    }
    @media (max-width: 720px) {
      .case-grid { grid-template-columns: 1fr; }
      .stat-strap .frame { grid-template-columns: 1fr; }
      .stat-strap .stat { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.12); }
    }
  </style>


  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <span style="color:#fff;">Case Studies</span>
        <div class="right">
          <span class="dot"></span>
          <span class="placeholder placeholder-inline">[#]</span>&nbsp; published &middot; <span class="placeholder placeholder-inline">[#]</span> in production
        </div>
      </div>

      <div class="title-row">
        <h1>
          Stories from <em>the cooperative.</em>
          <span class="light">Member companies, member outcomes &mdash; documented, sourced, and on the record.</span>
        </h1>
        <div class="meta-stack">
          <p>
            Each case study is co-authored with the member company at the center of it. Numbers are pulled from member ledgers and verified before publication. No anonymised vendors. No composite communities.
          </p>
          <div class="pub">Case Studies &middot; Member Success Stories</div>
        </div>
      </div>

      <!-- FILTERS -->
      <div class="filter-band">
        <div class="row">
          <span class="label">Type</span>
          <div class="pills">
            <button class="pill active">All <span class="ct placeholder placeholder-inline">[12]</span></button>
            <button class="pill">Switching to a member <span class="ct placeholder placeholder-inline">[4]</span></button>
            <button class="pill">Self-managed transition <span class="ct placeholder placeholder-inline">[2]</span></button>
            <button class="pill">Vendor program savings <span class="ct placeholder placeholder-inline">[3]</span></button>
            <button class="pill">Growth &amp; M&amp;A <span class="ct placeholder placeholder-inline">[2]</span></button>
            <button class="pill">Cooperative operations <span class="ct placeholder placeholder-inline">[1]</span></button>
          </div>
        </div>
        <div class="row">
          <span class="label">Audience</span>
          <div class="pills">
            <button class="pill active">All</button>
            <button class="pill">For Boards</button>
            <button class="pill">For CAM Owners</button>
            <button class="pill">For Self-Managed</button>
          </div>
        </div>
        <div class="row">
          <span class="label">Region</span>
          <div class="pills">
            <button class="pill active">National</button>
            <button class="pill">Southeast</button>
            <button class="pill">Mountain West</button>
            <button class="pill">Southwest</button>
            <button class="pill">Mid-Atlantic</button>
            <button class="pill">Pacific Northwest</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRAP -->
  <section class="stat-strap">
    <div class="container">
      <div class="frame">
        <div class="stat">
          <span class="v placeholder placeholder-inline">$24M+</span>
          <span class="k">In documented member savings</span>
        </div>
        <div class="stat">
          <span class="v placeholder placeholder-inline">38</span>
          <span class="k">States with member coverage</span>
        </div>
        <div class="stat">
