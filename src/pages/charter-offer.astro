---
// Static route: /charter-offer/
// The Innovia Charter — founding-member offer landing page.
//
// Standalone page on purpose: it ships its own unique header/nav + footer
// (inside CharterOffer.astro), so it does NOT use the shared BaseLayout /
// SiteHeader / SiteFooter chrome used by the rest of the site.
//
// The baked variant is set via the <body> data-* attributes below:
//   data-framing    = "invitation" | "challenge"
//   data-value-emph = "partner"    | "total"
//   data-urgency    = "on"         | "off"
import CharterOffer from "../components/CharterOffer.astro";
import ReviewWidget from "../components/ReviewWidget.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Innovia Charter · Innovia Co-op</title>
    <meta
      name="description"
      content="Innovia membership, First Citizens Bank, and Alloy Growth Partners — all three for one $1,500 charter rate your first 90 days. One charter seat per metro. Are you the operator who takes it?"
    />
    <link rel="canonical" href="https://innoviaco-op.com/charter-offer/" />
    <link rel="icon" type="image/png" href="/assets/innovia-icon.png" />
    <link rel="apple-touch-icon" href="/assets/innovia-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="The Innovia Charter · One CAM per market" />
    <meta
      property="og:description"
      content="Innovia membership, First Citizens Bank, and Alloy Growth Partners — all three for one $1,500 charter rate your first 90 days. One charter seat per metro."
    />
    <meta property="og:url" content="https://innoviaco-op.com/charter-offer/" />
    <meta property="og:image" content="/assets/og/option-1-type-led.png" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body
    data-screen-label="Charter Offer"
    data-framing="invitation"
    data-urgency="on"
    data-value-emph="total"
  >
    <CharterOffer />
    <ReviewWidget />
  </body>
</html>
