---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Hero ---------- */
    .page-hero {
      padding: 96px 0 64px;
      position: relative; overflow: hidden;
    }
    .page-hero::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 88% 8%, rgba(149,208,49,0.16) 0%, transparent 40%),
        radial-gradient(circle at 4% 92%, rgba(42,74,120,0.55) 0%, transparent 50%);
      pointer-events: none;
    }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
      margin-bottom: 56px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero .crumb .right {
      margin-left: auto;
      display: flex; align-items: center; gap: 12px;
    }
    .page-hero .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }
    .page-hero h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(64px, 9vw, 148px);
      line-height: 0.9;
      letter-spacing: -0.045em;
      color: #fff; margin: 0;
      text-wrap: balance;
    }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light {
      font-family: var(--font-body);
      font-weight: 300; font-style: italic;
      color: rgba(255,255,255,0.5);
      letter-spacing: -0.025em;
    }
    .page-hero .below {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 64px;
      align-items: end;
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .below p {
      font-size: clamp(17px, 1.4vw, 20px);
      line-height: 1.55;
      color: rgba(255,255,255,0.78);
      max-width: 52ch;
      margin: 0;
    }
    .page-hero .below .info-row {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .page-hero .below .info-row > div {
      display: flex; flex-direction: column; gap: 4px;
    }
    .page-hero .below .info-row .k {
      font-family: var(--font-display); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .page-hero .below .info-row .v {
      font-family: var(--font-display); font-weight: 700;
      font-size: 16px; color: #fff;
    }

    /* ---------- Origin (cream block) ---------- */
    .origin {
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .origin .layout {
      display: grid; grid-template-columns: 0.9fr 1.1fr;
      gap: 96px;
      align-items: start;
    }
    .origin h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.4vw, 60px);
      letter-spacing: -0.028em;
      margin: 14px 0 0;
      max-width: 14ch;
    }
    .origin .body p {
      font-size: 18px;
      line-height: 1.7;
      color: var(--fg-2);
      margin: 0 0 18px;
    }
    .origin .body p:first-child::first-letter {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 96px;
      float: left;
      line-height: 0.78;
      margin: 8px 14px 0 0;
      color: var(--innovia-navy);
    }
    .origin .body .pull {
      font-family: var(--font-display); font-weight: 500;
      font-size: clamp(22px, 2.2vw, 28px);
      line-height: 1.35;
      letter-spacing: -0.014em;
      color: var(--innovia-navy);
      padding: 28px 0;
      margin: 28px 0;
      border-top: 4px solid var(--innovia-green);
      border-bottom: 1px solid var(--border-subtle);
      max-width: 36ch;
    }

    /* ---------- The cooperative model ---------- */
    .model {
      padding: 120px 0;
      background: var(--innovia-navy);
    }
    .model .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 64px;
    }
    .model h2 {
      color: #fff;
      font-size: clamp(38px, 4.6vw, 60px);
      letter-spacing: -0.028em;
      max-width: 16ch;
    }
    .model .head p { color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.6; }
    .model .principles {
      display: grid; grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--innovia-green);
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .model .principle {
      padding: 36px 28px 36px;
      border-right: 1px solid rgba(255,255,255,0.12);
      display: flex; flex-direction: column; gap: 14px;
    }
    .model .principle:last-child { border-right: 0; }
    .model .principle .num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 56px; line-height: 0.85;
      color: var(--innovia-green);
      letter-spacing: -0.035em;
    }
    .model .principle h4 {
      font-size: 20px; color: #fff;
      letter-spacing: -0.014em;
      margin: 0;
    }
    .model .principle p {
      font-size: 14px; line-height: 1.55;
      color: rgba(255,255,255,0.68);
      margin: 0;
    }
    .model .principle .meta {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.4); letter-spacing: 0.04em;
      margin-top: auto;
      padding-top: 14px;
      border-top: 1px solid rgba(255,255,255,0.10);
    }

    /* ---------- Creed (manifesto strap) ---------- */
    .creed {
      padding: 120px 0;
      background: var(--innovia-navy);
      position: relative; overflow: hidden;
    }
    .creed::before {
      content: ""; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 80%);
    }
    .creed .container { position: relative; z-index: 1; text-align: center; }
    .creed .meta {
      display: flex; justify-content: center; gap: 16px;
      margin-bottom: 36px;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .creed .meta .bar { width: 36px; height: 1px; background: rgba(255,255,255,0.3); align-self: center; }
    .creed h2 {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(48px, 7vw, 112px);
      line-height: 0.94;
      letter-spacing: -0.038em;
      color: #fff;
      margin: 0;
      max-width: 18ch;
      margin-left: auto; margin-right: auto;
    }
    .creed h2 em { color: var(--innovia-green); font-style: normal; }

    /* ---------- Governance ---------- */
    .governance {
      position: relative;
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
      overflow: hidden;
    }
    .governance::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: url('/assets/photos/how-the-cooperative-is-run.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0.08;
      pointer-events: none;
      z-index: 0;
    }
    .governance > .container { position: relative; z-index: 1; }
    .governance .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 56px;
    }
    .governance h2 {
      color: var(--innovia-navy);
      font-size: clamp(38px, 4.6vw, 60px);
      letter-spacing: -0.026em;
      margin: 0;
      max-width: 18ch;
    }
    .governance h2 em {
      color: var(--innovia-green-deep);
      font-style: italic;
      font-weight: 400;
    }
    .governance .head p {
      font-size: 17px; line-height: 1.6;
      max-width: 52ch;
      color: var(--fg-2);
      margin: 0;
    }
    .governance .head p strong {
      color: var(--innovia-navy);
      font-weight: 600;
    }
    .governance .gov-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-top: 2px solid var(--innovia-green);
      border-bottom: 1px solid var(--border-subtle);
      background: #fff;
    }
    .governance .gov-card {
      padding: 36px 32px 32px;
      border-right: 1px solid var(--border-subtle);
      display: flex; flex-direction: column;
      gap: 14px;
    }
    .governance .gov-card:last-child { border-right: 0; }
    .governance .gov-num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 56px;
      color: var(--innovia-navy);
      letter-spacing: -0.035em;
      line-height: 0.85;
    }
    .governance .gov-card h4 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 22px;
      color: var(--innovia-navy);
      letter-spacing: -0.014em;
      line-height: 1.2;
      margin: 0;
    }
    .governance .gov-card p {
      font-size: 14px; line-height: 1.6;
      color: var(--fg-2);
      margin: 0;
    }
    .governance .gov-tag {
      margin-top: auto;
      padding-top: 18px;
      border-top: 1px solid var(--border-subtle);
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3);
      letter-spacing: 0.04em;
    }
    .governance .gov-creed {
      margin-top: 36px;
      padding: 28px 32px;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.85);
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 32px;
      align-items: start;
    }
    .governance .gov-creed .k {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding-top: 2px;
    }
    .governance .gov-creed p {
      font-family: var(--font-display); font-weight: 500;
      font-size: 19px;
      line-height: 1.45;
      color: #fff;
      letter-spacing: -0.005em;
      margin: 0;
      max-width: 68ch;
    }

    /* ---------- Partners ---------- */
    .partners {
      padding: 120px 0;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
    }
    .partners .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 48px;
    }
    .partners h2 { color: #fff; font-size: clamp(34px, 3.8vw, 48px); letter-spacing: -0.024em; }
    .partners .head p { color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.6; }
    .partners .row {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
    .partners .partner {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
      padding: 28px;
      display: flex; flex-direction: column; gap: 14px;
      transition: border-color .2s;
    }
    .partners .partner:hover { border-color: var(--innovia-green); }
    .partners .partner .kind {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green); letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .partners .partner h4 {
      font-size: 18px; color: #fff;
      letter-spacing: -0.01em;
      margin: 0;
    }
    .partners .partner p {
      font-size: 13px; line-height: 1.5;
      color: rgba(255,255,255,0.6);
      margin: 0;
    }

    /* ---------- Recognition (placeholder) ---------- */
    .recognition {
      padding: 80px 0;
      background: var(--innovia-navy-deep);
      color: rgba(255,255,255,0.6);
    }
    .recognition .frame {
      display: grid; grid-template-columns: 1fr 2fr;
      gap: 64px; align-items: center;
    }
    .recognition .label {
      font-family: var(--font-display); font-size: 12px;
      font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .recognition .marks {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      align-items: center;
    }
    .recognition .marks .mark-slot {
      aspect-ratio: 3 / 1;
      background: rgba(255,255,255,0.04);
      border: 1px dashed rgba(255,255,255,0.18);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.08em; text-transform: uppercase;
    }

    /* ---------- CTA ---------- */
    .cta-finale {
      padding: 140px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .cta-finale .frame {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 80px; align-items: center;
    }
    .cta-finale h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 5.4vw, 80px);
      letter-spacing: -0.03em;
      line-height: 0.98;
      max-width: 16ch;
    }
    .cta-finale h2 em { color: #fff; font-style: normal; }
    .cta-finale .lead {
      max-width: 50ch; margin-top: 18px;
      font-size: 17px; line-height: 1.55;
      color: var(--innovia-navy);
      opacity: 0.85;
    }
    .cta-finale .actions {
      display: flex; flex-direction: column; gap: 10px;
    }
    .cta-finale .actions .btn { padding: 18px 28px; font-size: 16px; justify-content: center; }
    .cta-finale .actions .btn-navy { background: var(--innovia-navy); color: #fff; }
    .cta-finale .actions .btn-navy:hover { background: var(--innovia-navy-deep); }
    .cta-finale .actions .btn-outline { color: var(--innovia-navy); border-color: var(--innovia-navy); }
    .cta-finale .actions .btn-outline:hover { background: var(--innovia-navy); color: #fff; }

    @media (max-width: 1080px) {
      .page-hero .below, .origin .layout, .model .head, .governance .head, .partners .head, .recognition .frame, .cta-finale .frame { grid-template-columns: 1fr; gap: 32px; }
      .model .principles { grid-template-columns: repeat(2, 1fr); }
      .model .principle:nth-child(2) { border-right: 0; }
      .model .principle:nth-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.12); }
      .governance .gov-grid { grid-template-columns: 1fr; }
      .governance .gov-card { border-right: 0; border-bottom: 1px solid var(--border-subtle); }
      .governance .gov-card:last-child { border-bottom: 0; }
      .governance .gov-creed { grid-template-columns: 1fr; gap: 14px; }
      .partners .row { grid-template-columns: repeat(2, 1fr); }
      .recognition .marks { grid-template-columns: repeat(2, 1fr); }
    }
  </style>


  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <span style="color:#fff;">About</span>
        <div class="right">
          <span class="dot"></span>
          Member-owned · invitation-only · est. <span>2012</span>
        </div>
      </div>
      <h1>
        By the members.<br>
        <em>For</em> the members.
      </h1>
      <div class="below">
        <p>Innovia is a national cooperative of independent community association management companies. Owned by its members, run for their benefit, and built on the premise that the country&rsquo;s best independent operators are stronger together than they are alone. Our mission is to empower community management companies to leverage the collective strength of the member network &mdash; providing access to exclusive programs and services that improve operations and enhance the communities they serve.</p>
        <div class="info-row">
          <div><span class="k">Founded</span><span class="v">2012</span></div>
          <div><span class="k">Headquartered</span><span class="v">Manchester, NH</span></div>
          <div><span class="k">Member companies</span><span class="v">80+</span></div>
          <div><span class="k">Households served</span><span class="v">1.4M+</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ORIGIN -->
  <section class="origin">
    <div class="container">
      <div class="layout">
        <div>
          <div class="eyebrow"><span class="num">No. 01</span><span class="rule-mini"></span>Origin</div>
          <h2>The room that started it.</h2>
        </div>
        <div class="body">
          <p>
            Innovia was started <span>2012</span> by a handful of independent CAM company founders who kept ending up in the same hallway conversations at industry events. The conversations were always the same shape: the nationals had vendor terms the independents couldn&rsquo;t match, the boards were getting price-sensitive, and the loneliest seat at every operator&rsquo;s table was the one labelled <em>owner</em>.
          </p>
          <p>
            The first deal was a banking program. The second was a software licensing agreement. The third was a Wednesday afternoon &mdash; four hours over coffee &mdash; that turned into the peer council the cooperative is now built around. The pattern was clear: pool the volume, share the intelligence, keep the independence.
          </p>
          <p class="pull">
            We didn&rsquo;t set out to build a co-op. We set out to make a better room. The co-op is what it took to keep the room going.
          </p>
          <p>
            The cooperative grew the way the founders wanted it to grow: by introduction. A member nominates a peer. A peer takes the call. If the fit is real, the room expands. 80+ firms later, the model still answers the phone the same way.
          </p>
          <p>
            Today Innovia&rsquo;s members manage <span>1.4&nbsp;million</span>&nbsp;+ households across <span>25+</span> states. The community is structured around three commitments &mdash; elite community, business growth, and a vendor program built specifically for the CAM industry &mdash; and a single working creed:
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CREED -->
  <section class="creed">
    <div class="container">
      <div class="meta">
        <span class="bar"></span>
        Innovia&rsquo;s working creed
        <span class="bar"></span>
      </div>
      <h2>
        We stand <em>apart</em><br>
        because we stand <em>together.</em>
      </h2>
    </div>
  </section>

  <!-- COOPERATIVE MODEL -->
  <section class="model">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 02</span><span class="rule-mini"></span>The cooperative model</div>
          <h2 style="margin-top: 14px;">Owned by members. Run for members.</h2>
        </div>
        <p>Innovia is structured as a true cooperative &mdash; not a GPO, not a franchise, not a referral network. Members hold a stake in the organization, contribute to governance, and share in its success.</p>
      </div>
      <div class="principles">
        <div class="principle">
          <div class="num">01</div>
          <h4>Member-owned</h4>
          <p>Every member company has a stake in the cooperative. No outside investors. No PE backing. <span class="placeholder placeholder-inline">[Specific governance &amp; equity details to confirm with client.]</span></p>
          <span class="meta">P · 01 · Structure</span>
        </div>
        <div class="principle">
          <div class="num">02</div>
          <h4>Invitation-only</h4>
          <p>Membership grows by member nomination. We don&rsquo;t prospect. We don&rsquo;t cold-call. New companies join because an existing one vouched for them in a room.</p>
          <span class="meta">P · 02 · Growth</span>
        </div>
        <div class="principle">
          <div class="num">03</div>
          <h4>Member-governed</h4>
          <p>An elected member council sets the annual program, votes on vendor lineup changes, and steers the cooperative&rsquo;s direction. <span class="placeholder placeholder-inline">[Council composition and term details TBD.]</span></p>
          <span class="meta">P · 03 · Governance</span>
        </div>
        <div class="principle">
          <div class="num">04</div>
          <h4>No vendor agenda</h4>
          <p>The cooperative is not paid by vendors to feature them. Vendor partners earn the lineup by member-rated performance, then defend their slot each year.</p>
          <span class="meta">P · 04 · Independence</span>
        </div>
      </div>
    </div>
  </section>

  <!-- GOVERNANCE -->
  <section class="governance" id="governance">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow"><span class="num">No. 03</span><span class="rule-mini"></span>Governance</div>
          <h2 style="margin-top: 14px;">How the cooperative <em>is run.</em></h2>
        </div>
        <p>Decisions are made <strong>by</strong> the member companies, not for them. The cooperative has no outside investors, no PE backing, and no leadership team that exists separately from the membership. Every direction the co-op takes runs through the member council and a one-company-one-vote.</p>
      </div>

      <div class="gov-grid">
        <article class="gov-card">
          <div class="gov-num">01</div>
          <h4>The Member Council</h4>
          <p>An elected council of member-company founders and senior operators that sets the annual program, votes on vendor lineup, and steers the cooperative&rsquo;s long-term direction. <span class="placeholder placeholder-inline">[Composition: # of seats, term length, election cycle &mdash; to confirm with client.]</span></p>
          <span class="gov-tag">Strategy &middot; Program &middot; Vendor lineup</span>
        </article>
        <article class="gov-card">
          <div class="gov-num">02</div>
          <h4>One company, one vote</h4>
          <p>Cooperative-wide matters &mdash; new admissions, governance changes, the annual plan, and the vendor program &mdash; carry equal voting weight for every member company. Portfolio size doesn&rsquo;t buy more votes; it never has.</p>
          <span class="gov-tag">Admissions &middot; Plan &middot; Governance</span>
        </article>
        <article class="gov-card">
          <div class="gov-num">03</div>
          <h4>The Annual Cooperative Report</h4>
          <p>Published each <span class="placeholder placeholder-inline">[month]</span> and distributed to every member company. Includes member-rated vendor performance, financial summary, the year&rsquo;s wins, and the open questions going into the next Summit. The full member council and operating roster is listed inside.</p>
          <span class="gov-tag">Transparency &middot; Financials &middot; Council roster</span>
        </article>
      </div>

      <div class="gov-creed">
        <span class="k">The shorthand we use internally</span>
        <p>&ldquo;For and by the members.&rdquo; The cooperative isn&rsquo;t a brand built on top of independent operators &mdash; it is the operators, organized to negotiate together and keep the room they need to run their companies well.</p>
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="partners">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 04</span><span class="rule-mini"></span>Strategic partners</div>
          <h2 style="margin-top: 14px;">The companies that help us run.</h2>
        </div>
        <p>The cooperative works with a small group of long-term strategic partners on growth, brand, and the annual Summit. Vendor partners are separately curated for members and listed in the member portal.</p>
      </div>
      <div class="row">
        <article class="partner">
          <span class="kind">Banking</span>
          <h4>First Citizens Bank</h4>
          <p>Association banking, lockbox, and lending partner. First Citizens supports member companies and the communities they manage with HOA-specific banking expertise.</p>
        </article>
        <article class="partner">
          <span class="kind">Technology</span>
          <h4>Vantaca</h4>
          <p>The community association management platform powering member operations &mdash; accounting, communications, and resident experience built for the way modern CAMs run.</p>
        </article>
        <article class="partner">
          <span class="kind">Brand &amp; Growth</span>
          <h4>Alloy Growth Partners</h4>
          <p>Brand strategy, content, and the rebuild of this site. Alloy GP helps the cooperative speak to two audiences at once without losing the peer-to-peer register.</p>
        </article>
        <article class="partner">
          <span class="kind">Industry Affiliation</span>
          <h4 class="placeholder placeholder-inline">[CAI affiliation, etc.]</h4>
          <p class="placeholder placeholder-inline">[Confirm CAI member status, AAMC participation, and any other industry affiliations to feature here.]</p>
        </article>
      </div>
    </div>
  </section>

  <!-- RECOGNITION (placeholder) -->
  <section class="recognition">
    <div class="container">
      <div class="frame">
        <span class="label">As featured in &nbsp;·&nbsp; <span class="placeholder placeholder-inline">[Press &amp; industry coverage TBD]</span></span>
        <div class="marks">
          <div class="mark-slot">Press logo 01</div>
          <div class="mark-slot">Press logo 02</div>
          <div class="mark-slot">Press logo 03</div>
          <div class="mark-slot">Press logo 04</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-finale" id="talk">
    <div class="container">
      <div class="frame">
        <div>
          <div class="eyebrow" style="color: var(--innovia-navy); opacity: 0.65;"><span class="num" style="color: var(--innovia-navy);">No. 05</span><span class="rule-mini"></span>Get in touch</div>
          <h2 style="margin-top: 14px;">Talk to the <em>cooperative.</em></h2>
          <p class="lead">Whether you&rsquo;re a board evaluating management, an independent company exploring membership, or a journalist working on the industry &mdash; this is the right door.</p>
        </div>
        <div class="actions">
          <a href="/for-cams/why-innovia/" class="btn btn-navy">
            For CAM Owners · Why Join
