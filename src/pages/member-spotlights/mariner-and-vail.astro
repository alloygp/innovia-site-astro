---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Masthead ---------- */
    .spotlight-mast {
      padding: 64px 0 96px;
      position: relative; overflow: hidden;
    }
    .spotlight-mast::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 92% 12%, rgba(149,208,49,0.16) 0%, transparent 40%),
        radial-gradient(circle at 4% 88%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .spotlight-mast .container { position: relative; z-index: 1; }
    .spotlight-mast .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
      margin-bottom: 48px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .spotlight-mast .crumb a:hover { color: #fff; }
    .spotlight-mast .crumb .right {
      margin-left: auto;
      display: flex; align-items: center; gap: 12px;
      color: var(--innovia-green);
    }
    .spotlight-mast .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }
    .spotlight-mast .row {
      display: grid; grid-template-columns: 1fr 380px;
      gap: 80px; align-items: end;
    }
    .spotlight-mast .row .mark-row {
      display: flex; align-items: center; gap: 18px;
      margin-bottom: 28px;
    }
    .spotlight-mast .row .mark-row .mark {
      width: 72px; height: 72px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(149,208,49,0.4);
      color: var(--innovia-green);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 800;
      font-size: 26px;
    }
    .spotlight-mast .row .mark-row .badges { display: flex; gap: 8px; }
    .spotlight-mast .row .mark-row .badges span {
      font-family: var(--font-display); font-size: 11px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--innovia-green);
      background: rgba(149,208,49,0.18);
      padding: 6px 10px;
    }
    .spotlight-mast h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(48px, 6.4vw, 108px);
      line-height: 0.94;
      letter-spacing: -0.04em;
      color: #fff; margin: 0;
      text-wrap: balance;
    }
    .spotlight-mast .strap {
      margin-top: 24px;
      font-size: 19px; color: rgba(255,255,255,0.78);
      max-width: 60ch;
      line-height: 1.5;
    }
    .spotlight-mast .strap em { color: var(--innovia-green); font-style: normal; font-weight: 600; }
    .spotlight-mast aside {
      display: flex; flex-direction: column; gap: 16px;
      padding-bottom: 8px;
    }
    .spotlight-mast aside .row-info {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .spotlight-mast aside .row-info > div {
      display: flex; flex-direction: column; gap: 4px;
      padding: 14px 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
    }
    .spotlight-mast aside .row-info .k {
      font-family: var(--font-display); font-size: 10px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255,255,255,0.5); font-weight: 600;
    }
    .spotlight-mast aside .row-info .v {
      font-family: var(--font-display); font-weight: 800;
      font-size: 18px; color: #fff;
      letter-spacing: -0.014em;
    }
    .spotlight-mast aside .actions {
      display: flex; gap: 10px; margin-top: 8px;
    }
    .spotlight-mast aside .actions .btn { flex: 1; justify-content: center; padding: 14px 18px; }

    /* ---------- Cover photo ---------- */
    .cover-photo {
      padding: 0;
      background: var(--innovia-navy);
    }
    .cover-photo .frame {
      aspect-ratio: 21 / 8;
      overflow: hidden;
      position: relative;
    }
    .cover-photo .frame img {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.92);
    }
    .cover-photo .frame::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(15,36,71,0.3) 0%, transparent 30%, rgba(15,36,71,0.6) 100%);
    }
    .cover-photo .frame .play {
      position: absolute; left: 56px; bottom: 56px; z-index: 1;
      display: flex; align-items: center; gap: 16px;
      padding: 14px 22px 14px 14px;
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      font-family: var(--font-display); font-weight: 600;
      font-size: 14px;
    }
    .cover-photo .frame .play .icon {
      width: 40px; height: 40px;
      border-radius: 999px;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      display: flex; align-items: center; justify-content: center;
    }
    .cover-photo .frame .caption {
      position: absolute; bottom: 24px; right: 32px; z-index: 1;
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.7);
      letter-spacing: 0.04em;
    }

    /* ---------- Story (cream block) ---------- */
    .story {
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .story .layout {
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 96px;
      align-items: start;
    }
    .story h2 {
      color: var(--innovia-navy);
      font-size: clamp(36px, 4vw, 56px);
      letter-spacing: -0.028em;
      margin: 14px 0 0;
      max-width: 14ch;
    }
    .story .body { max-width: 62ch; }
    .story .body p {
      font-size: 17px;
      line-height: 1.7;
      color: var(--fg-2);
      margin: 0 0 18px;
    }
    .story .body p:first-of-type::first-letter {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 96px;
      float: left;
      line-height: 0.78;
      margin: 8px 14px 0 0;
      color: var(--innovia-navy);
    }
    .story .body blockquote {
      margin: 32px 0;
      padding: 28px 0 28px 32px;
      border-left: 4px solid var(--innovia-green);
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 24px;
      line-height: 1.32;
      letter-spacing: -0.014em;
      color: var(--innovia-navy);
      text-wrap: balance;
    }
    .story .body blockquote cite {
      display: block;
      margin-top: 14px;
      font-style: normal;
      font-family: var(--font-body);
      font-size: 13px;
      color: var(--fg-3);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    /* ---------- What it means for you (navy) ---------- */
    .what-it-means {
      padding: 120px 0;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
    }
    .what-it-means .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 56px;
    }
    .what-it-means h2 {
      color: #fff;
      font-size: clamp(38px, 4.6vw, 60px);
      letter-spacing: -0.028em;
      max-width: 18ch;
    }
    .what-it-means h2 em { color: var(--innovia-green); font-style: normal; }
    .what-it-means .head p { color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.6; }
    .what-it-means .benefits {
      display: grid; grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .what-it-means .benefit {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
      padding: 32px;
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 20px;
      transition: border-color .2s;
    }
    .what-it-means .benefit:hover { border-color: var(--innovia-green); }
    .what-it-means .benefit .icon {
      width: 48px; height: 48px;
      background: rgba(149,208,49,0.16);
      color: var(--innovia-green);
      display: flex; align-items: center; justify-content: center;
    }
    .what-it-means .benefit .body { display: flex; flex-direction: column; gap: 8px; }
    .what-it-means .benefit h4 {
      font-size: 20px; color: #fff;
      letter-spacing: -0.012em;
      margin: 0;
    }
    .what-it-means .benefit p {
      font-size: 14px;
      line-height: 1.55;
      color: rgba(255,255,255,0.7);
      margin: 0;
    }

    /* ---------- The people (cream) ---------- */
    .the-people {
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .the-people .head {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: end;
      margin-bottom: 56px;
    }
    .the-people h2 {
      color: var(--innovia-navy);
      font-size: clamp(36px, 4.4vw, 56px);
      letter-spacing: -0.028em;
      max-width: 16ch;
    }
    .the-people .head p { font-size: 17px; line-height: 1.55; max-width: 52ch; }
    .the-people .grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    .the-people .person {
      background: #fff;
      border: 1px solid var(--border-subtle);
      display: flex; flex-direction: column;
      transition: border-color .2s, transform .2s;
    }
    .the-people .person:hover {
      border-color: var(--innovia-navy);
      transform: translateY(-2px);
    }
    .the-people .person .photo {
      aspect-ratio: 4 / 5;
      background: var(--innovia-navy);
      overflow: hidden;
      position: relative;
    }
    .the-people .person .photo .placeholder-photo {
      width: 100%; height: 100%;
      background:
        radial-gradient(circle at 50% 35%, var(--innovia-navy-soft) 0%, var(--innovia-navy) 60%),
        var(--innovia-navy);
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 6px;
      color: rgba(255,255,255,0.4);
    }
    .the-people .person .photo .placeholder-photo .initials {
      font-family: var(--font-display); font-weight: 800;
      font-size: 44px;
      letter-spacing: -0.04em;
      color: rgba(255,255,255,0.7);
    }
    .the-people .person .photo .placeholder-photo .pl-tag {
      font-family: var(--font-mono); font-size: 9px;
      letter-spacing: 0.1em; text-transform: uppercase;
    }
    .the-people .person .body {
      padding: 20px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .the-people .person .role {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green-deep); letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .the-people .person h4 {
      font-size: 18px; color: var(--innovia-navy);
      letter-spacing: -0.012em;
      margin: 0; line-height: 1.2;
    }
    .the-people .person p {
      font-size: 13px; line-height: 1.5;
      color: var(--fg-2);
      margin: 4px 0 0;
    }

    /* ---------- Service philosophy (green) ---------- */
    .service-philosophy {
      padding: 120px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .service-philosophy .head {
      max-width: 980px;
      margin: 0 0 56px;
    }
    .service-philosophy h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 5.4vw, 80px);
      letter-spacing: -0.03em;
      max-width: 18ch;
    }
    .service-philosophy .head p {
      color: var(--innovia-navy);
      opacity: 0.85;
      margin-top: 18px;
      font-size: 18px;
      line-height: 1.55;
    }
    .service-philosophy .commitments {
      display: grid; grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--innovia-navy);
      border-bottom: 2px solid var(--innovia-navy);
    }
    .service-philosophy .commitment {
      padding: 40px 28px 40px;
      border-right: 1px solid rgba(24,51,94,0.18);
      display: flex; flex-direction: column; gap: 14px;
    }
    .service-philosophy .commitment:last-child { border-right: 0; }
    .service-philosophy .commitment .num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 56px; line-height: 0.85;
      color: var(--innovia-navy);
      letter-spacing: -0.035em;
    }
    .service-philosophy .commitment h4 {
      font-size: 22px; color: var(--innovia-navy);
      letter-spacing: -0.015em;
      margin: 0;
    }
    .service-philosophy .commitment p {
      font-size: 14px; line-height: 1.55;
      color: var(--innovia-navy); opacity: 0.78;
      margin: 0;
    }

    /* ---------- Board voice ---------- */
    .board-voice {
      padding: 0;
      background: var(--innovia-navy);
      color: rgba(255,255,255,0.78);
      position: relative; overflow: hidden;
      min-height: 540px;
      display: flex; align-items: center;
    }
    .board-voice .photo {
      position: absolute; inset: 0; z-index: 0;
    }
    .board-voice .photo img {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.85);
    }
    .board-voice .photo::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(95deg, rgba(15,36,71,0.94) 0%, rgba(15,36,71,0.74) 45%, rgba(15,36,71,0.38) 100%);
    }
    .board-voice .container { position: relative; z-index: 1; padding: 100px 0; }
    .board-voice .frame { max-width: 880px; }
    .board-voice .kick {
      font-family: var(--font-mono); font-size: 12px;
      color: var(--innovia-green);
      letter-spacing: 0.16em; text-transform: uppercase;
      margin-bottom: 28px;
    }
    .board-voice blockquote {
      margin: 0;
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(26px, 3vw, 42px);
      line-height: 1.22;
      letter-spacing: -0.018em;
      color: #fff;
      text-wrap: balance;
    }
    .board-voice blockquote::before {
      content: "“";
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 1.2em; line-height: 0;
      color: var(--innovia-green);
      vertical-align: -0.18em;
      margin-right: 0.05em;
    }
    .board-voice .attr {
      margin-top: 32px; padding-top: 22px;
      border-top: 1px solid rgba(255,255,255,0.2);
      display: flex; gap: 24px;
      font-size: 14px;
      color: rgba(255,255,255,0.74);
    }
    .board-voice .attr .name {
      font-family: var(--font-display); font-weight: 700;
      color: #fff;
    }

    /* ---------- Other companies ---------- */
    .other-companies {
      padding: 120px 0;
      background: var(--innovia-navy-deep);
      color: rgba(255,255,255,0.78);
    }
    .other-companies .head {
      display: flex; justify-content: space-between; align-items: end;
      margin-bottom: 40px;
    }
    .other-companies h2 {
      color: #fff;
      font-size: clamp(36px, 4.2vw, 56px);
      letter-spacing: -0.028em;
    }
    .other-companies .link-arrow { color: #fff; border-color: rgba(255,255,255,0.4); }
    .other-companies .link-arrow:hover { color: var(--innovia-green); border-color: var(--innovia-green); }
    .other-companies .grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }
    .other-companies .mini {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
      padding: 24px;
      display: flex; flex-direction: column; gap: 12px;
      transition: border-color .2s, transform .2s;
      cursor: pointer;
    }
    .other-companies .mini:hover { border-color: var(--innovia-green); transform: translateY(-2px); }
    .other-companies .mini .mark {
      width: 44px; height: 44px;
      background: rgba(149,208,49,0.16);
      color: var(--innovia-green);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 800; font-size: 14px;
    }
    .other-companies .mini h5 {
      font-size: 17px; color: #fff;
      letter-spacing: -0.01em;
      margin: 4px 0 0;
      line-height: 1.2;
    }
    .other-companies .mini .loc {
      font-size: 12px; color: rgba(255,255,255,0.55);
    }

    /* ---------- CTA ---------- */
    .contact-cta {
      padding: 140px 0;
      background: var(--innovia-navy);
      text-align: center;
      color: rgba(255,255,255,0.78);
    }
    .contact-cta h2 {
      color: #fff;
      font-size: clamp(44px, 6vw, 88px);
      letter-spacing: -0.032em;
      line-height: 0.98;
      margin: 0 auto;
      max-width: 22ch;
    }
    .contact-cta h2 em { color: var(--innovia-green); font-style: normal; }
    .contact-cta .lead {
      max-width: 56ch; margin: 28px auto 0;
      font-size: 18px; line-height: 1.6;
      color: rgba(255,255,255,0.74);
    }
    .contact-cta .ctas {
      display: flex; gap: 14px; justify-content: center;
      margin-top: 48px;
      flex-wrap: wrap;
    }
    .contact-cta .ctas .btn { padding: 18px 32px; font-size: 16px; }

    @media (max-width: 1080px) {
      .spotlight-mast .row, .story .layout, .what-it-means .head, .the-people .head, .other-companies .head { grid-template-columns: 1fr; gap: 32px; }
      .what-it-means .benefits { grid-template-columns: 1fr; }
      .the-people .grid { grid-template-columns: repeat(2, 1fr); }
      .service-philosophy .commitments { grid-template-columns: repeat(2, 1fr); }
      .service-philosophy .commitment:nth-child(2) { border-right: 0; }
      .service-philosophy .commitment:nth-child(-n+2) { border-bottom: 1px solid rgba(24,51,94,0.18); }
      .other-companies .grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>


  <!-- MASTHEAD -->
  <section class="spotlight-mast">
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a><span>/</span>
        <a href="/find-a-management-company/">For Boards</a><span>/</span>
        <a href="/member-spotlights/">Spotlights</a><span>/</span>
        <span style="color:#fff;">Mariner &amp; Vail</span>
        <div class="right">
          <span class="dot"></span>
          By appointment with your board
        </div>
      </div>

      <div class="row">
        <div>
          <div class="mark-row">
            <div class="mark">MV</div>
            <div class="badges">
              <span>Innovia-Backed</span>
              <span>Family-owned</span>
            </div>
          </div>
          <h1><span class="placeholder placeholder-inline">Mariner &amp; Vail<br>Community Management.</span></h1>
          <p class="strap">A <em>community-led</em> management company on the Southern California coast &mdash; serving boards, residents, and the homes in between, with the full backing of the Innovia cooperative.</p>
        </div>

        <aside>
          <div class="row-info">
            <div><span class="k">Founded</span><span class="v placeholder placeholder-inline">1998</span></div>
            <div><span class="k">Headquartered</span><span class="v placeholder placeholder-inline">San Diego</span></div>
            <div><span class="k">Innovia-backed since</span><span class="v placeholder placeholder-inline">2014</span></div>
            <div><span class="k">Cooperative role</span><span class="v">Charter</span></div>
          </div>
          <div class="actions">
            <a href="#contact" class="btn btn-primary">
              Request a Proposal
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
            <a href="/member-spotlights/" class="btn btn-outline-light">
              Back to spotlights
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- COVER PHOTO -->
  <section class="cover-photo">
    <div class="frame">
      <img src="/assets/photos/rooftop-deck-day.jpg" alt="The team at the Innovia Summit">
      <div class="play">
        <div class="icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </div>
        Meet the team · 4:32
      </div>
      <div class="caption">Recorded at the 2026 Summit · Lido House, Newport Beach</div>
    </div>
  </section>

  <!-- STORY -->
  <section class="story">
    <div class="container">
      <div class="layout">
        <div>
          <div class="eyebrow"><span class="num">No. 01</span><span class="rule-mini"></span>About this company</div>
          <h2>The people who answer the phone &mdash; and stand by their work.</h2>
        </div>
        <div class="body">
          <p>
            <span class="placeholder placeholder-inline">[Company name]</span> was founded on a simple belief: the people who manage your community should know it the way you do. The owners&rsquo; names are on the door, the same family has run the company for a generation, and the relationships with the boards they serve are measured in decades, not contracts.
          </p>
          <p>
            The company&rsquo;s reputation comes from doing the small things consistently. Calls returned the same day. Reserve studies prepared like the money was their own. Vendor work pursued like a long-time neighbor was the one paying the bill.
          </p>
          <blockquote>
            We took on community management because we wanted to make where people live better. Every board we serve, every resident we answer, every contractor we vet &mdash; we&rsquo;re working for the community first.
            <cite>— <span class="placeholder placeholder-inline">[Founder]</span> · Founder &amp; President</cite>
          </blockquote>
          <p>
            Joining the Innovia cooperative in <span class="placeholder placeholder-inline">2014</span> didn&rsquo;t change what the company does. It changed what the company brings with it &mdash; better-trained managers, better banking, better intelligence &mdash; all of it pointing back at the communities they serve.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT INNOVIA MEMBERSHIP MEANS FOR YOUR COMMUNITY -->
  <section class="what-it-means">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 02</span><span class="rule-mini"></span>What Innovia membership means for your community</div>
          <h2 style="margin-top: 14px;">A company with national resources, <em>locally accountable to you.</em></h2>
        </div>
        <p>The Innovia cooperative is a national network of independent community management companies. Members share intelligence, peer development, and vendor relationships &mdash; and every advantage points back at the communities they serve.</p>
      </div>

      <div class="benefits">
        <article class="benefit">
          <span class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <div class="body">
            <h4>Better-trained managers</h4>
            <p>Your community manager has a national peer cohort &mdash; people doing the same work, sharing what&rsquo;s working, and learning from one another. That investment shows up in your board meetings.</p>
          </div>
        </article>
        <article class="benefit">
          <span class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m7 14 4-4 4 4 6-6"/></svg>
          </span>
          <div class="body">
            <h4>Vendor relationships that reach your reserves</h4>
            <p>Cooperative-negotiated banking, insurance, and operational terms flow through to your operating and reserve budgets &mdash; not the company&rsquo;s bottom line. The savings are yours.</p>
          </div>
        </article>
        <article class="benefit">
          <span class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          </span>
          <div class="body">
            <h4>Industry intelligence, shared</h4>
            <p>What other Innovia member companies have learned about your kind of community &mdash; whether it&rsquo;s reserve planning, board governance, or vendor pitfalls &mdash; is available to your manager when you need it.</p>
          </div>
        </article>
        <article class="benefit">
          <span class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </span>
          <div class="body">
            <h4>The Innovia Academy</h4>
            <p>Cooperative-wide professional development for community managers, accounting staff, and maintenance leads. Your community gets the benefit of a more skilled team, every year.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- THE PEOPLE -->
  <section class="the-people">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow"><span class="num">No. 03</span><span class="rule-mini"></span>The team you&rsquo;d actually work with</div>
          <h2 style="margin-top: 14px;">Names. Not departments.</h2>
        </div>
        <p>The people who&rsquo;ll attend your board meetings, take your residents&rsquo; calls, and walk your property. Photos and full bios in the proposal.</p>
      </div>
      <div class="grid">
        <article class="person">
          <div class="photo">
            <div class="placeholder-photo">
              <span class="initials">JV</span>
              <span class="pl-tag">Portrait pending</span>
            </div>
          </div>
          <div class="body">
            <span class="role">Founder &amp; President</span>
            <h4 class="placeholder placeholder-inline">[Founder Name]</h4>
            <p>Personally meets with every new board in the first quarter of management. Available to chairs by direct line.</p>
          </div>
        </article>
        <article class="person">
          <div class="photo">
            <div class="placeholder-photo">
              <span class="initials">SR</span>
              <span class="pl-tag">Portrait pending</span>
            </div>
          </div>
          <div class="body">
            <span class="role">Senior Community Manager · CMCA<sup>&reg;</sup></span>
            <h4 class="placeholder placeholder-inline">[Manager Name]</h4>
            <p>Manages the community day to day. Attends every regular board meeting. Knows your reserve study by heart.</p>
          </div>
        </article>
        <article class="person">
          <div class="photo">
            <div class="placeholder-photo">
              <span class="initials">AT</span>
              <span class="pl-tag">Portrait pending</span>
            </div>
          </div>
          <div class="body">
            <span class="role">Accounting Lead</span>
            <h4 class="placeholder placeholder-inline">[Accountant Name]</h4>
            <p>Prepares your monthly financials and works directly with your treasurer on reserves and audit prep.</p>
          </div>
        </article>
        <article class="person">
          <div class="photo">
            <div class="placeholder-photo">
              <span class="initials">DF</span>
              <span class="pl-tag">Portrait pending</span>
            </div>
          </div>
          <div class="body">
            <span class="role">Facility &amp; Vendor Lead</span>
            <h4 class="placeholder placeholder-inline">[Facility Lead Name]</h4>
            <p>Manages bids, oversees scheduled maintenance, and walks the property weekly. Your direct line for vendor questions.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- SERVICE PHILOSOPHY (green) -->
  <section class="service-philosophy">
    <div class="container">
      <div class="head">
        <div class="eyebrow" style="color: var(--innovia-navy); opacity: 0.65;"><span class="num" style="color: var(--innovia-navy);">No. 04</span><span class="rule-mini"></span>How we think about boards</div>
        <h2 style="margin-top: 14px;">Four commitments. Every community.</h2>
      </div>
      <div class="commitments">
        <div class="commitment">
          <div class="num">01</div>
          <h4>The board leads.</h4>
          <p>You set direction. We support it. The community is yours; we&rsquo;re here to help you run it well.</p>
        </div>
        <div class="commitment">
          <div class="num">02</div>
          <h4>We answer the phone.</h4>
          <p>Calls returned same day. Direct lines for chairs and treasurers. A manager who knows your community by name.</p>
        </div>
        <div class="commitment">
          <div class="num">03</div>
          <h4>We bring questions.</h4>
          <p>Not just answers. The hard ones &mdash; about reserves, governance, vendor terms &mdash; are easier to face with a thinking partner.</p>
        </div>
        <div class="commitment">
          <div class="num">04</div>
          <h4>Your interests come first.</h4>
          <p>Every cooperative-negotiated dollar flows to the community. Vendor terms, banking, insurance &mdash; they&rsquo;re yours, not ours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOARD VOICE -->
  <section class="board-voice">
    <div class="photo" aria-hidden="true">
      <img src="/assets/photos/breakout-cupola-room.jpg" alt="">
    </div>
    <div class="container">
      <div class="frame">
        <div class="kick">From a board chair we serve</div>
        <blockquote>
          They&rsquo;ve been with our community longer than most of our board members. When something hard comes up, they show up with options &mdash; and the patience to walk through them. We&rsquo;re lucky to have them.
        </blockquote>
        <div class="attr">
          <span><span class="name placeholder placeholder-inline">[Board Chair Name]</span> · Board President</span>
          <span class="placeholder placeholder-inline">[Community Name], [City]</span>
        </div>
      </div>
    </div>
  </section>

  <!-- OTHER COMPANIES -->
  <section class="other-companies">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 05</span><span class="rule-mini"></span>Explore the cooperative</div>
          <h2 style="margin-top: 14px;">Other Innovia member companies.</h2>
        </div>
        <a href="/find-a-management-company/" class="link-arrow on-dark">
          See the full directory
          <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
        </a>
      </div>
      <div class="grid">
        <div class="mini">
          <div class="mark">CB</div>
          <h5><span class="placeholder placeholder-inline">Coastal Bay Association Mgmt</span></h5>
          <div class="loc">Tampa, FL</div>
        </div>
        <div class="mini">
          <div class="mark">NS</div>
          <h5><span class="placeholder placeholder-inline">North Star Property Council</span></h5>
          <div class="loc">Denver, CO</div>
        </div>
        <div class="mini">
          <div class="mark">HV</div>
          <h5><span class="placeholder placeholder-inline">Hudson Valley Community</span></h5>
          <div class="loc">Westchester, NY</div>
        </div>
        <div class="mini">
          <div class="mark">PG</div>
          <h5><span class="placeholder placeholder-inline">Piedmont Greens Mgmt</span></h5>
          <div class="loc">Raleigh, NC</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="contact-cta" id="contact">
    <div class="container">
      <h2>If you&rsquo;re a board considering a management change, <em>we&rsquo;d be honored to meet.</em></h2>
      <p class="lead">A proposal from us starts with a conversation &mdash; about your community, your reserves, your board&rsquo;s priorities. No call lists. No pressure. Just a thoughtful read on whether we&rsquo;re the right fit.</p>
      <div class="ctas">
        <a href="/find-a-management-company/#request" class="btn btn-primary">
          Request a Proposal
          <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
        </a>
        <a href="/find-a-management-company/" class="btn btn-outline-light">
          See other companies in your area
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  


  
`;
---
<BaseLayout
  title="Management Company Spotlight · Innovia Co-op"
  description="Management Company Spotlight · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  ctaLabel="Request a Proposal"
  ctaHref="#contact"
>
  <Fragment set:html={html} />
</BaseLayout>
