---
import BaseLayout from '../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }

    .site-header {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }
    .site-header .row { height: 76px; }

    /* ---------- Page hero ---------- */
    .page-hero {
      padding: 80px 0 64px;
      position: relative; overflow: hidden;
    }
    .page-hero::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 92% 8%, rgba(149,208,49,0.16) 0%, transparent 40%),
        radial-gradient(circle at 4% 96%, rgba(42,74,120,0.55) 0%, transparent 50%);
      pointer-events: none;
    }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5); letter-spacing: 0.04em;
      margin-bottom: 56px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero .crumb .right {
      margin-left: auto;
      display: flex; align-items: center; gap: 12px;
    }
    .page-hero .crumb .right .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--innovia-green);
      box-shadow: 0 0 12px rgba(149,208,49,0.7);
    }
    .page-hero h1 {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(64px, 8.6vw, 144px);
      line-height: 0.9;
      letter-spacing: -0.042em;
      color: #fff; margin: 0;
      text-wrap: balance;
    }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light {
      font-family: var(--font-body);
      font-weight: 300; font-style: italic;
      color: rgba(255,255,255,0.5);
      letter-spacing: -0.025em;
    }
    .page-hero .below {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 80px;
      align-items: end;
      margin-top: 56px;
      padding-top: 32px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .below p {
      font-size: clamp(17px, 1.3vw, 19px);
      line-height: 1.55;
      color: rgba(255,255,255,0.78);
      max-width: 52ch;
      margin: 0;
    }
    .page-hero .below .meta {
      display: flex; flex-direction: column; gap: 16px;
    }
    .page-hero .below .info-row {
      display: flex; gap: 28px;
      padding-top: 18px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .page-hero .below .info-row > div {
      display: flex; flex-direction: column; gap: 4px;
    }
    .page-hero .below .info-row .k {
      font-family: var(--font-display); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .page-hero .below .info-row .v {
      font-family: var(--font-display); font-weight: 700;
      font-size: 16px; color: #fff;
    }

    /* ---------- Map band ---------- */
    .map-band {
      padding: 0 0 24px;
    }
    .map-band .frame {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 16px;
      align-items: stretch;
    }
    .map-band .map {
      position: relative;
      background: #FBFAF6;
      padding: 24px;
      min-height: 420px;
      overflow: hidden;
    }
    .map-band .map .grid {
      position: absolute; inset: 24px;
      background-image:
        linear-gradient(rgba(24,51,94,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(24,51,94,0.06) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
    }
    .map-band .map svg.us {
      width: 100%; height: auto;
      position: relative; z-index: 1; display: block;
      max-height: 440px;
    }
    .map-band .map .pin { transition: r .2s, fill .2s; cursor: pointer; }
    .map-band .map .pin:hover { fill: var(--innovia-green-deep); }
    .map-band .map .pin.active { fill: var(--innovia-green); }
    .map-band .map .pin-label {
      font-family: var(--font-display); font-size: 11px;
      font-weight: 600; fill: var(--innovia-navy);
      text-anchor: middle;
    }
    .map-band .map .label {
      position: absolute; top: 18px; left: 24px;
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3); letter-spacing: 0.04em;
      z-index: 2;
    }
    .map-band .map .legend {
      position: absolute; bottom: 14px; right: 18px;
      display: flex; gap: 16px; align-items: center;
      font-family: var(--font-mono); font-size: 11px;
      color: var(--fg-3); z-index: 2;
    }
    .map-band .map .legend .dot {
      width: 8px; height: 8px; border-radius: 50%;
      display: inline-block; background: var(--innovia-green-deep);
      margin-right: 6px;
    }
    .map-band .stats {
      display: grid; grid-template-rows: repeat(4, 1fr);
      gap: 0;
      background: var(--innovia-navy-deep);
      border: 1px solid rgba(255,255,255,0.08);
    }
    .map-band .stats .cell {
      padding: 18px 22px;
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .map-band .stats .cell:last-child { border-bottom: 0; }
    .map-band .stats .cell .label {
      font-family: var(--font-display); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255,255,255,0.5); font-weight: 600;
    }
    .map-band .stats .cell .v {
      font-family: var(--font-display); font-weight: 900;
      font-size: 32px; line-height: 1;
      color: #fff;
      letter-spacing: -0.025em;
      margin-top: 6px;
    }
    .map-band .stats .cell .v .pct { color: var(--innovia-green); font-size: 0.6em; vertical-align: top; }
    .map-band .stats .cell .note {
      font-size: 12px; color: rgba(255,255,255,0.5);
      margin-top: 4px;
    }

    /* ---------- Search & results ---------- */
    .results-section {
      padding: 24px 0 96px;
    }
    .results-section .layout {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 16px;
      align-items: start;
    }
    .filters {
      position: sticky; top: 92px;
      background: #FBFAF6;
      border: 1px solid rgba(255,255,255,0.10);
    }
    .filters .head {
      padding: 18px 20px;
      border-bottom: 1px solid var(--border-subtle);
      display: flex; justify-content: space-between; align-items: center;
    }
    .filters .head h3 {
      font-size: 14px; font-weight: 700;
      color: var(--innovia-navy);
      letter-spacing: 0.04em; text-transform: uppercase;
      margin: 0;
    }
    .filters .head .clear {
      font-family: var(--font-body); font-size: 12px;
      color: var(--fg-3);
      background: none; border: 0; cursor: pointer;
    }
    .filters .head .clear:hover { color: var(--innovia-navy); }
    .filters .group {
      padding: 18px 20px;
      border-bottom: 1px solid var(--border-subtle);
    }
    .filters .group:last-child { border-bottom: 0; }
    .filters .group .label {
      font-family: var(--font-display);
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--fg-3);
      margin-bottom: 12px;
    }
    .filters .group select, .filters .group input[type="text"] {
      width: 100%;
      padding: 10px 12px;
      background: #fff;
      border: 1px solid var(--border-subtle);
      font-family: var(--font-body);
      font-size: 14px; color: var(--innovia-navy);
    }
    .filters .group .options {
      display: flex; flex-direction: column; gap: 8px;
    }
    .filters .group label.opt {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--fg-2);
      cursor: pointer;
    }
    .filters .group label.opt input { accent-color: var(--innovia-green-deep); }
    .filters .group .pills-row {
      display: flex; flex-wrap: wrap; gap: 6px;
    }
    .filters .group .pills-row button {
      padding: 6px 12px;
      background: #fff;
      border: 1px solid var(--border-subtle);
      border-radius: 999px;
      font-family: var(--font-body);
      font-size: 12px; color: var(--fg-2);
    }
    .filters .group .pills-row button:hover { border-color: var(--innovia-navy); color: var(--innovia-navy); }
    .filters .group .pills-row button.active {
      background: var(--innovia-navy); color: #fff; border-color: var(--innovia-navy);
    }

    /* Results grid */
    .results .top-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 14px 20px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
      margin-bottom: 12px;
      color: rgba(255,255,255,0.78);
    }
    .results .top-bar .count {
      font-family: var(--font-display); font-weight: 600;
      font-size: 14px; color: #fff;
    }
    .results .top-bar .count span { font-family: var(--font-mono); color: var(--innovia-green); }
    .results .top-bar .sort {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: rgba(255,255,255,0.5);
    }
    .results .top-bar .sort select {
      background: transparent; border: 0;
      font-family: var(--font-body); font-size: 13px;
      color: #fff; cursor: pointer;
    }
    .results .top-bar .sort select option { color: var(--innovia-navy); background: #fff; }
    .results .grid {
      display: grid; grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .firm-card {
      background: #FBFAF6;
      padding: 28px;
      display: flex; flex-direction: column; gap: 18px;
      transition: transform .2s;
      cursor: pointer;
    }
    .firm-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.25);
    }
    .firm-card .head {
      display: grid;
      grid-template-columns: 64px 1fr auto;
      gap: 16px;
      align-items: start;
    }
    .firm-card .head .mark {
      width: 64px; height: 64px;
      background: var(--innovia-navy);
      color: var(--innovia-green);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 800;
      font-size: 18px; letter-spacing: -0.02em;
    }
    .firm-card .head h4 {
      font-size: 22px; color: var(--innovia-navy);
      letter-spacing: -0.015em;
      margin: 0; line-height: 1.18;
    }
    .firm-card .head .loc {
      font-size: 13px; color: var(--fg-3);
      margin-top: 4px;
      display: flex; align-items: center; gap: 6px;
    }
    .firm-card .head .badge {
      font-family: var(--font-display);
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--innovia-green-deep);
      background: rgba(149,208,49,0.18);
      padding: 4px 8px;
      align-self: start;
    }
    .firm-card .stats {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      padding-top: 14px;
      border-top: 1px solid var(--border-subtle);
    }
    .firm-card .stats div { display: flex; flex-direction: column; gap: 2px; }
    .firm-card .stats .k {
      font-family: var(--font-display); font-size: 10px;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--fg-3); font-weight: 600;
    }
    .firm-card .stats .v {
      font-family: var(--font-display); font-weight: 800;
      font-size: 16px; color: var(--innovia-navy);
      letter-spacing: -0.005em;
    }
    .firm-card .services {
      display: flex; flex-wrap: wrap; gap: 6px;
    }
    .firm-card .services .svc {
      padding: 4px 10px;
      background: #fff;
      border: 1px solid var(--border-subtle);
      border-radius: 999px;
      font-size: 11px;
      color: var(--fg-2);
      letter-spacing: 0.02em;
    }
    .firm-card .foot {
      display: flex; justify-content: space-between; align-items: center;
      margin-top: 4px;
    }
    .firm-card .foot .link-arrow { font-size: 13px; padding-bottom: 3px; }

    .pagination {
      display: flex; justify-content: center; gap: 8px;
      margin-top: 32px;
    }
    .pagination .page {
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.12);
      font-family: var(--font-display); font-weight: 600;
      font-size: 13px; color: #fff;
      cursor: pointer;
    }
    .pagination .page.active { background: var(--innovia-green); color: var(--innovia-navy); border-color: var(--innovia-green); }
    .pagination .page:hover:not(.active) { border-color: var(--innovia-green); }

    /* ---------- Reassure (green block) ---------- */
    .reassure {
      padding: 120px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
    }
    .reassure .head {
      max-width: 980px;
      margin: 0 0 56px;
    }
    .reassure h2 {
      color: var(--innovia-navy);
      font-size: clamp(40px, 5.6vw, 80px);
      letter-spacing: -0.03em;
      max-width: 18ch;
    }
    .reassure .head p {
      color: var(--innovia-navy);
      opacity: 0.85;
      margin-top: 18px;
      font-size: 18px;
      line-height: 1.55;
    }
    .reassure .reasons {
      display: grid; grid-template-columns: repeat(4, 1fr);
      border-top: 2px solid var(--innovia-navy);
      border-bottom: 2px solid var(--innovia-navy);
    }
    .reassure .reason {
      padding: 40px 28px 40px;
      border-right: 1px solid rgba(24,51,94,0.18);
      display: flex; flex-direction: column; gap: 14px;
    }
    .reassure .reason:last-child { border-right: 0; }
    .reassure .reason .num {
      font-family: var(--font-display); font-weight: 900;
      font-size: 56px; line-height: 0.85;
      color: var(--innovia-navy);
      letter-spacing: -0.035em;
    }
    .reassure .reason h4 {
      font-size: 22px; color: var(--innovia-navy);
      letter-spacing: -0.015em;
      margin: 0;
    }
    .reassure .reason p {
      font-size: 14px; line-height: 1.55;
      color: var(--innovia-navy); opacity: 0.78;
      margin: 0;
    }

    @media (max-width: 1080px) {
      .page-hero .below, .map-band .frame { grid-template-columns: 1fr; gap: 24px; }
      .results-section .layout { grid-template-columns: 1fr; }
      .filters { position: static; }
      .results .grid { grid-template-columns: 1fr; }
      .reassure .reasons { grid-template-columns: repeat(2, 1fr); }
      .reassure .reason:nth-child(2) { border-right: 0; }
      .reassure .reason:nth-child(-n+2) { border-bottom: 1px solid rgba(24,51,94,0.18); }
    }

    /* ---------- Request form (replaces full directory grid) ---------- */
    .request-section {
      padding: 96px 0 120px;
      background: var(--innovia-navy);
      position: relative;
    }
    .request-section::after {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 6% 12%, rgba(149,208,49,0.10) 0%, transparent 36%),
        radial-gradient(circle at 96% 92%, rgba(42,74,120,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .request-section .container { position: relative; z-index: 1; }
    .request-section .request-layout {
      display: grid;
      grid-template-columns: 1fr 1.3fr;
      gap: 80px;
      align-items: start;
    }
    .request-aside h2 {
      color: #fff;
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(36px, 4.2vw, 56px);
      letter-spacing: -0.025em;
      line-height: 1.04;
      margin: 14px 0 0;
      max-width: 14ch;
    }
    .request-aside h2 em {
      color: var(--innovia-green);
      font-style: italic;
      font-weight: 400;
    }
    .request-aside > p {
      font-size: 17px; line-height: 1.6;
      color: rgba(255,255,255,0.78);
      max-width: 44ch;
      margin: 22px 0 0;
    }
    .request-aside .how {
      margin-top: 36px;
      display: flex; flex-direction: column;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .request-aside .step {
      padding: 22px 0;
      border-bottom: 1px solid rgba(255,255,255,0.18);
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 18px;
      align-items: start;
    }
    .request-aside .step .ix {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green); letter-spacing: 0.06em;
      padding-top: 4px;
    }
    .request-aside .step h5,
    .request-aside .step p { grid-column: 2; }
    .request-aside .step h5 {
      font-family: var(--font-display); font-weight: 700;
      font-size: 16px;
      color: #fff;
      letter-spacing: -0.005em;
      line-height: 1.3;
      margin: 0 0 4px;
    }
    .request-aside .step p {
      font-size: 13px; line-height: 1.55;
      color: rgba(255,255,255,0.65);
      margin: 0;
      max-width: 42ch;
    }

    /* The form */
    .request-form {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.14);
      padding: 36px 36px 28px;
    }
    .request-form .form-head {
      display: flex; justify-content: space-between; align-items: center;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.14);
      margin-bottom: 24px;
      font-family: var(--font-mono); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
    }
    .request-form .form-label {
      color: var(--innovia-green);
    }
    .request-form .form-count {
      color: rgba(255,255,255,0.5);
    }
    .request-form fieldset {
      border: 0;
      padding: 0;
      margin: 0 0 24px;
      display: flex; flex-direction: column;
      gap: 14px;
    }
    .request-form legend {
      font-family: var(--font-display); font-weight: 700;
      font-size: 13px;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 0 0 8px;
      margin-bottom: 4px;
      border-bottom: 1px solid rgba(255,255,255,0.10);
      width: 100%;
    }
    .request-form label {
      display: flex; flex-direction: column;
      gap: 6px;
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.65);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .request-form label .opt {
      font-family: var(--font-body);
      font-size: 10px;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.04em;
      text-transform: none;
      font-style: italic;
      margin-left: 8px;
    }
    .request-form .grid-2 {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    .request-form input,
    .request-form select,
    .request-form textarea {
      background: rgba(0,0,0,0.22);
      border: 1px solid rgba(255,255,255,0.18);
      padding: 13px 14px;
      color: #fff;
      font-family: var(--font-body);
      font-size: 15px;
      letter-spacing: 0;
      text-transform: none;
      transition: border-color .15s, box-shadow .15s;
      width: 100%;
      box-sizing: border-box;
    }
    .request-form textarea {
      resize: vertical;
      min-height: 80px;
      font-family: var(--font-body);
    }
    .request-form input:focus,
    .request-form select:focus,
    .request-form textarea:focus {
      outline: none;
      border-color: var(--innovia-green);
      box-shadow: 0 0 0 3px rgba(149,208,49,0.22);
    }
    .request-form input::placeholder,
    .request-form textarea::placeholder { color: rgba(255,255,255,0.4); }
    .request-form .submit-row {
      display: flex; justify-content: space-between; align-items: center;
      gap: 16px;
      margin-top: 8px;
      padding-top: 22px;
      border-top: 1px solid rgba(255,255,255,0.14);
    }
    .request-form .submit-row small {
      font-family: var(--font-body); font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0;
      text-transform: none;
      max-width: 44ch;
      line-height: 1.45;
    }
    .request-form button[type="submit"] {
      background: var(--innovia-green);
      color: var(--innovia-navy);
      border: 0;
      padding: 16px 26px;
      font-family: var(--font-display); font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .15s;
      display: inline-flex; align-items: center; gap: 10px;
      white-space: nowrap;
    }
    .request-form button[type="submit"]:hover { background: var(--innovia-green-deep); color: #fff; }

    @media (max-width: 1080px) {
      .request-section .request-layout { grid-template-columns: 1fr; gap: 40px; }
      .request-form .grid-2 { grid-template-columns: 1fr; }
      .request-form .submit-row { flex-direction: column; align-items: stretch; gap: 18px; }
      .request-form .submit-row small { max-width: none; }
    }

  </style>


  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <span style="color:#fff;">Looking for management</span>
        <div class="right">
          <span class="dot"></span>
          For HOA &amp; condo boards
        </div>
      </div>
      <h1>
        Looking for <em>management?</em><br>
        <span class="light">we&rsquo;ll route you to the right member.</span>
      </h1>
      <div class="below">
        <p>Innovia is a cooperative of <span class="placeholder placeholder-inline">80+</span> independently-owned management companies coast to coast. Rather than send you to a public phone-tree, we route your inquiry to the member company best positioned for your community &mdash; by region, portfolio size, and what you&rsquo;re looking for. No call lists. No pressure.</p>
        <div class="meta">
          <div class="info-row">
            <div><span class="k">Response</span><span class="v">Within 2 business days</span></div>
            <div><span class="k">Coverage</span><span class="v"><span class="placeholder placeholder-inline">38</span>&nbsp;states &middot; coast to coast</span></div>
            <div><span class="k">Cost</span><span class="v">No fee to ask</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP BAND -->
  <section class="map-band">
    <div class="container">
      <div class="frame">
        <div class="map">
          <div class="grid"></div>
          <span class="label">Member Footprint · Q1 2026</span>
          <svg class="us" viewBox="0 0 900 480" xmlns="http://www.w3.org/2000/svg">
            <path d="M 130 130 L 270 90 L 380 95 L 420 105 L 480 100 L 540 95 L 600 100 L 640 105 L 720 95 L 800 110 L 820 150 L 800 200 L 780 240 L 760 290 L 730 330 L 700 360 L 670 380 L 620 390 L 570 380 L 510 360 L 460 350 L 410 360 L 360 380 L 320 390 L 280 380 L 240 360 L 200 330 L 170 300 L 150 260 L 130 200 Z"
                  fill="none" stroke="rgba(24,51,94,0.18)" stroke-width="1.5" stroke-linejoin="round"/>
            <g>
              <circle class="pin" cx="200" cy="270" r="6" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="200" y="295">CA · 12</text>
              <circle class="pin" cx="640" cy="345" r="9" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="640" y="370">FL · 14</text>
              <circle class="pin" cx="450" cy="310" r="7" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="450" y="335">TX · 10</text>
              <circle class="pin" cx="640" cy="260" r="5" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="640" y="245">NC · 7</text>
              <circle class="pin active" cx="730" cy="220" r="8" fill="var(--innovia-green)"/>
              <text class="pin-label" x="730" y="205">NY · 9</text>
              <circle class="pin" cx="520" cy="200" r="5" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="520" y="185">IL · 6</text>
              <circle class="pin" cx="380" cy="230" r="4" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="380" y="215">CO · 5</text>
              <circle class="pin" cx="700" cy="300" r="4" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="700" y="320">GA · 5</text>
              <circle class="pin" cx="270" cy="180" r="3" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="270" y="165">WA · 3</text>
              <circle class="pin" cx="610" cy="200" r="3" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="610" y="185">OH · 4</text>
              <circle class="pin" cx="280" cy="320" r="3" fill="var(--innovia-green-deep)"/>
              <text class="pin-label" x="280" y="345">AZ · 3</text>
            </g>
          </svg>
          <div class="legend">
            <span><span class="dot"></span>Innovia-backed Company</span>
            <span>Size · No. of companies</span>
          </div>
        </div>

        <div class="stats">
          <div class="cell">
            <div class="label">Management Companies</div>
            <div class="v placeholder placeholder-inline">80<span class="pct">+</span></div>
            <div class="note">Innovia-backed</div>
          </div>
          <div class="cell">
            <div class="label">States</div>
            <div class="v placeholder placeholder-inline">38</div>
            <div class="note">Coast to coast</div>
          </div>
          <div class="cell">
            <div class="label">Households</div>
            <div class="v placeholder placeholder-inline">1.2M<span class="pct">+</span></div>
            <div class="note">Under cooperative management</div>
          </div>
          <div class="cell">
            <div class="label">Avg. tenure</div>
            <div class="v placeholder placeholder-inline">22yr</div>
            <div class="note">Management company operating history</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REQUEST FORM -->
  <section class="request-section" id="request">
    <div class="container">
      <div class="request-layout">
        <aside class="request-aside">
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 02</span><span class="rule-mini"></span>How this works</div>
          <h2>Tell us about your <em>community.</em></h2>
          <p>The cooperative routes your inquiry to the Innovia-backed company best positioned to serve your association &mdash; by geography, portfolio size, and what you&rsquo;re looking for in a manager. One company. One conversation. No sales calls from a dozen firms.</p>

          <div class="how">
            <div class="step">
              <span class="ix">01</span>
              <h5>You share a few details below.</h5>
              <p>Location, size, what you&rsquo;re looking for, and how to reach you. Three minutes.</p>
            </div>
            <div class="step">
              <span class="ix">02</span>
              <h5>We match and route.</h5>
              <p>The cooperative routes the inquiry to the member company best positioned for your community. We&rsquo;ll let you know which one.</p>
            </div>
            <div class="step">
              <span class="ix">03</span>
              <h5>They reach out. You take the meeting if it fits.</h5>
              <p>A single introduction. No call lists. No pressure. Within two business days.</p>
            </div>
          </div>
        </aside>

        <form class="request-form" onsubmit="event.preventDefault(); this.querySelector('button[type=submit]').textContent='Thanks \\u2014 we\\u2019ll be in touch within 2 business days';">
          <div class="form-head">
            <span class="form-label">Inquiry &middot; HOA / Condo Board</span>
            <span class="form-count">10 fields &middot; ~3 min</span>
          </div>

          <fieldset>
            <legend>About your community</legend>
            <div class="grid-2">
              <label>Community name
                <input type="text" placeholder="e.g. Mariner Cove HOA" autocomplete="organization" required>
              </label>
              <label>City, State
                <input type="text" placeholder="e.g. San Diego, CA" autocomplete="address-level2" required>
              </label>
            </div>
            <div class="grid-2">
              <label>Property type
                <select required>
                  <option value="">Choose one</option>
                  <option>Single-family HOA</option>
                  <option>Condominium</option>
                  <option>Townhome / planned development</option>
                  <option>Master-planned community</option>
                  <option>Mixed-use</option>
                  <option>Other</option>
                </select>
              </label>
              <label>Number of units
                <select required>
                  <option value="">Choose a range</option>
                  <option>Under 50</option>
                  <option>50&ndash;150</option>
                  <option>150&ndash;400</option>
                  <option>400&ndash;1,000</option>
                  <option>Over 1,000</option>
                </select>
              </label>
            </div>
          </fieldset>

          <fieldset>
            <legend>Your situation</legend>
            <div class="grid-2">
              <label>Current management
                <select required>
                  <option value="">Choose one</option>
                  <option>Self-managed today</option>
                  <option>Working with a company we&rsquo;re evaluating changing</option>
                  <option>Between management companies</option>
                  <option>Newly forming / pre-management</option>
                  <option>Just exploring</option>
                </select>
              </label>
              <label>Timeline
                <select required>
                  <option value="">Choose one</option>
                  <option>Immediate &middot; within 30 days</option>
                  <option>Soon &middot; 1&ndash;3 months</option>
                  <option>This year &middot; 3&ndash;12 months</option>
                  <option>Just exploring</option>
                </select>
              </label>
            </div>
            <label>Anything specific we should know? <span class="opt">Optional</span>
              <textarea rows="3" placeholder="Concerns about your current arrangement, what matters most to your community, anything we should pass along"></textarea>
            </label>
          </fieldset>

          <fieldset>
            <legend>How to reach you</legend>
            <div class="grid-2">
              <label>Your name
                <input type="text" placeholder="Jordan Reyes" autocomplete="name" required>
              </label>
              <label>Role on the board
                <select required>
                  <option value="">Choose one</option>
                  <option>President</option>
                  <option>Vice President</option>
                  <option>Treasurer</option>
                  <option>Secretary</option>
                  <option>Board member</option>
                  <option>Property manager / staff</option>
                  <option>Other</option>
                </select>
              </label>
            </div>
            <div class="grid-2">
              <label>Email
                <input type="email" placeholder="you@yourcommunity.org" autocomplete="email" required>
              </label>
              <label>Phone <span class="opt">Optional</span>
                <input type="tel" placeholder="(555) 555-0123" autocomplete="tel">
              </label>
            </div>
          </fieldset>

          <div class="submit-row">
            <small>Your details go to Innovia Co-op only. We share with the matched member company; we don&rsquo;t sell to vendors.</small>
            <button type="submit">
              Send the inquiry
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- BROWSE BY STATE -->
  <section style="padding: 80px 0 0; background: var(--innovia-navy);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start;">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 03</span><span class="rule-mini"></span>Or browse by state</div>
          <h2 style="color: #fff; font-family: var(--font-display); font-weight: 700; font-size: clamp(32px, 4vw, 48px); letter-spacing: -0.022em; line-height: 1.04; margin: 14px 0 14px; max-width: 14ch;">Prefer to look around first?</h2>
          <p style="font-size: 16px; line-height: 1.6; color: rgba(255,255,255,0.74); max-width: 42ch; margin: 0;">Each state hub lists the Innovia-backed companies operating there, with metro-level sub-pages for the major markets.</p>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
          <a href="/find-a-management-company/texas/" style="padding: 22px 22px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit; transition: border-color .15s, background .15s;">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase;">Texas</span>
            <span style="font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff; letter-spacing: -0.008em;"><span class="placeholder placeholder-inline">10</span> member companies</span>
            <span style="font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em;">5 metros &middot; <span class="placeholder placeholder-inline">280K+</span> households</span>
          </a>
          <a href="/find-a-management-company/colorado/" style="padding: 22px 22px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit;">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase;">Colorado</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff;">8 member companies</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em;">3 metros</span>
          </a>
          <a href="/find-a-management-company/florida/" style="padding: 22px 22px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit;">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase;">Florida</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff;">14 member companies</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em;">4 metros</span>
          </a>
          <a href="/find-a-management-company/north-carolina/" style="padding: 22px 22px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit;">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase;">North Carolina</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff;">7 member companies</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em;">2 metros</span>
          </a>
          <a href="/find-a-management-company/arizona/" style="padding: 22px 22px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit;">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase;">Arizona</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff;">5 member companies</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em;">2 metros</span>
          </a>
          <a href="/find-a-management-company/georgia/" style="padding: 22px 22px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.14); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit;">
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase;">Georgia</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff;">5 member companies</span>
            <span class="placeholder placeholder-inline" style="font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em;">2 metros</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- REASSURE (green) -->
  <section class="reassure">
    <div class="container">
      <div class="head">
        <div class="eyebrow" style="color: var(--innovia-navy); opacity: 0.65;"><span class="num" style="color: var(--innovia-navy);">No. 03</span><span class="rule-mini"></span>Why an Innovia member firm</div>
        <h2 style="margin-top: 14px;">Elite communities deserve <em>elite management.</em></h2>
        <p>Every Innovia management company is independently owned &mdash; and backed by a cooperative that trains their managers, negotiates better vendor terms for the communities they serve, and shares intelligence from across the country.</p>
      </div>
      <div class="reasons">
        <div class="reason">
          <div class="num">01</div>
          <h4>Better-trained managers</h4>
          <p>Innovia management companies have access to peer cohorts, the Innovia Academy, and certification programs that solo independents can&rsquo;t offer.</p>
        </div>
        <div class="reason">
          <div class="num">02</div>
          <h4>Better vendor pricing</h4>
          <p>Cooperative-negotiated rates with industry-vetted partners &mdash; passed through to your reserve and operating budgets.</p>
        </div>
        <div class="reason">
          <div class="num">03</div>
          <h4>Better benchmarking</h4>
          <p>Innovia management companies benchmark against 1.2M+ households of cooperative data. Your community gets the median, not a guess.</p>
        </div>
        <div class="reason">
          <div class="num">04</div>
          <h4>Independence preserved</h4>
          <p>Innovia management companies aren&rsquo;t franchise locations of a national. They&rsquo;re local operators with national resources &mdash; service stays local.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  


  
`;
