---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    .site-header { background: rgba(15,36,71,0.94); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10); }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); color: var(--innovia-navy); }

    .page-hero { padding: 56px 0 56px; position: relative; overflow: hidden; }
    .page-hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 92% 8%, rgba(149,208,49,0.14) 0%, transparent 38%), radial-gradient(circle at 4% 96%, rgba(42,74,120,0.5) 0%, transparent 50%); pointer-events: none; }
    .page-hero .container { position: relative; z-index: 1; }
    .page-hero .crumb { display: flex; gap: 10px; align-items: center; font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.18); margin-bottom: 36px; }
    .page-hero .crumb a:hover { color: #fff; }
    .page-hero h1 { font-family: var(--font-display); font-weight: 900; font-size: clamp(48px, 6vw, 88px); letter-spacing: -0.034em; color: #fff; line-height: 1; margin: 0; text-wrap: balance; }
    .page-hero h1 em { color: var(--innovia-green); font-style: normal; }
    .page-hero h1 .light { display: block; margin-top: 8px; font-family: var(--font-body); font-weight: 300; font-style: italic; color: rgba(255,255,255,0.55); font-size: 0.48em; letter-spacing: -0.02em; }
    .page-hero .lede { font-size: 17px; line-height: 1.62; color: rgba(255,255,255,0.78); max-width: 56ch; margin: 24px 0 0; }
    
  
    .state-snapshot { padding: 24px 0 32px; }
    .state-snapshot .row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 0; border-top: 2px solid var(--innovia-green); border-bottom: 1px solid rgba(255,255,255,0.18); padding: 28px 0; }
    .state-snapshot .cell { padding: 0 32px; border-right: 1px solid rgba(255,255,255,0.10); display: flex; flex-direction: column; gap: 6px; }
    .state-snapshot .cell:last-child { border-right: 0; }
    .state-snapshot .num { font-family: var(--font-display); font-weight: 900; font-size: 44px; line-height: 0.9; color: #fff; letter-spacing: -0.03em; }
    .state-snapshot .num .pct { color: var(--innovia-green); }
    .state-snapshot .label { font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,0.55); letter-spacing: 0.12em; text-transform: uppercase; }
    .state-snapshot .note { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; }

    .city-grid { padding: 56px 0; }
    .city-grid .head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 24px; }
    .city-grid h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 3vw, 38px); color: #fff; letter-spacing: -0.018em; margin: 0; }
    .city-grid .head p { color: rgba(255,255,255,0.55); font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; }
    .city-grid .row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
    .city-grid .city { padding: 22px 22px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit; transition: border-color .15s, background .15s; }
    .city-grid .city:hover { border-color: var(--innovia-green); background: rgba(149,208,49,0.06); }
    .city-grid .city .name { font-family: var(--font-display); font-weight: 700; font-size: 19px; color: #fff; letter-spacing: -0.008em; }
    .city-grid .city .meta { font-family: var(--font-mono); font-size: 10px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; }

    .member-list { padding: 56px 0 96px; }
    .member-list .head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 24px; }
    .member-list h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 3vw, 38px); color: #fff; letter-spacing: -0.018em; margin: 0; }
    .member-list .head p { color: rgba(255,255,255,0.55); font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; }
    .member-list .table { border-top: 1px solid rgba(255,255,255,0.18); }
    .member-list .firm { display: grid; grid-template-columns: 48px 1.4fr 1fr 1fr auto; gap: 24px; padding: 22px 0; border-bottom: 1px solid rgba(255,255,255,0.12); align-items: center; text-decoration: none; color: inherit; transition: background .15s; }
    .member-list .firm:hover { background: rgba(149,208,49,0.04); }
    .member-list .firm .mark { width: 44px; height: 44px; background: rgba(149,208,49,0.16); color: var(--innovia-green); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 800; font-size: 14px; }
    .member-list .firm .name { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff; letter-spacing: -0.008em; }
    .member-list .firm .city-text { font-size: 14px; color: rgba(255,255,255,0.7); }
    .member-list .firm .tags { font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; }
    .member-list .firm .go { font-family: var(--font-mono); font-size: 11px; color: var(--innovia-green); letter-spacing: 0.12em; text-transform: uppercase; }

    .state-cta { padding: 96px 0; background: var(--innovia-green); color: var(--innovia-navy); }
    .state-cta .frame { display: grid; grid-template-columns: 1.4fr 1fr; gap: 64px; align-items: center; }
    .state-cta h2 { font-family: var(--font-display); font-weight: 700; font-size: clamp(34px, 4vw, 52px); color: var(--innovia-navy); letter-spacing: -0.022em; margin: 0; max-width: 18ch; }
    .state-cta h2 em { font-style: italic; font-weight: 400; }
    .state-cta p { font-size: 16px; line-height: 1.55; margin: 20px 0 0; max-width: 50ch; }
    .state-cta .actions { display: flex; flex-direction: column; gap: 12px; }
    .state-cta .actions .btn { justify-content: center; padding: 16px 24px; font-size: 15px; }

    @media (max-width: 1080px) {
      .state-snapshot .row, .city-grid .row { grid-template-columns: 1fr 1fr; gap: 12px; }
      .state-snapshot .cell { border-right: 0; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.10); }
      .member-list .firm { grid-template-columns: 44px 1fr; gap: 14px; }
      .member-list .firm .city-text, .member-list .firm .tags, .member-list .firm .go { grid-column: 2; }
      .state-cta .frame { grid-template-columns: 1fr; gap: 32px; }
    }
  </style>



  <section class="page-hero">
    <div class="container">
      
      <div class="crumb">
        <a href="/">Innovia</a>
        <span>/</span>
        <a href="/find-a-management-company/">For Boards</a>
        <span>/</span>
        <span style="color:#fff;">Texas</span>
      </div>
      <h1>HOA management companies <em>in Texas.</em><span class="light">cooperative-backed. locally operated. four major metros.</span></h1>
      <p class="lede">Innovia-backed management companies serving Texas associations from <span class="placeholder placeholder-inline">[count]</span>&nbsp;offices across the state. Every one is independently owned and locally operated &mdash; with the cooperative&rsquo;s national resources behind every contract.</p>
    </div>
  </section>

  <section class="state-snapshot">
    <div class="container">
      <div class="row">
        <div class="cell"><span class="num placeholder placeholder-inline">10</span><span class="label">Member companies</span><span class="note">in Texas</span></div>
        <div class="cell"><span class="num placeholder placeholder-inline">280K<span class="pct">+</span></span><span class="label">Households served</span><span class="note">across the state</span></div>
        <div class="cell"><span class="num placeholder placeholder-inline">5</span><span class="label">Metro areas</span><span class="note">with member offices</span></div>
        <div class="cell"><span class="num"><span class="placeholder placeholder-inline">2</span> bus. days</span><span class="label">Response time</span><span class="note">average for inquiries</span></div>
      </div>
    </div>
  </section>

  <section class="city-grid">
    <div class="container">
      <div class="head">
        <h2>Find a manager by city.</h2>
        <p>5 metro hubs</p>
      </div>
      <div class="row">
        
        <a class="city" href="/find-a-management-company/texas/austin/">
          <span class="meta placeholder placeholder-inline">Austin metro</span>
          <span class="name">Austin</span>
          <span class="meta" style="color:rgba(255,255,255,0.5);">Travis County</span>
        </a>
        <a class="city" href="/find-a-management-company/texas/houston/">
          <span class="meta placeholder placeholder-inline">Austin metro</span>
          <span class="name">Houston</span>
          <span class="meta" style="color:rgba(255,255,255,0.5);">Harris County</span>
        </a>
        <a class="city" href="/find-a-management-company/texas/dallas/">
          <span class="meta placeholder placeholder-inline">Austin metro</span>
          <span class="name">Dallas</span>
          <span class="meta" style="color:rgba(255,255,255,0.5);">Dallas&ndash;FW Metroplex</span>
        </a>
        <a class="city" href="/find-a-management-company/texas/san-antonio/">
          <span class="meta placeholder placeholder-inline">Austin metro</span>
          <span class="name">San Antonio</span>
          <span class="meta" style="color:rgba(255,255,255,0.5);">Bexar County</span>
        </a>
        <a class="city" href="/find-a-management-company/texas/fort-worth/">
          <span class="meta placeholder placeholder-inline">Austin metro</span>
          <span class="name">Fort Worth</span>
          <span class="meta" style="color:rgba(255,255,255,0.5);">Tarrant County</span>
        </a>
      </div>
    </div>
  </section>

  <section class="member-list">
    <div class="container">
      <div class="head">
        <h2>Texas member companies.</h2>
        <p><span class="placeholder placeholder-inline">10</span>&nbsp;listed &middot; updated weekly</p>
      </div>
      <div class="table">
        
        <a class="firm" href="https://innoviaco-op.com/blog/" target="_blank" rel="noopener">
          <span class="mark">NA</span>
          <span class="name">Nova Association Management Partners</span>
          <span class="city-text">Austin, TX</span>
          <span class="tags">Single-family · Master-planned · 15K+ households</span>
          <span class="go">View &rarr;</span>
        </a>
        <a class="firm" href="https://innoviaco-op.com/blog/" target="_blank" rel="noopener">
          <span class="mark">AMG</span>
          <span class="name">Association Management Group</span>
          <span class="city-text">Dallas, TX</span>
          <span class="tags">Condo · Single-family · 8K households</span>
          <span class="go">View &rarr;</span>
        </a>
        <a class="firm" href="#" >
          <span class="mark">RC</span>
          <span class="name placeholder placeholder-inline">Rocky Creek Association Management</span>
          <span class="city-text">Austin, TX</span>
          <span class="tags placeholder placeholder-inline">Townhome · Single-family</span>
          <span class="go">View &rarr;</span>
        </a>
        <a class="firm" href="#" >
          <span class="mark">SC</span>
          <span class="name placeholder placeholder-inline">Sunbelt Communities Management</span>
          <span class="city-text">Houston, TX</span>
          <span class="tags placeholder placeholder-inline">Master-planned · 20K+ households</span>
          <span class="go">View &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="state-cta">
    <div class="container">
      <div class="frame">
        <div>
          <h2>Skip the list. <em>Tell us about your community</em> and we&rsquo;ll route you.</h2>
          <p>One inquiry, one match. The Innovia-backed Texas member best positioned to serve your association &mdash; by region, portfolio size, and what your board is looking for.</p>
        </div>
        <div class="actions">
          <a href="/find-a-management-company/#request" class="btn btn-navy">Send the inquiry
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
          <a href="/hoa-management-services/" class="btn btn-outline" style="color: var(--innovia-navy); border-color: var(--innovia-navy);">Services overview</a>
        </div>
      </div>
    </div>
  </section>

  


  
`;
---
<BaseLayout
  title="HOA Management Companies in Texas · Innovia Co-op"
  description="HOA Management Companies in Texas · Innovia Co-op"
  ogImage="/assets/og/option-1-type-led.png"
  ctaLabel="Send Inquiry"
  ctaHref="/find-a-management-company/#request"
>
  <Fragment set:html={html} />
</BaseLayout>
