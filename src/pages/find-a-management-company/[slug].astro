---
// Dynamic page: one static landing page per member in src/data/members.ts
// Output URL: /find-a-management-company/<slug>/
import MemberLanding from "../../components/MemberLanding.astro";
import { members } from "../../data/members";

// Site runs in `output: 'server'` mode — prerender these data-driven
// landing pages to static HTML at build time so getStaticPaths() applies.
export const prerender = true;

export function getStaticPaths() {
  return members.map((member) => ({
    params: { slug: member.slug },
    props: { member },
  }));
}

const { member } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{member.metaTitle}</title>
    <meta name="description" content={member.metaDescription} />
    <link rel="canonical" href={member.canonical} />
    <link rel="icon" type="image/png" href="/assets/innovia-icon.png" />
    <link rel="apple-touch-icon" href="/assets/innovia-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={member.metaTitle} />
    <meta property="og:description" content={member.metaDescription} />
    <meta property="og:url" content={member.canonical} />
    {member.ogImage && <meta property="og:image" content={member.ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body data-screen-label="Member Landing">
    <MemberLanding member={member} />
  </body>
</html>
