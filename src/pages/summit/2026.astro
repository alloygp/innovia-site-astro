---
import BaseLayout from '../../layouts/BaseLayout.astro';
const html = `<style>
    body { background: var(--innovia-navy); color: rgba(255,255,255,0.78); }
    /* Solid navy nav (matches other pages) — beats the global .site-header.inverse transparent rule */
    .site-header, .site-header.inverse {
      background: rgba(15,36,71,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .site-header nav > a { color: rgba(255,255,255,0.7); }
    .site-header nav > a:hover, .site-header nav > a.active { color: #fff; }
    .site-header .btn-navy { background: #fff; color: var(--innovia-navy); }
    .site-header .btn-navy:hover { background: var(--innovia-green); }

    /* ---------- Summit hero ---------- */
    .summit-hero {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: 40px 0 96px;
    }
    .summit-hero .bg { position: absolute; inset: 0; z-index: -2; }
    .summit-hero .bg img {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.92);
    }
    .summit-hero .bg::after {
      content: ""; position: absolute; inset: 0;
      background:
        linear-gradient(105deg, rgba(15,36,71,0.92) 0%, rgba(15,36,71,0.45) 65%, rgba(15,36,71,0.62) 100%),
        linear-gradient(180deg, transparent 50%, rgba(15,36,71,0.6) 100%);
    }
    .summit-hero .crumb {
      display: flex; gap: 10px; align-items: center;
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.04em;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.18);
      margin-bottom: 64px;
    }
    .summit-hero .crumb a:hover { color: #fff; }
    .summit-hero .summit-mark {
      font-family: var(--font-summit);
      font-weight: 700;
      font-size: clamp(56px, 8vw, 132px);
      line-height: 0.9;
      letter-spacing: 0.04em;
      color: #fff;
      text-transform: uppercase;
      margin: 0;
    }
    .summit-hero .summit-mark .yr {
      color: var(--innovia-green);
    }
    .summit-hero .summit-mark .summit-logo {
      display: block;
      width: auto;
      max-width: min(300px, 64vw);
      height: auto;
      margin: 8px 0 4px;
    }
    .summit-hero .row {
      display: grid; grid-template-columns: 1.4fr 1fr;
      gap: 80px; align-items: end;
      margin-top: 32px;
      padding-top: 32px;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .summit-hero .row p {
      font-size: clamp(17px, 1.4vw, 20px);
      line-height: 1.55;
      color: rgba(255,255,255,0.82);
      max-width: 52ch;
      margin: 0;
    }
    .summit-hero .row .meta {
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
    }
    .summit-hero .row .meta > div {
      display: flex; flex-direction: column; gap: 6px;
    }
    .summit-hero .row .meta .k {
      font-family: var(--font-display); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .summit-hero .row .meta .v {
      font-family: var(--font-display); font-weight: 700;
      font-size: 16px; color: #fff;
      letter-spacing: -0.005em;
    }

    /* ---------- Editorial recap intro ---------- */
    .recap-intro {
      padding: 120px 0;
      background: #FBFAF6;
      color: var(--fg-2);
    }
    .recap-intro .layout {
      display: grid; grid-template-columns: 1fr 1.5fr;
      gap: 96px;
      align-items: start;
    }
    .recap-intro h2 {
      color: var(--innovia-navy);
      font-size: clamp(34px, 4vw, 56px);
      letter-spacing: -0.026em;
      margin: 14px 0 0;
      max-width: 14ch;
    }
    .recap-intro .body p {
      font-size: 18px;
      line-height: 1.7;
      color: var(--fg-2);
      margin: 0 0 18px;
    }
    .recap-intro .body p:first-child::first-letter {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 88px;
      float: left;
      line-height: 0.78;
      margin: 8px 14px 0 0;
      color: var(--innovia-navy);
    }
    .recap-intro .body .pull {
      font-family: var(--font-display); font-weight: 500;
      font-size: clamp(24px, 2.2vw, 30px);
      line-height: 1.35;
      letter-spacing: -0.015em;
      color: var(--innovia-navy);
      padding: 24px 0 28px;
      margin: 28px 0;
      border-top: 4px solid var(--innovia-green);
      border-bottom: 1px solid var(--border-subtle);
      max-width: 36ch;
    }

    /* ---------- Agenda ---------- */
    .agenda {
      padding: 120px 0;
      background: var(--innovia-navy);
    }
    .agenda .head {
      display: grid; grid-template-columns: 1fr 1.4fr;
      gap: 64px; align-items: end;
      margin-bottom: 64px;
    }
    .agenda h2 { color: #fff; }
    .agenda .head p { color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.6; }
    .agenda .days {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-top: 2px solid var(--innovia-green);
    }
    .agenda .day {
      padding: 36px 32px 40px;
      border-right: 1px solid rgba(255,255,255,0.18);
      display: flex; flex-direction: column;
      gap: 18px;
    }
    .agenda .day:last-child { border-right: 0; }
    .agenda .day .date {
      font-family: var(--font-mono); font-size: 12px;
      color: var(--innovia-green); letter-spacing: 0.06em;
    }
    .agenda .day h3 {
      color: #fff; font-size: 26px;
      letter-spacing: -0.015em;
      margin: 0;
    }
    .agenda .day p {
      font-size: 15px;
      color: rgba(255,255,255,0.74);
      line-height: 1.55;
      margin: 0;
    }
    .agenda .day .schedule {
      margin-top: 8px;
      display: flex; flex-direction: column; gap: 14px;
    }
    .agenda .day .item {
      display: grid; grid-template-columns: 64px 1fr;
      gap: 16px;
      padding: 14px 0;
      border-top: 1px solid rgba(255,255,255,0.12);
      align-items: start;
    }
    .agenda .day .item:first-of-type { border-top: 0; }
    .agenda .day .item .time {
      font-family: var(--font-mono); font-size: 11px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.04em;
      padding-top: 2px;
    }
    .agenda .day .item .what {
      font-family: var(--font-display); font-weight: 600;
      font-size: 14px; color: #fff;
      letter-spacing: -0.005em;
      line-height: 1.4;
    }
    .agenda .day .item .what small {
      display: block; font-family: var(--font-body); font-weight: 400;
      color: rgba(255,255,255,0.6); font-size: 13px;
      margin-top: 2px;
    }

    /* ---------- Speaker / session highlights ---------- */
    .sessions {
      padding: 120px 0;
      background: #0c1d3a;
    }
    .sessions .head {
      display: flex; justify-content: space-between; align-items: end;
      margin-bottom: 56px;
    }
    .sessions h2 { color: #fff; }
    .sessions .grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.18);
    }
    .sessions .session {
      padding: 36px 32px 40px 0;
      border-bottom: 1px solid rgba(255,255,255,0.18);
      display: flex; flex-direction: column; gap: 16px;
    }
    .sessions .session + .session { padding-left: 32px; border-left: 1px solid rgba(255,255,255,0.18); }
    .sessions .session:nth-child(3n+1):not(:first-child) {
      border-left: 0; padding-left: 0;
    }
    .sessions .session .photo {
      aspect-ratio: 4/3;
      background: var(--innovia-navy);
      overflow: hidden;
    }
    .sessions .session .photo img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.92); }
    .sessions .session .num {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--innovia-green); letter-spacing: 0.06em;
    }
    .sessions .session h4 {
      font-size: 22px; color: #fff;
      letter-spacing: -0.014em;
      margin: 0;
      line-height: 1.2;
    }
    .sessions .session p {
      font-size: 14px; line-height: 1.55;
      color: rgba(255,255,255,0.7);
      margin: 0;
    }
    .sessions .session .speaker {
      margin-top: auto;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.12);
      font-size: 12px;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    /* ---------- Photo wall ---------- */
    .photo-wall {
      padding: 120px 0;
      background: var(--innovia-navy-deep);
    }
    .photo-wall .head {
      display: flex; justify-content: space-between; align-items: end;
      margin-bottom: 32px;
    }
    .photo-wall h2 { color: #fff; }
    .photo-wall .count {
      font-family: var(--font-mono); font-size: 12px;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.04em;
    }
    .photo-wall .gallery {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      grid-auto-rows: 160px;
      gap: 4px;
    }
    .photo-wall .gallery figure { margin: 0; overflow: hidden; background: #18335E; position: relative; }
    .photo-wall .gallery figure img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.9); transition: transform .6s var(--ease-out); }
    .photo-wall .gallery figure:hover img { transform: scale(1.04); }
    .photo-wall .gallery .lg { grid-column: span 4; grid-row: span 2; }
    .photo-wall .gallery .md { grid-column: span 2; grid-row: span 2; }
    .photo-wall .gallery .wd { grid-column: span 2; }
    .photo-wall .gallery .tl { grid-row: span 2; }
    .photo-wall .gallery figcaption {
      position: absolute; bottom: 10px; left: 12px;
      font-family: var(--font-mono); font-size: 10px;
      color: rgba(255,255,255,0.85);
      letter-spacing: 0.04em;
    }

    /* ---------- Save the date ---------- */
    .save-date {
      padding: 120px 0;
      background: var(--innovia-green);
      color: var(--innovia-navy);
      position: relative; overflow: hidden;
    }
    .save-date .frame {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .save-date .summit-mark {
      font-family: var(--font-summit);
      font-weight: 700;
      font-size: clamp(56px, 8vw, 140px);
      line-height: 0.88;
      letter-spacing: 0.02em;
      color: var(--innovia-navy);
      text-transform: uppercase;
      margin: 0;
    }
    .save-date .summit-mark .yr { color: #fff; }
    .save-date .copy h2 {
      color: var(--innovia-navy);
      font-size: clamp(34px, 4vw, 52px);
      letter-spacing: -0.024em;
    }
    .save-date .copy p {
      font-size: 17px;
      line-height: 1.6;
      margin: 20px 0;
      max-width: 50ch;
      color: var(--innovia-navy);
      opacity: 0.85;
    }
    .save-date .copy .pulses {
      display: flex; gap: 28px;
      padding-top: 20px;
      border-top: 2px solid var(--innovia-navy);
      margin-top: 24px;
    }
    .save-date .copy .pulses > div {
      display: flex; flex-direction: column; gap: 4px;
    }
    .save-date .copy .pulses .k {
      font-family: var(--font-display); font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--innovia-navy); opacity: 0.65;
    }
    .save-date .copy .pulses .v {
      font-family: var(--font-display); font-weight: 700;
      font-size: 17px; color: var(--innovia-navy);
    }
    .save-date .copy .actions {
      margin-top: 32px;
      display: flex; gap: 12px; flex-wrap: wrap;
    }
    .save-date .copy .btn-navy { background: var(--innovia-navy); color: #fff; }
    .save-date .copy .btn-navy:hover { background: var(--innovia-navy-deep); }
    .save-date .copy .btn-outline { border-color: var(--innovia-navy); color: var(--innovia-navy); }

    @media (max-width: 1080px) {
      .summit-hero .row, .recap-intro .layout, .agenda .head, .sessions .head, .save-date .frame { grid-template-columns: 1fr; gap: 32px; }
      .agenda .days { grid-template-columns: 1fr; }
      .agenda .day { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.18); }
      .sessions .grid { grid-template-columns: 1fr; }
      .sessions .session + .session { border-left: 0; padding-left: 0; }
      .photo-wall .gallery { grid-template-columns: repeat(3, 1fr); }
      .photo-wall .gallery .lg, .photo-wall .gallery .md, .photo-wall .gallery .wd { grid-column: span 3; }
    }
  </style>


  <!-- HERO -->
  <section class="summit-hero">
    <div class="bg" aria-hidden="true">
      <img src="/assets/photos/lido-house-newport-beach.jpg" alt="Lido House, Newport Beach">
    </div>
    <div class="container">
      <div class="crumb">
        <a href="/">Innovia</a><span style="color: rgba(255,255,255,0.3);">/</span><a href="/summit/" style="color: rgba(255,255,255,0.7);">Summit</a><span style="color: rgba(255,255,255,0.3);">/</span><span style="color: #fff">2026 Archive</span>
        <span style="flex: 1;"></span>
        <a href="/summit/" style="color: var(--innovia-green); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;">
          Summit 2027 →
        </a>
      </div>

      <!-- Summit 2026 official logo lockup -->
      <h1 class="summit-mark">
        <img class="summit-logo" src="/assets/logos/summit-2026-logo.png" alt="Innovia Summit 2026 · Newport Beach, CA">
      </h1>

      <div class="row">
        <p>The Innovia Summit is the closed-door annual convening where the cooperative becomes a single body &mdash; founder-only sessions, candid working groups, and the unhurried hospitality of a yacht-club retreat.</p>
        <div class="meta">
          <div><span class="k">Edition</span><span class="v">Annual Summit</span></div>
          <div><span class="k">Venue</span><span class="v">Lido House · Newport Beach</span></div>
          <div><span class="k">Attendees</span><span class="v">45</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECAP INTRO -->
  <section class="recap-intro">
    <div class="container">
      <div class="layout">
        <div>
          <div class="eyebrow"><span class="num">No. 01</span><span class="rule-mini"></span>2026 Recap</div>
          <h2>Three days. One cooperative.</h2>
        </div>
        <div class="body">
          <p>
            The 2026 Summit gathered 45 member-company founders and senior operators at the Lido House in Newport Beach for three days of working sessions, founder-only conversations, and the kind of unhurried networking that calls and emails can&rsquo;t reproduce.
          </p>
          <p>
            The format is deliberately spare. No vendor booths. No sponsor floors. No tracks of fifty parallel sessions. Just one room, the whole co-op, the topics members raised in the months before, and time to actually work through them. The hospitality &mdash; the rooftop reception, the firepit dinners, the morning runs along the harbor &mdash; is the connective tissue.
          </p>
          <p class="pull">
            &ldquo;No noise. No vendor floors. No filler. Just focused conversation, meaningful connection, and forward momentum.&rdquo;
          </p>
          <p>
            By Tuesday afternoon members were trading new banking terms in the lobby. By Wednesday morning two companies had quietly started a shared talent pipeline. By Thursday night the playbook for next year had already been roughed out at a firepit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AGENDA -->
  <section class="agenda">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 02</span><span class="rule-mini"></span>The 2026 program</div>
          <h2 class="t-h2" style="margin-top: 14px;">A working agenda.</h2>
        </div>
        <p>Built from member-submitted topics. Closed-door, Chatham House rules. Everything below is post-event detail; the live agenda is shared with attendees in advance.</p>
      </div>

      <div class="days">
        <div class="day">
          <span class="date">Wed · 4 Feb 2026 · Day 01</span>
          <h3>Arrivals &amp; welcome</h3>
          <p>Members travel in from 31 companies across 25+ states. The cooperative opens the way it always does &mdash; in person, over drinks, before the work begins.</p>
          <div class="schedule">
            <div class="item">
              <span class="time">17:00</span>
              <span class="what">Welcome reception <small>Sponsored by Vantaca</small></span>
            </div>
          </div>
        </div>

        <div class="day">
          <span class="date">Thu · 5 Feb 2026 · Day 02</span>
          <h3>State of the Co-Op &amp; breakouts</h3>
          <p>The full program day: the State of the Co-Op, four rotating breakout tracks every attendee moved through, and the member banquet to close.</p>
          <div class="schedule">
            <div class="item">
              <span class="time">09:00</span>
              <span class="what">State of the Co-Op <small>Co-op leadership</small></span>
            </div>
            <div class="item">
              <span class="time">10:00</span>
              <span class="what">Breakout sessions 1&ndash;4 · rotating <small>Every attendee through all four tracks</small></span>
            </div>
            <div class="item">
              <span class="time">16:00</span>
              <span class="what">First Citizens Bank session <small>Banking &amp; treasury</small></span>
            </div>
            <div class="item">
              <span class="time">18:00</span>
              <span class="what">Cocktails &amp; member banquet <small>Sponsored by First Citizens Bank</small></span>
            </div>
          </div>
        </div>

        <div class="day">
          <span class="date">Fri · 6 Feb 2026 · Day 03</span>
          <h3>Recaps &amp; the road ahead</h3>
          <p>Facilitators and team captains recap each track, the cooperative introduces Alloy Growth Partners as its new agency, and the Summit closes on the Lido Lawn.</p>
          <div class="schedule">
            <div class="item">
              <span class="time">09:00</span>
              <span class="what">General session &amp; panel recaps <small>Facilitators &amp; team captains</small></span>
            </div>
            <div class="item">
              <span class="time">14:00</span>
              <span class="what">Closing reception <small>Sponsored by SmartProperty</small></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SESSIONS -->
  <section class="sessions" id="sessions">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 03</span><span class="rule-mini"></span>Session highlights</div>
          <h2 class="t-h2" style="margin-top: 14px;">Six sessions that landed.</h2>
        </div>
        <p style="max-width: 34ch; color: rgba(255,255,255,0.7); font-size: 15px; line-height: 1.6;">Four professional facilitators guided rotating focus groups on Day 2, and every attendee moved through all four tracks.</p>
      </div>
      <div class="grid">
        <article class="session">
          <div class="photo"><img src="/assets/photos/speaker-rocket-launch.jpg" alt=""></div>
          <span class="num">Plenary · Day 02</span>
          <h4>State of the Co-Op</h4>
          <p>Day 2 opened with a candid look at where Innovia stands &mdash; the Member Portal in development and the 2026 priorities: expanded focus groups, portal build-out, and a national industry perception campaign.</p>
          <div class="speaker">Co-op leadership &middot; plenary</div>
        </article>
        <article class="session">
          <div class="photo"><img src="/assets/photos/speaker-finance.jpg" alt=""></div>
          <span class="num">Track 01 · Technology</span>
          <h4>Technology, AI &amp; Digital Transformation</h4>
          <p>Members moved past experimentation into measurable wins: company-specific AI trained on governing docs, voice assistants fielding routine calls, and freed capacity redeployed into high-touch &ldquo;Ambassador&rdquo; roles.</p>
          <div class="speaker">Facilitated by Marty Stowe &middot; Vistage Chair, former CEO &amp; COO</div>
        </article>
        <article class="session">
          <div class="photo"><img src="/assets/photos/panel-discussion.jpg" alt=""></div>
          <span class="num">Track 02 · Revenue</span>
          <h4>Financial Innovation, Revenue &amp; Partnerships</h4>
          <p>A three-level profit model: plug scope-creep leaks, layer in Schedule A add-ons, and build new revenue streams. Refreshed contracts, billing-capture logs, and a 30% incentive on billed extras led the takeaways.</p>
          <div class="speaker">Facilitated by Mark Murphy &middot; Vistage Chair, former CEO, COO &amp; CFO</div>
        </article>
        <article class="session">
          <div class="photo"><img src="/assets/photos/audience-listening.jpg" alt=""></div>
          <span class="num">Track 03 · Talent</span>
          <h4>HR, Talent Management &amp; Scalability</h4>
          <p>Hire for attitude over experience. Pre-interview assessments, sourcing from hospitality and retail, and structured check-ins that catch burnout early &mdash; built on a Hire, Retention, Culture, Scalability framework.</p>
          <div class="speaker">Facilitated by Tri Nguyen &middot; Vistage Chair, former SVP of HR</div>
        </article>
        <article class="session">
          <div class="photo"><img src="/assets/photos/roundtable-discussion.jpg" alt=""></div>
          <span class="num">Track 04 · Metrics</span>
          <h4>Business Intelligence &amp; Performance Metrics</h4>
          <p>Target a 20&ndash;25% minimum client margin, forecast with weighted pipelines, and use Power BI over Vantaca and QuickBooks for profit by client, manager, and service line. The right metrics, acted on.</p>
          <div class="speaker">Facilitated by Manvir Heir &middot; Founder &amp; CEO, CAM Advisors</div>
        </article>
        <article class="session">
          <div class="photo"><img src="/assets/photos/working-session.jpg" alt=""></div>
          <span class="num">Recaps · Day 03</span>
          <h4>Panel recaps &amp; the road ahead</h4>
          <p>Facilitators and team captains recapped each track&rsquo;s takeaways, and the cooperative introduced Alloy Growth Partners as its new agency for national campaigns and shared digital resources.</p>
          <div class="speaker">Facilitators &amp; team captains</div>
        </article>
      </div>
    </div>
  </section>

  <!-- PHOTO WALL -->
  <section class="photo-wall">
    <div class="container">
      <div class="head">
        <div>
          <div class="eyebrow on-dark"><span class="num" style="color: rgba(255,255,255,0.5)">No. 04</span><span class="rule-mini"></span>From the floor</div>
          <h2 class="t-h2" style="margin-top: 14px;">2026 in photographs.</h2>
        </div>
        <span class="count">18 images · Photography &copy; Innovia Summit 2026</span>
