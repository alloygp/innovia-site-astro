  <script is:inline>
(function () {
      var header = document.querySelector('.member-header');
      var form = document.getElementById('inquiry');
      if (!header || !form || !('IntersectionObserver' in window)) {
        if (header) header.classList.add('cta-shown');
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        var e = entries[0];
        if (!e.isIntersecting && e.boundingClientRect.top < 0) {
          header.classList.add('cta-shown');
        } else {
          header.classList.remove('cta-shown');
        }
      }, { rootMargin: '-74px 0px 0px 0px', threshold: 0 });
      io.observe(form);
    })();
  </script>

  <script is:inline>
(function () {
      var sec = document.querySelector('.faq-sec');
      if (!sec) return;
      var items = Array.prototype.slice.call(sec.querySelectorAll('details'));
      if (!items.length) return;
      sec.classList.add('js');
      items.forEach(function (d) {
        var a = d.querySelector('.a');
        if (a && !a.querySelector('.a-inner')) {
          var inner = document.createElement('div');
          inner.className = 'a-inner';
          while (a.firstChild) inner.appendChild(a.firstChild);
          a.appendChild(inner);
        }
        var wasOpen = d.hasAttribute('open');
        d.setAttribute('open', '');          // keep content rendered; CSS handles collapse
        if (wasOpen) d.classList.add('open');
        var sum = d.querySelector('summary');
        sum.addEventListener('click', function (e) {
          e.preventDefault();
          var willOpen = !d.classList.contains('open');
          items.forEach(function (o) { o.classList.remove('open'); });
          if (willOpen) d.classList.add('open');
        });
      });
    })();
  </script>

  <script is:inline>
(function () {
      var links = Array.prototype.slice.call(document.querySelectorAll('.member-header nav a'));
      var map = {}, sections = [];
      links.forEach(function (a) {
        var href = a.getAttribute('href') || '';
        if (href.charAt(0) === '#') {
          var el = document.querySelector(href);
          if (el) { map[el.id] = a; sections.push(el); }
        }
      });
      if (!sections.length || !('IntersectionObserver' in window)) return;
      var visible = {};
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) visible[e.target.id] = true; else delete visible[e.target.id];
        });
        var current = null, top = Infinity;
        sections.forEach(function (s) {
          if (visible[s.id]) {
            var t = s.getBoundingClientRect().top;
            if (t < top) { top = t; current = s.id; }
          }
        });
        links.forEach(function (a) { a.classList.remove('active'); });
        if (current && map[current]) map[current].classList.add('active');
      }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
      sections.forEach(function (s) { io.observe(s); });
    })();
  </script>
