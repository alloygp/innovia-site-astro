---
// src/components/SiteFooter.astro
// Shared site footer. Ported from the static site's canonical footer block,
// with internal links mapped to clean Astro URLs.
---

<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <div class="brand">
        <img src="/assets/logos/innovia-white-green.png" alt="Innovia Co-op">
        <p>A national cooperative of independent community management companies. Owned by members. Built for the communities they serve.</p>
        <div class="social">
          <a href="https://www.linkedin.com/company/innovia-community-management-cooperative/" aria-label="LinkedIn" target="_blank" rel="noopener"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg></a>
          <a href="https://x.com/innoviacoop" aria-label="X" target="_blank" rel="noopener"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
          <a href="https://www.facebook.com/InnoviaCoOp/" aria-label="Facebook" target="_blank" rel="noopener"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg></a>
        </div>
      </div>
      <div>
        <h6>The Co-op</h6>
        <ul>
          <li><a href="/for-cams/why-innovia/">For CAMs</a></li>
          <li><a href="/for-cams/three-pillars/">Three Pillars</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/about/#governance">Governance</a></li>
          <li><a href="/about/founders/">Our Founders</a></li>
          <li><a href="/about/cca-global-partners/">CCA Global Partners</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/partners/">Vendor Partners</a></li>
        </ul>
      </div>
      <div>
        <h6>For Boards</h6>
        <ul>
          <li><a href="/find-a-management-company/">Find a Management Company</a></li>
          <li><a href="/board-education/how-hoa-management-works/">How HOA Management Works</a></li>
          <li><a href="/member-spotlights/">Member Spotlights</a></li>
          <li><a href="/case-studies/">Case Studies</a></li>
          <li><a href="/testimonials/">Testimonials</a></li>
          <li><a href="/hoa-management-services/">Services Overview</a></li>
          <li><a href="/board-education/">Resources &amp; Guides</a></li>
        </ul>
      </div>
      <div>
        <h6>Summit</h6>
        <ul>
          <li><a href="/summit/">Summit 2027</a></li>
          <li><a href="/summit/2026/">2026 Archive</a></li>
          <li><a href="/summit/#past">Past Summits</a></li>
        </ul>
      </div>
      <div class="newsletter">
        <h6>Stay in the loop</h6>
        <p>Industry intelligence, summit announcements, and member spotlights &mdash; about once a month.</p>
        <form class="newsletter-form" onsubmit="event.preventDefault(); this.classList.add('submitted');">
          <input type="email" placeholder="you@yourcompany.com" aria-label="Email address" required>
          <button type="submit" aria-label="Subscribe">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </button>
          <span class="newsletter-ok">Thanks &mdash; you&rsquo;re on the list.</span>
        </form>
      </div>
    </div>
    <div class="copy">
      <span>&copy; 2026 Innovia Co-op. Member-owned. All rights reserved.</span>
      <span class="colophon">We stand apart because we stand together.</span>
    </div>
  </div>
</footer>
