---
// The Innovia Charter — founding-member offer (3 partners, first 90 days free, one CAM per metro).
// Ported from the working HTML prototype. Tweaks/React removed; the chosen variant is set
// via the body data-* attributes in the page route (charter-offer.astro).
import "../styles/tokens.css";
import "../styles/site.css";
import "../styles/charter-offer.css";
---

<!-- ============ HEADER ============ -->
  <header class="site-header">
    <div class="container row">
      <a href="/" class="brand">
        <img src="/assets/logos/innovia-white-green.png" alt="Innovia Co-op" style="height: 38px;">
      </a>
      <nav>
        <a href="/why-join">For CAMs</a>
        <a href="/charter-offer" class="active">The Charter</a>
        <a href="/about">About</a>
        <a href="/summit">Summit</a>
      </nav>
      <div class="nav-cta">
        <a href="tel:+18885550192" class="phone">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>(888) 555-0192</span>
        </a>
        <a href="#start" class="btn btn-primary reveal-cta">
          Start the Conversation
          <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </header>

  <!-- ============ URGENCY BAR (sticky strip below the nav) ============ -->
  <div class="urgency-bar">
    <div class="container inner">
      <span class="ping"></span>
      <span><strong class="placeholder placeholder-inline">7 of 24</strong> charter metros still open for the founding cohort</span>
      <a href="#metros" class="u-cta">See your market
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
      </a>
    </div>
  </div>

  <!-- ============ HERO ============ -->
  <section class="hero" id="top">
    <div class="hero-bg" aria-hidden="true"><img src="/assets/photos/member-introductions.jpg" alt=""></div>
    <div class="container">
      <div class="layout">
        <div class="pitch">
          <div class="crumb">
            <span class="dot"></span>
            The Innovia Charter
            <span class="sep">/</span>
            One seat per metro
            <span class="sep">/</span>
            By introduction
          </div>

          <!-- FRAMING A — CHALLENGE -->
          <div class="frame-copy f-challenge">
            <h1>Do you have what it takes to <em>own your market?</em></h1>
            <p class="lede">We are inviting <strong>one</strong> community management company in each metro into the founding charter cohort &mdash; and backing them with the full Innovia stack. <strong>Innovia membership, First Citizens Bank, and Alloy Growth Partners.</strong> The first 90 days, free. The only question is whether you&rsquo;re the operator who takes it.</p>
          </div>

          <!-- FRAMING B — INVITATION -->
          <div class="frame-copy f-invitation">
            <h1>Your most valuable <em>90 days</em> in business.</h1>
            <p class="lede">Three forces behind your firm at once &mdash; <strong>Innovia membership, First Citizens Bank, and Alloy Growth Partners</strong> &mdash; free for your first 90 days. We open <strong>one charter seat per metro</strong>. This is the invitation to take yours.</p>
          </div>

          <div class="actions">
            <a href="#start" class="btn btn-primary">Start the Conversation
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            </a>
            <a href="#stack" class="btn btn-outline-light">See what you get</a>
          </div>

          <div class="reassure">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Confidential conversation &middot; no obligation &middot; founding cohort only
          </div>
        </div>

        <!-- OFFER TICKET -->
        <div class="ticket">
          <span class="flag">Charter member offer</span>
          <div class="t-head">
            <span class="lbl">The powerhouse</span>
            <h2>Three forces. Ninety days. Zero cost.</h2>
            <p>Everything a charter member activates on day one &mdash; and what it would normally cost to run.</p>
          </div>
          <div class="rows">
            <div class="trow">
              <div class="who">
                <span class="wm">innovia<span style="color:var(--innovia-green)"> membership</span></span>
                <span class="role">The cooperative</span>
              </div>
              <div class="val">
                <div class="was placeholder placeholder-inline">$3,600/qtr</div>
                <div class="now">Free &middot; 90 days</div>
              </div>
            </div>
            <div class="trow">
              <div class="who">
                <span class="wm bank">First Citizens Bank</span>
                <span class="role">Banking &amp; treasury</span>
              </div>
              <div class="val">
                <div class="was placeholder placeholder-inline">$1,400/qtr</div>
                <div class="now">Free &middot; 90 days</div>
              </div>
            </div>
            <div class="trow">
              <div class="who">
                <span class="wm">Alloy <span class="lt" style="color:var(--innovia-green)">Growth</span></span>
                <span class="role">Brand &amp; growth program</span>
              </div>
              <div class="val">
                <div class="was placeholder placeholder-inline">$19,500</div>
                <div class="now">Free &middot; 90 days</div>
              </div>
            </div>
          </div>
          <div class="t-total">
            <div class="l">
              <span class="k">Launch value</span>
              <span class="v placeholder placeholder-inline">$24,500<span class="pct">+</span></span>
            </div>
            <div class="r">
              <div class="now">$0</div>
              <div class="span">Your first 90 days</div>
            </div>
          </div>
          <div class="t-foot">Figures illustrative &mdash; confirm final program values before publishing.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ THE STACK ============ -->
  <section class="stack" id="stack">
    <div class="container">
      <div class="sec-head">
        <div>
          <div class="eyebrow"><span class="rule-mini"></span>The powerhouse, unpacked</div>
          <h2 style="margin-top:14px;">One firm. Three forces working in the same direction.</h2>
        </div>
        <p>Most firms assemble these one at a time, over years, and pay full freight for each. A charter member switches all three on at once &mdash; and runs the first 90 days on us.</p>
      </div>

      <div class="powers">
        <!-- INNOVIA -->
        <div class="power">
          <div class="mark">
            <span class="ix">Force 01</span>
            <span class="plate"><img class="partner-logo" src="/assets/logos/innovia-navy.png" alt="Innovia Co-op"></span>
            <span class="kind">Membership &middot; the cooperative</span>
          </div>
          <div class="body">
            <h3>The collective buying power of the country&rsquo;s best independents.</h3>
            <p>Membership in Innovia is the spine of the stack. You join a national cooperative of independent CAM companies and immediately tap what no single firm negotiates alone &mdash; peer counsel, a shared vendor program, and real industry benchmarks.</p>
            <ul class="gets">
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Elite Community &mdash; a peer council of vetted operators</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Vendor Program &mdash; pre-negotiated terms on the line items you already run</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Business Growth &mdash; a national lead engine that routes board inquiries to you</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Benchmarks across the cooperative &mdash; the median, not a guess</li>
            </ul>
          </div>
          <div class="price">
            <span class="was-lbl">Member dues</span>
            <div class="was placeholder placeholder-inline">$3,600 / quarter</div>
            <div class="free-badge"><span class="n">$0</span><span class="u">first 90 days</span></div>
            <p class="term">Dues waived through your charter window. Full member benefits live from day one.</p>
          </div>
        </div>

        <!-- FIRST CITIZENS BANK -->
        <div class="power">
          <div class="mark">
            <span class="ix">Force 02</span>
            <span class="plate"><img class="partner-logo fc" src="/assets/logos/first-citizens-bank.png" alt="First Citizens Bank"></span>
            <span class="kind">Banking &amp; treasury</span>
          </div>
          <div class="body">
            <h3>Association banking built around how a CAM company actually operates.</h3>
            <p>A banking relationship purpose-built for community management &mdash; operating and reserve accounts, dues collection, and treasury tools, with a dedicated banker who understands association cash flow. <span class="placeholder placeholder-inline">Confirm the exact First Citizens service set with the bank before publishing.</span></p>
            <ul class="gets">
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Operating &amp; reserve account structure</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Dues collection &amp; lockbox</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Treasury &amp; cash-management tools</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>A dedicated banker, not a call center</li>
            </ul>
          </div>
          <div class="price">
            <span class="was-lbl">Service &amp; treasury fees</span>
            <div class="was placeholder placeholder-inline">$1,400 / quarter</div>
            <div class="free-badge"><span class="n">$0</span><span class="u">first 90 days</span></div>
            <p class="term">Standard service fees waived for the charter window while accounts are stood up.</p>
          </div>
        </div>

        <!-- ALLOY GROWTH PARTNERS -->
        <div class="power">
          <div class="mark">
            <span class="ix">Force 03</span>
            <span class="plate"><img class="partner-logo alloy" src="/assets/logos/alloy-growth.svg" alt="Alloy Growth Partners"></span>
            <span class="kind">Brand &amp; growth program</span>
          </div>
          <div class="body">
            <h3>A growth engine pointed at your metro &mdash; built, funded, and handed to you.</h3>
            <p>Alloy Growth Partners doesn&rsquo;t hand you advice; they build the machine. A dedicated, market-targeted presence goes live for your firm, with paid demand behind it and a written plan you keep.</p>
            <ul class="gets">
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>A dedicated market-targeting landing page</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>A managed PPC budget driving qualified board demand</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>A local market takeover campaign</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>A custom CAM growth blueprint &mdash; yours to keep, with options to extend</li>
            </ul>
          </div>
          <div class="price">
            <span class="was-lbl">Build, media &amp; blueprint</span>
            <div class="was placeholder placeholder-inline">$19,500 value</div>
            <div class="free-badge"><span class="n">$0</span><span class="u">first 90 days</span></div>
            <p class="term">Built and managed during the charter window. Extend on your terms after 90 days.</p>
          </div>
        </div>
      </div>

      <div class="sumline">
        <div class="l">
          <span class="k">What it adds up to</span>
          <div class="v"><span class="placeholder placeholder-inline">$24,500+</span> of launch value, working for one firm in your metro &mdash; <em>$0 for 90 days.</em></div>
        </div>
        <div class="r">
          <a href="#start" class="btn btn-primary">Claim your metro
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ QUALIFICATION STACK ============ -->
  <div class="qual-stack">

    <!-- SELF-ASSESSMENT -->
    <section class="fit" id="fit">
      <div class="container">
        <div class="head">
          <div class="eyebrow on-dark"><span class="rule-mini"></span>Does this sound like you?</div>
          <h2 style="margin-top:14px;">The charter isn&rsquo;t for everyone. <em>It might be for you.</em></h2>
          <p>We built this offer for a specific kind of operator. Read the six statements below. Check the ones that ring true &mdash; the more that do, the more this was made for your firm.</p>
        </div>
        <div class="grid" id="fitGrid">
          <button type="button" class="stmt" aria-pressed="false">
            <span class="box"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span class="txt"><strong>You own the firm.</strong> The decision to grow is yours to make &mdash; not three layers up.</span>
          </button>
          <button type="button" class="stmt" aria-pressed="false">
            <span class="box"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span class="txt"><strong>You&rsquo;re the best in your market.</strong> Or you intend to be &mdash; and you can prove the work behind it.</span>
          </button>
          <button type="button" class="stmt" aria-pressed="false">
            <span class="box"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span class="txt"><strong>You won&rsquo;t sell to a national.</strong> You chose independence on purpose and you mean to keep it.</span>
          </button>
          <button type="button" class="stmt" aria-pressed="false">
            <span class="box"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span class="txt"><strong>You want leverage, not a logo.</strong> Better vendor terms, real banking, and demand &mdash; not another badge.</span>
          </button>
          <button type="button" class="stmt" aria-pressed="false">
            <span class="box"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span class="txt"><strong>You&rsquo;ll show up.</strong> The cooperative gives most to the members who put the most in.</span>
          </button>
          <button type="button" class="stmt" aria-pressed="false">
            <span class="box"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span class="txt"><strong>You move when it&rsquo;s right.</strong> A founding seat closes the moment another firm in your metro takes it.</span>
          </button>
        </div>
        <div class="tally">
          <div class="meter"><span id="fitCount">0</span> / 6</div>
          <div class="verdict" id="fitVerdict">Check the statements that sound like your firm.</div>
          <a href="#start" class="btn btn-primary">Start the Conversation
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- THE BAR / SCORECARD -->
    <section class="bar" id="bar">
      <div class="container">
        <div class="head">
          <div>
            <div class="eyebrow"><span class="rule-mini"></span>The bar to clear</div>
            <h2 style="margin-top:14px;">What it takes to hold a charter seat.</h2>
          </div>
          <p>A charter seat carries the full weight of the Innovia name plus two partners in your market. We&rsquo;re selective on purpose. Here is the bar we hold every candidate to.</p>
        </div>
        <div class="card-rows">
          <div class="crit">
            <span class="n">01</span>
            <div>
              <h4>Owner-operated</h4>
              <div class="req">Founder or principal at the table</div>
            </div>
            <p>Decisions on growth, banking, and brand are made by the person we&rsquo;re talking to &mdash; not escalated to a parent company.</p>
          </div>
          <div class="crit">
            <span class="n">02</span>
            <div>
              <h4>Established book</h4>
              <div class="req placeholder placeholder-inline">~1,000+ units under management</div>
            </div>
            <p>Enough scale that the cooperative&rsquo;s leverage moves real money &mdash; and enough operating maturity to absorb growth well.</p>
          </div>
          <div class="crit">
            <span class="n">03</span>
            <div>
              <h4>Reputation that holds up</h4>
              <div class="req">Reference-checked with boards &amp; peers</div>
            </div>
            <p>We route a candidate through existing members and ask boards directly. The Innovia name only goes on firms that earn it.</p>
          </div>
          <div class="crit">
            <span class="n">04</span>
            <div>
              <h4>Independent &mdash; and staying that way</h4>
              <div class="req">Not on an acquisition path</div>
            </div>
            <p>The charter rewards firms committed to independence. If you&rsquo;re planning to sell to a national, this isn&rsquo;t the right fit.</p>
          </div>
          <div class="crit">
            <span class="n">05</span>
            <div>
              <h4>Open market in your metro</h4>
              <div class="req">One seat, first qualified firm</div>
            </div>
            <p>We seat a single charter member per metro. If your market is still open and you clear the bar, the seat is yours to take.</p>
          </div>
        </div>
        <div class="note">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          Meet most of these and the conversation is worth having. We&rsquo;ll be honest about fit on the first call.
        </div>
      </div>
    </section>

  </div>

  <!-- ============ ONE SEAT PER METRO ============ -->
  <section class="market" id="metros">
    <div class="container">
      <div class="frame">
        <div class="copy">
          <div class="eyebrow on-dark"><span class="rule-mini"></span>One seat per market</div>
          <h2 style="margin-top:14px;">We back <em>one</em> firm per metro. Then we close it.</h2>
          <p>The whole point is leverage you don&rsquo;t share with the firm across town. So the charter seats exactly one community management company in each metro &mdash; flexible to how a market is really drawn &mdash; and the demand engine works for them alone.</p>
          <div class="why">
            <div class="w">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <p><strong>No internal competition.</strong> Co-op vendor leverage and the growth program point at your firm, not a roomful of locals.</p>
            </div>
            <div class="w">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <p><strong>The market is yours to own.</strong> Board demand we generate in your metro routes to one charter member &mdash; you.</p>
            </div>
            <div class="w">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              <p><strong>First qualified firm holds it.</strong> When a seat is claimed, it&rsquo;s gone &mdash; the next firm in that metro waits for renewal.</p>
            </div>
          </div>
        </div>

        <div class="board">
          <div class="b-head">
            <span class="t">Charter availability</span>
            <span class="live"><span class="d"></span>Founding cohort</span>
          </div>
          <div class="rows">
            <div class="m">
              <span class="city">Phoenix <span class="sub">AZ metro</span></span>
              <span class="status open"><span class="d"></span>Open</span>
            </div>
            <div class="m">
              <span class="city">Charlotte <span class="sub">NC metro</span></span>
              <span class="status open"><span class="d"></span>Open</span>
            </div>
            <div class="m">
              <span class="city">Denver <span class="sub">CO metro</span></span>
              <span class="status talking"><span class="d"></span>In conversation</span>
            </div>
            <div class="m">
              <span class="city">Tampa &ndash; St. Pete <span class="sub">FL metro</span></span>
              <span class="status open"><span class="d"></span>Open</span>
            </div>
            <div class="m">
              <span class="city">Dallas &ndash; Fort Worth <span class="sub">TX metro</span></span>
              <span class="status claimed"><span class="d"></span>Claimed</span>
            </div>
            <div class="m">
              <span class="city">Las Vegas <span class="sub">NV metro</span></span>
              <span class="status open"><span class="d"></span>Open</span>
            </div>
            <div class="m">
              <span class="city">Nashville <span class="sub">TN metro</span></span>
              <span class="status talking"><span class="d"></span>In conversation</span>
            </div>
            <div class="m">
              <span class="city">Raleigh &ndash; Durham <span class="sub">NC metro</span></span>
              <span class="status claimed"><span class="d"></span>Claimed</span>
            </div>
          </div>
          <div class="b-foot">
            <div class="legend">
              <span><span class="d" style="background:var(--innovia-green)"></span>Open</span>
              <span><span class="d" style="background:#E8C75A"></span>In conversation</span>
