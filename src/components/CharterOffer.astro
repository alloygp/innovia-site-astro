<script is:inline>
    /* self-assessment tally */
    (function () {
      var grid = document.getElementById('fitGrid');
      if (!grid) return;
      var countEl = document.getElementById('fitCount');
      var verdictEl = document.getElementById('fitVerdict');
      var btns = Array.prototype.slice.call(grid.querySelectorAll('.stmt'));
      var checks = Array.prototype.slice.call(document.querySelectorAll('.lead-form .fit-check input[data-fit]'));
      function verdict(n) {
        if (n === 0) return 'Check the statements that sound like your firm.';
        if (n <= 2) return 'A few hit home. Worth a conversation to see if the rest could.';
        if (n <= 4) return 'You&rsquo;re squarely the operator we built this for.';
        if (n === 5) return '<strong>This was made for your firm.</strong> Your metro may not stay open long.';
        return '<strong>You&rsquo;re exactly who the charter is for.</strong> Start the conversation before your seat is taken.';
      }
      function refresh() {
        var n = btns.filter(function (b) { return b.getAttribute('aria-pressed') === 'true'; }).length;
        countEl.textContent = n;
        verdictEl.innerHTML = verdict(n);
      }
      function setOn(i, on) {
        if (btns[i]) btns[i].setAttribute('aria-pressed', on ? 'true' : 'false');
        var cb = checks.filter(function (c) { return +c.getAttribute('data-fit') === i; })[0];
        if (cb) {
          cb.checked = on;
          var wrap = cb.closest('.fit-check');
          if (wrap) wrap.classList.toggle('is-on', on);
        }
        refresh();
      }
      btns.forEach(function (b, i) {
        b.addEventListener('click', function () {
          setOn(i, b.getAttribute('aria-pressed') !== 'true');
        });
      });
      checks.forEach(function (cb) {
        cb.addEventListener('change', function () {
          setOn(+cb.getAttribute('data-fit'), cb.checked);
        });
      });
    })();

    /* header CTA: collapsed until the hero scrolls out of view, then slides in */
    (function () {
      var header = document.querySelector('.site-header');
      var hero = document.getElementById('top');
      if (!header || !hero || !('IntersectionObserver' in window)) {
        if (header) header.classList.add('cta-shown');
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        var e = entries[0];
        if (!e.isIntersecting && e.boundingClientRect.top < 0) {
          header.classList.add('cta-shown');
        } else {
          header.classList.remove('cta-shown');
        }
      }, { rootMargin: '-76px 0px 0px 0px', threshold: 0 });
      io.observe(hero);
    })();

    /* scarcity bar eases up & back on scroll: hidden when scrolling down, shown near top / on scroll up */
    (function () {
      var bar = document.querySelector('.urgency-bar');
      if (!bar) return;
      var lastY = window.scrollY, ticking = false;
      var SHOW_AT = 80, DELTA = 5;
      function setCollapsed(on) {
        bar.style.transform = on ? 'translateY(-100%)' : 'translateY(0)';
      }
      setCollapsed(false);
      function upd() {
        var y = window.scrollY;
        if (y <= SHOW_AT) setCollapsed(false);
        else if (y - lastY > DELTA) setCollapsed(true);
        else if (lastY - y > DELTA) setCollapsed(false);
        lastY = y; ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(upd); ticking = true; }
      }, { passive: true });
    })();
</script>
