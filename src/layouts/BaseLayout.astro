---
// src/layouts/BaseLayout.astro
// Root layout for the Innovia Co-op marketing site.
// Renders <head> SEO, the shared header + mega-menu, and the shared footer.
// Page-specific <style> can be passed via the "head" slot; page-specific
// inline scripts via the "scripts" slot.

import '../styles/site.css';
import { SITE } from '../config/site.ts';
import { REVIEW_ITEMS, PASTEL_BASE, TICKET_ID } from '../config/review.ts';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  /** <title> tag. Required. */
  title: string;
  /** Meta description. Required. */
  description: string;
  /** Optional og:title override (defaults to title). */
  ogTitle?: string;
  /** Optional og:description override (defaults to description). */
  ogDescription?: string;
  /** og:type. Default 'website'. */
  ogType?: 'website' | 'article';
  /** Per-page OG image from /public. Default: site default. */
  ogImage?: string;
  /** robots meta. Omit for normal indexed pages. */
  robots?: string;
  /** Page-specific JSON-LD schema. */
  pageSchema?: Record<string, unknown> | Record<string, unknown>[];

  // ---- Header props (forwarded to SiteHeader) ----
  headerVariant?: '' | 'inverse';
  activeNav?: 'about' | 'cams' | 'boards' | 'summit' | null;
  headerLogo?: string;
  headerLogoHeight?: number;
  ctaLabel?: string;
  ctaHref?: string;
  ctaClass?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogType = 'website',
  ogImage: ogImageProp,
  robots,
  pageSchema,
  headerVariant = '',
  activeNav = null,
  headerLogo = '/assets/logos/innovia-white-green.png',
  headerLogoHeight = 38,
  ctaLabel = 'Schedule a Conversation',
  ctaHref = '/schedule-a-conversation/',
  ctaClass = 'btn btn-navy',
} = Astro.props;

const defaultOg = SITE.defaultOgImage ?? '/assets/og/option-1-type-led.png';
const canonicalUrl    = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString();
const resolvedOgImage = new URL(ogImageProp ?? defaultOg, Astro.site ?? SITE.url).toString();

const orgLd = {
  '@context': 'https://schema.org',
  '@type': SITE.org.type,
  name: SITE.name,
  url: SITE.url,
  logo: SITE.org.logo,
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.org.addressLocality,
    addressRegion:   SITE.org.addressRegion,
    addressCountry:  SITE.org.addressCountry,
  },
  telephone: SITE.org.telephone,
  email:     SITE.org.email,
  areaServed: SITE.org.areaServed,
  priceRange: SITE.org.priceRange,
};

const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/innovia-icon.png" />
    <link rel="apple-touch-icon" href="/assets/innovia-icon.png" />

    {robots && <meta name="robots" content={robots} />}

    <!-- Open Graph -->
    <meta property="og:title"       content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:type"        content={ogType} />
    <meta property="og:site_name"   content={SITE.name} />
    <meta property="og:locale"      content={SITE.locale} />
    <meta property="og:image"       content={resolvedOgImage} />
    <meta property="og:image:type"  content="image/png" />
    <meta property="og:image:width" content={SITE.ogImageWidth} />
    <meta property="og:image:height" content={SITE.ogImageHeight} />
    <meta property="og:image:alt"   content={SITE.name} />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content={SITE.twitterHandle} />
    <meta name="twitter:title"       content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image"       content={resolvedOgImage} />
    <meta name="twitter:image:alt"   content={SITE.name} />

    <!-- JSON-LD: Organization (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {pageSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    )}

    <!-- Per-page styles / preloads -->
    <slot name="head" />

    <!-- Google Analytics: deferred until after page paint -->
    {gaMeasurementId && (
      <script is:inline define:vars={{ gaMeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaMeasurementId);
        window.addEventListener('load', function() {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaMeasurementId;
          document.head.appendChild(s);
        });
      </script>
    )}
  </head>
  <body>
    <SiteHeader
      variant={headerVariant}
      active={activeNav}
      logo={headerLogo}
      logoHeight={headerLogoHeight}
      ctaLabel={ctaLabel}
      ctaHref={ctaHref}
      ctaClass={ctaClass}
    />

    <slot />

    <SiteFooter />

    <!-- Header behaviors + mega menu (ported from shared/header.js) -->
    <script is:inline>
      (function () {
        const header = document.querySelector(".site-header");
        if (header) {
          let lastY = window.scrollY;
          let ticking = false;
          const THRESHOLD = 120;
          const DELTA = 4;
          function updateScroll() {
            const y = window.scrollY;
            const diff = y - lastY;
            if (Math.abs(diff) < DELTA) { ticking = false; return; }
            if (y < THRESHOLD) {
              header.classList.remove("is-hidden");
            } else if (diff > 0) {
              header.classList.add("is-hidden");
              closeAllMega();
            } else {
              header.classList.remove("is-hidden");
            }
            lastY = y;
            ticking = false;
          }
          window.addEventListener("scroll", () => {
            if (!ticking) { requestAnimationFrame(updateScroll); ticking = true; }
          }, { passive: true });
        }

        const MEGA = {
          boards: {
            eyebrow: "For HOA & Condo Boards",
            title: "Looking for management? We’ll route you to the right Innovia member.",
            image: "/assets/photos/working-session.jpg",
            imageCaption: "Pl. 01 · Cooperative working session, Summit 2026",
            footnote: "Free for board members · no account required",
            cta: { label: "Looking for Management?", href: "/find-a-management-company/#request" },
            items: [
              { icon: 'map-pin', title: 'Find a Management Company', desc: 'Tell us about your community and we’ll route the inquiry to the Innovia-backed company best positioned to serve you. One match. No call lists.', href: '/find-a-management-company/' },
              { icon: 'building', title: 'HOA Management Services', desc: 'What Innovia-backed companies deliver to associations — by property type. Single-family, condo, townhome, plus accounting and covenant sub-services.', href: '/hoa-management-services/' },
              { icon: 'book-open', title: 'Board Resources & Guides', desc: 'Cooperatively-authored guides for boards: choosing a manager, reserves, RFPs, governance. Migrating from the old blog.', href: '/board-education/' },
            ],
          },
          cams: {
            eyebrow: "For Community Management Companies",
            title: "Independent companies. Stronger together.",
            image: "/assets/photos/member-introductions.jpg",
            imageCaption: "Pl. 02 · Member introductions, Summit 2026",
            footnote: "Membership by introduction · confidential",
            cta: { label: "Schedule a Conversation", href: "/schedule-a-conversation/" },
            columns: [
              {
                heading: 'Membership',
                items: [
                  { icon: 'users-round', title: 'Why Innovia for your company', desc: 'A peer council, a shared vendor program, and industry intelligence — in service of every level of your operation.', href: '/for-cams/why-innovia/' },
                  { icon: 'building', title: 'Member Spotlights', desc: 'Operators in action — eight member-company profiles and the 22 summit films producing across 2026.', href: '/member-spotlights/' },
                  { icon: 'anchor', title: 'The Annual Summit', desc: 'Three days. The whole cooperative in one room — closed-door, no vendor floor. Summit 2027 in February.', href: '/summit/' },
                ],
              },
              {
                heading: 'The Three Pillars',
                items: [
                  { icon: 'trophy', title: 'Elite Community', desc: 'An invitation-only circle of the country’s best independent operators.', href: '/for-cams/three-pillars/elite-community/' },
                  { icon: 'trending-up', title: 'Business Growth', desc: 'A national SEO and content engine routes qualified board leads to the closest member.', href: '/for-cams/three-pillars/business-growth/' },
                  { icon: 'handshake', title: 'Vendor Program', desc: 'Pre-negotiated agreements with vetted partners across the line items every CAM company runs.', href: '/for-cams/three-pillars/vendor-program/' },
                ],
              },
            ],
          },
        };

        const ICONS = {
          'map-pin': '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
          'building': '<rect x="4" y="2" width="16" height="20" rx="1"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M12 6h.01M12 10h.01M12 14h.01M16 10h.01M16 14h.01M8 10h.01M8 14h.01"/>',
          'book-open': '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
          'users-round': '<path d="M18 21a8 8 0 0 0-16 0"/><circle cx="10" cy="8" r="5"/><path d="M22 20c0-3.37-2-6.5-4-8a5 5 0 0 0-.45-8.3"/>',
          'layers': '<path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>',
          'anchor': '<circle cx="12" cy="5" r="3"/><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/>',
          'trophy': '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
          'trending-up': '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
          'handshake': '<path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/>',
        };

        function svg(name) {
          return '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">' + (ICONS[name] || '') + '</svg>';
        }

        function renderItem(item) {
          return '<a class="item" href="' + item.href + '">' +
            '<span class="icon">' + svg(item.icon) + '</span>' +
            '<span class="text"><h5>' + item.title + '</h5><p>' + item.desc + '</p></span>' +
            '<span class="arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>' +
            '</a>';
        }

        function buildPanel(key) {
          const data = MEGA[key];
          if (!data) return null;
          const panel = document.createElement('div');
          panel.className = 'mega-panel';
          panel.dataset.mega = key;
          let itemsHtml;
          if (data.columns) {
            itemsHtml = '<div class="columns">' + data.columns.map(function (col) {
              return '<div class="col"><h6 class="col-heading">' + col.heading + '</h6><div class="items">' + col.items.map(renderItem).join('') + '</div></div>';
            }).join('') + '</div>';
          } else {
            itemsHtml = '<div class="items">' + data.items.map(renderItem).join('') + '</div>';
          }
          panel.innerHTML =
            '<div class="layout">' +
              '<div class="image"><img src="' + data.image + '" alt=""><div class="image-shade"></div>' +
                '<div class="image-meta"><div class="image-eyebrow">' + data.eyebrow + '</div>' +
                '<div class="image-title">' + data.title + '</div>' +
                '<div class="image-caption">' + data.imageCaption + '</div></div></div>' +
              '<div class="right">' + itemsHtml +
                '<div class="footnote"><span class="dot"></span><span class="footnote-text">' + data.footnote + '</span>' +
                (data.cta ? '<a class="footnote-cta" href="' + data.cta.href + '">' + data.cta.label + '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></a>' : '') +
                '</div></div>' +
            '</div>';
          return panel;
        }

        let activeMega = null;
        let activeTrigger = null;

        function closeAllMega() {
          document.querySelectorAll('.mega-panel.is-open').forEach(function (p) { p.classList.remove('is-open'); });
          document.querySelectorAll('.nav-item-mega.is-open').forEach(function (n) { n.classList.remove('is-open'); });
          document.body.classList.remove('mega-open');
          activeMega = null;
          activeTrigger = null;
        }

        function openMega(key, trigger) {
          if (activeMega === key) return;
          closeAllMega();
          let panel = document.querySelector('.mega-panel[data-mega="' + key + '"]');
          if (!panel) {
            panel = buildPanel(key);
            if (!panel) return;
            document.body.appendChild(panel);
          }
          requestAnimationFrame(function () {
            panel.classList.add('is-open');
            trigger.classList.add('is-open');
            document.body.classList.add('mega-open');
          });
          activeMega = key;
          activeTrigger = trigger;
        }

        function init() {
          const triggers = document.querySelectorAll('a.nav-item-mega, .nav-item-mega');
          if (!triggers.length) return;
          triggers.forEach(function (trigger) {
            const key = trigger.dataset.mega;
            if (!key) return;
            trigger.addEventListener('click', function (e) {
              e.preventDefault();
              if (activeMega === key) { closeAllMega(); } else { openMega(key, trigger); }
            });
            trigger.addEventListener('mouseenter', function () {
              if (window.matchMedia('(hover: hover)').matches) { openMega(key, trigger); }
            });
          });
          const navArea = document.querySelector('.site-header');
          if (navArea) {
            navArea.addEventListener('mouseleave', function () {
              setTimeout(function () { if (!document.querySelector('.mega-panel:hover')) closeAllMega(); }, 80);
            });
          }
          document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAllMega(); });
          document.addEventListener('click', function (e) {
            if (!activeMega) return;
            if (e.target.closest('.mega-panel') || e.target.closest('.nav-item-mega') || e.target.closest('[data-mega]')) return;
            closeAllMega();
          });
          document.addEventListener('mouseout', function (e) {
            const out = e.relatedTarget;
            if (!activeMega) return;
            if (out && (out.closest && (out.closest('.mega-panel') || out.closest('.nav-item-mega')))) return;
            const panel = document.querySelector('.mega-panel.is-open');
            if (!panel) return;
            const overPanel = panel.matches(':hover');
            const overTrigger = activeTrigger && activeTrigger.matches(':hover');
            if (!overPanel && !overTrigger) {
              setTimeout(function () {
                const p = document.querySelector('.mega-panel.is-open');
                if (!p) return;
                if (!p.matches(':hover') && !(activeTrigger && activeTrigger.matches(':hover'))) closeAllMega();
              }, 100);
            }
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <!-- Accordion behavior: one open at a time + eased open/close animation.
         Groups <details> by their shared parent, so it covers every FAQ list
         (.faq .list, .tp-faq, and any future accordion) with no markup change. -->
    <script is:inline>
      (function () {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var OPEN_MS = 300, CLOSE_MS = 250;
        var EASE_OPEN = 'cubic-bezier(0.22, 0.61, 0.36, 1)';
        var EASE_CLOSE = 'cubic-bezier(0.4, 0, 0.2, 1)';

        function panelOf(d) {
          return d.querySelector(':scope > .a') ||
                 d.querySelector(':scope > *:not(summary)');
        }

        function expand(d) {
          var c = panelOf(d);
          if (!c) { d.open = true; return; }
          if (d._anim) d._anim.cancel();
          d.open = true;
          if (reduce) return;
          var cs = getComputedStyle(c);
          var pt = cs.paddingTop, pb = cs.paddingBottom;
          var full = c.scrollHeight;
          c.style.overflow = 'hidden';
          var a = c.animate(
            [
              { height: '0px', paddingTop: '0px', paddingBottom: '0px', opacity: 0 },
              { height: full + 'px', paddingTop: pt, paddingBottom: pb, opacity: 1 }
            ],
            { duration: OPEN_MS, easing: EASE_OPEN }
          );
          d._anim = a;
          a.onfinish = function () { d._anim = null; c.style.height = c.style.paddingTop = c.style.paddingBottom = c.style.overflow = ''; };
          a.oncancel = function () { c.style.overflow = ''; };
        }

        function shrink(d) {
          var c = panelOf(d);
          if (!c) { d.open = false; return; }
          if (reduce) { d.open = false; return; }
          if (d._anim) d._anim.cancel();
          var cs = getComputedStyle(c);
          var pt = cs.paddingTop, pb = cs.paddingBottom;
          var full = c.scrollHeight;
          c.style.overflow = 'hidden';
          var a = c.animate(
            [
              { height: full + 'px', paddingTop: pt, paddingBottom: pb, opacity: 1 },
              { height: '0px', paddingTop: '0px', paddingBottom: '0px', opacity: 0 }
            ],
            { duration: CLOSE_MS, easing: EASE_CLOSE }
          );
          d._anim = a;
          a.onfinish = function () { d._anim = null; d.open = false; c.style.height = c.style.paddingTop = c.style.paddingBottom = c.style.overflow = ''; };
          a.oncancel = function () { c.style.overflow = ''; };
        }

        function init() {
          var groups = new Map();
          document.querySelectorAll('details').forEach(function (d) {
            var p = d.parentElement;
            if (!p) return;
            if (!groups.has(p)) groups.set(p, []);
            groups.get(p).push(d);
          });
          groups.forEach(function (items) {
            items.forEach(function (d) {
              var summary = d.querySelector(':scope > summary');
              if (!summary) return;
              summary.addEventListener('click', function (e) {
                e.preventDefault();
                if (d.open) {
                  shrink(d);
                } else {
                  items.forEach(function (other) { if (other !== d && other.open) shrink(other); });
                  expand(d);
                }
              });
            });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <!-- ── Alloy Preview Review Widget ─────────────────────────────────────
         Vanilla JS — no framework deps, works inside Pastel proxy.
         Config comes from src/config/review.ts via define:vars.
    ──────────────────────────────────────────────────────────────────────── -->
    <script is:inline define:vars={{ reviewItems: REVIEW_ITEMS, pastelBase: PASTEL_BASE, ticketIdFromConfig: TICKET_ID }}>
    (function() {
      var items = (reviewItems || []).filter(function(i) { return i.review; });
      if (!items.length) return;

      var P  = '#381c4f';   // alloy purple
      var PK = '#d9356e';   // alloy pink
      var FONT = '"Gotham","Poppins","Helvetica Neue",Arial,sans-serif';

      var SK  = 'innovia_review_v1';
      var TK  = 'innovia_review_v1_ticket';
      var ISK = 'innovia_review_v1_started';

      // ── Persisted state ──────────────────────────────────────────────────
      var checked = {};
      try { checked = JSON.parse(localStorage.getItem(SK) || '{}'); } catch(_) {}

      // Ticket ID comes from review.ts (baked in at deploy time) — no URL param needed
      var ticketId = ticketIdFromConfig || '';
      try {
        if (ticketId) { localStorage.setItem(TK, ticketId); }
        else { ticketId = localStorage.getItem(TK) || ''; }
      } catch(_) {}

      // ── Widget state ─────────────────────────────────────────────────────
      var isOpen       = true;
      var isStarted    = false;
      try { isStarted = localStorage.getItem(ISK) === '1'; } catch(_) {}
      var isSubmitting = false;
      var isSubmitted  = false;
      var wasDone      = false;

      // ── Platform detection ───────────────────────────────────────────────
      var isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform || navigator.userAgent || '');

      // ── Pastel mode detection ────────────────────────────────────────────
      // We don't know exactly what Pastel injects, so cast a wide net:
      //   1. body/html outline or inset box-shadow (whole-page highlight)
      //   2. body/html class name changes (e.g. pastel adds a class)
      //   3. any fixed element covering most of the viewport
      //   4. any element with a Pastel-pattern class (tw-*, pastel-*)


      // ── Inject font + hover CSS once ─────────────────────────────────────
      if (!document.getElementById('agp-styles')) {
        var s = document.createElement('style');
        s.id = 'agp-styles';
        s.textContent =
          '@font-face{font-family:"Gotham";font-weight:400;font-display:swap;src:url("/fonts/Gotham-Book.woff2") format("woff2")}' +
          '@font-face{font-family:"Gotham";font-weight:500;font-display:swap;src:url("/fonts/Gotham-Medium.woff2") format("woff2")}' +
          '@font-face{font-family:"Gotham";font-weight:700;font-display:swap;src:url("/fonts/Gotham-Bold.woff2") format("woff2")}' +
          '@font-face{font-family:"Gotham";font-weight:800;font-display:swap;src:url("/fonts/Gotham-Black.woff2") format("woff2")}' +
          '#agp-rw .agp-row:hover{background:#f8f6ff!important}' +
          '#agp-rw input:focus,#agp-rw textarea:focus{border-color:' + PK + '!important;outline:none}' +
          '#agp-rw .agp-open:hover{background:' + P + '!important;color:#fff!important;border-color:' + P + '!important}' +
          '#agp-tab:hover{background:#4a2468!important;box-shadow:0 6px 24px rgba(56,28,79,.5)!important}' +
          '#agp-minimize:hover{opacity:1!important;background:rgba(255,255,255,.15)!important}' +
          '.tw-1txb66d.px-3.whitespace-nowrap{display:none!important}' +
          '@keyframes agp-confetti-fall{0%{transform:translateY(0) rotate(0deg);opacity:1}100%{transform:translateY(220px) rotate(720deg);opacity:0}}' +
          '@keyframes agp-bar-pulse{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0)}50%{box-shadow:0 0 0 5px rgba(34,197,94,.35)}}';
        document.head.appendChild(s);
      }

      // ── Mount ────────────────────────────────────────────────────────────
      var wrap = document.createElement('div');
      wrap.id = 'agp-rw';
      wrap.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:2147483647;font-family:' + FONT + ';opacity:1;';
      document.body.appendChild(wrap);

      function count() { return items.filter(function(i) { return checked[i.path]; }).length; }

      // ── Confetti burst ───────────────────────────────────────────────────
      function launchConfetti() {
        var colors = ['#22c55e','#16a34a','#d9356e','#381c4f','#f5d880','#fff'];
        var bar = document.getElementById('agp-bar-fill');
        var rect = bar ? bar.getBoundingClientRect() : wrap.getBoundingClientRect();
        for (var i = 0; i < 40; i++) {
          var p = document.createElement('div');
          var size  = 5 + Math.random() * 6;
          var left  = rect.left + Math.random() * rect.width;
          var top   = rect.top + rect.height / 2;
          var delay = Math.random() * 350;
          var dur   = 900 + Math.random() * 700;
          var color = colors[Math.floor(Math.random() * colors.length)];
          var shape = Math.random() > 0.5 ? '50%' : '2px';
          p.style.cssText =
            'position:fixed;top:' + top + 'px;left:' + left + 'px;' +
            'width:' + size + 'px;height:' + size + 'px;' +
            'background:' + color + ';border-radius:' + shape + ';' +
            'pointer-events:none;z-index:2147483648;' +
            'animation:agp-confetti-fall ' + dur + 'ms ease-in ' + delay + 'ms forwards;';
          document.body.appendChild(p);
          setTimeout(function(el) { return function() { if (el.parentNode) el.parentNode.removeChild(el); }; }(p), dur + delay + 100);
        }
      }

      // ── Render ───────────────────────────────────────────────────────────
      function render() {
        var n    = count();
        var tot  = items.length;
        var pct  = tot ? Math.round(n / tot * 100) : 0;
        var done = n === tot;
        var rem  = tot - n;

        // ── Collapsed tab ────────────────────────────────────────────────
        if (!isOpen) {
          wrap.innerHTML =
            '<button id="agp-tab" style="background:' + P + ';color:#fff;border:none;border-radius:10px;' +
            'padding:10px 16px;cursor:pointer;font-weight:700;font-size:13px;display:flex;align-items:center;' +
            'gap:8px;box-shadow:0 4px 20px rgba(56,28,79,.35);letter-spacing:.01em;font-family:' + FONT + ';' +
            'transition:background 150ms,box-shadow 150ms;">' +
              '<img src="/assets/alloy-icon.png" alt="" style="width:20px;height:20px;display:block;flex-shrink:0;" />' +
              '<span>Review Checklist</span>' +
              '<span style="background:' + PK + ';color:#fff;border-radius:20px;padding:1px 7px;' +
              'font-size:11px;font-weight:800;">' + n + '/' + tot + '</span>' +
            '</button>';
          document.getElementById('agp-tab').onclick = function() { isOpen = true; render(); };
          return;
        }

        // ── Panel ────────────────────────────────────────────────────────
        var html =
          '<div style="background:#fff;border-radius:14px;width:340px;' +
          'box-shadow:0 12px 48px rgba(56,28,79,.28);overflow:hidden;display:flex;' +
          'flex-direction:column;max-height:82vh;">';

        // Header (always shown)
        html +=
          '<div style="background:' + P + ';color:#fff;padding:13px 16px;display:flex;' +
          'align-items:center;justify-content:space-between;">' +
            '<div style="display:flex;align-items:center;gap:10px;">' +
              '<img src="/assets/alloy-icon.png" alt="" style="width:28px;height:28px;border-radius:6px;background:rgba(255,255,255,.15);padding:3px;display:block;flex-shrink:0;" />' +
              '<div>' +
                '<div style="font-weight:700;font-size:14px;line-height:1.2;">Review Checklist</div>' +
                '<div style="font-size:10px;opacity:.7;font-weight:400;letter-spacing:.01em;">Check off each page as you review it</div>' +
              '</div>' +
            '</div>' +
            '<button id="agp-minimize" title="Minimize" style="background:none;border:none;color:#fff;cursor:pointer;' +
            'padding:4px 6px;border-radius:6px;opacity:.7;font-family:' + FONT + ';display:flex;flex-direction:column;' +
            'gap:3px;align-items:center;justify-content:center;transition:opacity 150ms,background 150ms;" aria-label="Minimize">' +
              '<span style="display:block;width:14px;height:2px;background:#fff;border-radius:1px;"></span>' +
            '</button>' +
          '</div>';

        // ── Cover state (before review started) ──────────────────────────
        if (!isStarted) {
          html +=
            '<div style="padding:32px 24px 24px;display:flex;flex-direction:column;align-items:center;gap:20px;">' +
              // Toggle replica — Browse mode (circle left, grey track)
              '<div style="display:flex;align-items:center;gap:10px;background:#f4f2f9;border-radius:999px;padding:8px 18px;">' +
                '<span style="font-size:13px;font-weight:700;color:' + P + ';">Browse</span>' +
                '<div style="width:44px;height:24px;background:#ccc;border-radius:999px;position:relative;flex-shrink:0;">' +
                  '<div style="position:absolute;left:3px;top:3px;width:18px;height:18px;background:#fff;border-radius:50%;box-shadow:0 1px 3px rgba(0,0,0,.2);"></div>' +
                '</div>' +
                '<span style="font-size:13px;font-weight:400;color:#aaa;">Comment</span>' +
              '</div>' +
              '<div style="text-align:center;">' +
                '<div style="font-weight:700;font-size:15px;color:' + P + ';margin-bottom:8px;">Switch to Browse mode first</div>' +
                '<div style="font-size:12px;color:#888;line-height:1.6;">Use the toggle at the bottom of your screen<br>to switch modes — or press <kbd style="background:#ede9f8;color:' + P + ';border-radius:4px;padding:1px 5px;font-size:11px;font-family:ui-monospace,monospace;">' + (isMac ? '⌥C' : 'Ctrl+C') + '</kbd> to toggle.</div>' +
              '</div>' +
              '<button id="agp-start" style="background:' + P + ';color:#fff;border:none;border-radius:10px;' +
              'padding:12px 24px;font-weight:800;font-size:13px;cursor:pointer;width:100%;' +
              'letter-spacing:.02em;font-family:' + FONT + ';box-shadow:0 4px 14px rgba(56,28,79,.22);transition:all 200ms;">' +
                'Start review' +
              '</button>' +
            '</div>';

        // ── Success state ─────────────────────────────────────────────────
        } else if (isSubmitted) {
          html +=
            '<div style="padding:40px 24px;text-align:center;color:#1a7a4a;">' +
              '<div style="width:48px;height:48px;background:#22c55e;border-radius:50%;display:flex;' +
              'align-items:center;justify-content:center;margin:0 auto 14px;font-size:22px;color:#fff;">✓</div>' +
              '<div style="font-weight:700;font-size:15px;margin-bottom:6px;">Review submitted!</div>' +
              '<div style="font-size:12px;color:#666;line-height:1.5;">The Alloy team has been notified<br>and will follow up shortly.</div>' +
            '</div>';

        // ── Checklist state ───────────────────────────────────────────────
        } else {
          // Progress bar
          html +=
            '<div style="padding:12px 16px 0;border-bottom:1px solid #f0f0f0;">' +
              '<div style="height:8px;background:#ede9f8;border-radius:4px;margin-bottom:8px;">' +
                '<div id="agp-bar-fill" style="height:100%;border-radius:4px;background:linear-gradient(90deg,#22c55e,#16a34a);' +
                'width:' + pct + '%;transition:width .3s;' + (done ? 'animation:agp-bar-pulse 600ms ease 2;' : '') + '"></div>' +
              '</div>' +
              '<div style="font-size:11px;color:#666;padding-bottom:6px;">' +
                (done ? '✓ All pages reviewed' : n + ' of ' + tot + ' pages reviewed') +
              '</div>' +
              '<div style="font-size:11px;padding-bottom:10px;line-height:1.5;' + (done ? 'color:#16a34a;font-weight:700;' : 'color:#999;') + '">' +
                (done ? '🎉 All done! Hit the button below when you\'re ready.' : 'Open each page, check it off when done.') +
              '</div>' +
            '</div>';

          // Checklist — unchecked first
          var sorted = items.slice().sort(function(a, b) {
            return (checked[a.path] ? 1 : 0) - (checked[b.path] ? 1 : 0);
          });
          html += '<div id="agp-list" style="overflow-y:auto;flex:1;padding:6px 0;max-height:320px;">';
          sorted.forEach(function(item) {
            var isChecked = !!checked[item.path];
            var pUrl = pastelBase ? pastelBase + item.path : '';
            html +=
              '<div class="agp-row" data-path="' + item.path + '" style="display:flex;align-items:center;' +
              'gap:10px;padding:9px 14px;cursor:pointer;' +
              'background:' + (isChecked ? '#f8f6ff' : 'transparent') + ';' +
              'border-bottom:1px solid #f5f5f5;transition:background 120ms;">' +
                '<input type="checkbox" data-path="' + item.path + '" ' + (isChecked ? 'checked' : '') +
                ' style="width:15px;height:15px;accent-color:' + P + ';flex-shrink:0;cursor:pointer;" />' +
                '<span style="flex:1;color:' + (isChecked ? '#aaa' : P) + ';' +
                'text-decoration:' + (isChecked ? 'line-through' : 'none') + ';font-size:13px;">' +
                  item.label +
                '</span>' +
                '<a href="' + item.path + '" class="agp-open" ' +
                'style="font-size:11px;color:' + P + ';text-decoration:none;font-weight:700;' +
                'white-space:nowrap;padding:2px 8px;border:1.5px solid ' + P + ';' +
                'border-radius:6px;flex-shrink:0;transition:all 120ms;" onclick="event.stopPropagation()">Open page</a>' +
              '</div>';
          });
          html += '</div>';

          // Scroll hint (shown when list is long)
          if (items.length > 5) {
            html += '<div id="agp-scroll-hint" style="text-align:center;font-size:11px;color:#aaa;padding:4px 0 2px;' +
              'border-top:1px solid #f5f5f5;">Scroll for more pages ↓</div>';
          }

          // Submit button
          html +=
            '<div style="padding:12px 14px;border-top:1px solid #ede9f8;">' +
              '<div id="agp-err" style="font-size:11px;color:#c0392b;display:none;margin-bottom:6px;"></div>' +
              '<button id="agp-submit" style="background:' + (done ? P : '#c9c1d6') + ';color:#fff;border:none;border-radius:10px;' +
              'padding:12px;font-weight:800;font-size:13px;cursor:' + (done ? 'pointer' : 'not-allowed') + ';width:100%;' +
              'letter-spacing:.02em;font-family:' + FONT + ';transition:all 200ms;' +
              (done ? 'box-shadow:0 4px 14px rgba(56,28,79,.22);' : '') +
              '">Submit review to Alloy</button>' +
            '</div>';
        }

        html += '</div>';
        wrap.innerHTML = html;

        // ── Events ───────────────────────────────────────────────────────
        document.getElementById('agp-minimize').onclick = function() { isOpen = false; render(); };

        if (!isStarted) {
          document.getElementById('agp-start').onclick = function() {
            isStarted = true;
            try { localStorage.setItem(ISK, '1'); } catch(_) {}
            render();
          };
          return;
        }

        // Hide scroll hint once user scrolls to bottom
        var listEl = document.getElementById('agp-list');
        var hintEl = document.getElementById('agp-scroll-hint');
        if (listEl && hintEl) {
          listEl.onscroll = function() {
            if (listEl.scrollTop + listEl.clientHeight >= listEl.scrollHeight - 10) {
              hintEl.style.display = 'none';
            }
          };
        }

        wrap.querySelectorAll('.agp-row').forEach(function(row) {
          row.onclick = function(e) {
            if (e.target.tagName === 'A' || e.target.tagName === 'INPUT') return;
            var path = row.getAttribute('data-path');
            var prevDone = count() === items.length;
            checked[path] = !checked[path];
            try { localStorage.setItem(SK, JSON.stringify(checked)); } catch(_) {}
            var nowDone = count() === items.length;
            render();
            if (nowDone && !prevDone) launchConfetti();
          };
        });

        wrap.querySelectorAll('input[type=checkbox]').forEach(function(cb) {
          cb.onchange = function() {
            var path = cb.getAttribute('data-path');
            var prevDone = count() === items.length;
            checked[path] = cb.checked;
            try { localStorage.setItem(SK, JSON.stringify(checked)); } catch(_) {}
            var nowDone = count() === items.length;
            render();
            if (nowDone && !prevDone) launchConfetti();
          };
          cb.onclick = function(e) { e.stopPropagation(); };
        });

        if (!isSubmitted) {
          var submitEl = document.getElementById('agp-submit');

          submitEl.onclick = function() {
            if (count() < items.length || isSubmitting) return;
            isSubmitting = true;
            submitEl.disabled = true;
            submitEl.textContent = 'Sending…';
            submitEl.style.background = '#5a4070';

            fetch('/api/review-complete', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                checkedCount: count(),
                total:        items.length,
                items:        items.map(function(i) {
                                return { label: i.label, path: i.path, checked: !!checked[i.path] };
                              }),
                ticketId:     ticketId,
              }),
            })
            .then(function(r) {
              if (!r.ok) throw new Error('err');
              isSubmitted = true;
              isSubmitting = false;
              try { localStorage.removeItem(SK); localStorage.removeItem(ISK); } catch(_) {}
              render();
            })
            .catch(function() {
              isSubmitting = false;
              submitEl.disabled = false;
              submitEl.textContent = 'I\'m Done Reviewing';
              submitEl.style.background = P;
              var err = document.getElementById('agp-err');
              if (err) { err.textContent = 'Submission failed — email team@alloygp.co'; err.style.display = 'block'; }
            });
          };
        }
      }

      render();

      // ── Hide Pastel "Finish review" button ───────────────────────────────
      function hidePastelBtn() {
        document.querySelectorAll('button').forEach(function(el) {
          if (el.textContent.trim().toLowerCase().indexOf('finish review') !== -1) {
            el.style.setProperty('display', 'none', 'important');
            var p = el.parentElement;
            if (p) p.style.setProperty('display', 'none', 'important');
          }
        });
      }
      hidePastelBtn();
      var pastelObs = new MutationObserver(hidePastelBtn);
      pastelObs.observe(document.body, { childList: true, subtree: true });

    })();
    </script>

    <slot name="scripts" />
  </body>
</html>
